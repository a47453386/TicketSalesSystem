@model IEnumerable<TicketSalesSystem.Models.PublicNotice>
@Html.AntiForgeryToken()

@{
    ViewData["Title"] = "公告管理";
}
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/PublicNotice/PublicNoticeIndex.css" asp-append-version="true" />

@* 🚩 2. 主容器：鎖定暗色網格背景 *@
<div class="order-management-scope admin-body p-4">

    @* --- [頂部標頭：HUD 儀表板] --- *@
    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom border-info border-opacity-25 pb-3">
        <h1 class="neon-header m-0">
            <i class="bi bi-broadcast me-3"></i>@ViewData["Title"]
        </h1>
        <a asp-action="Create" class="btn-cyber px-4">
            <i class="bi bi-plus-lg me-2"></i>新增公告
        </a>
    </div>

    @* --- [主數據卡片：半透明磨砂感] --- *@
    <div class="cyber-card">
        <div class="table-responsive custom-scroll">
            <table class="table table-hover align-middle mb-0 border-0">
                <thead>
                    <tr class="text-center border-bottom border-info border-opacity-25">
                        <th class="pt-4 border-0" style="width: 22%;">
                            <div class="tech-key1">標題</div>
                        </th>

                        <th class="pt-4 border-0" style="width: 22%;">
                            <div class="tech-key1">摘要</div>
                        </th>

                        <th class="pt-4 border-0" style="width: 14%;"> 
                            <div class="tech-key1">排程</div>
                        </th>

                        <th class="pt-4  border-0" style="width: 15%;">
                            <div class="tech-key1">狀態</div>
                        </th>

                        <th class="pt-4  border-0" >
                            <div class="tech-key1">負責人</div>
                        </th>

                        <th class="text-end pe-4 border-0" style="width: 10%;">
                            <div class="tech-key1">操作</div>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="border-bottom border-info border-opacity-10">
                            @* 標題 *@
                            <td class="ps-4">
                                <div class="fw-bold text-info" style="font-size: 1.1rem; letter-spacing: 1px;">@item.PublicNoticeTitle</div>
                            </td>

                            @* 摘要 *@
                            <td>
                                <div class="synopsis-text">@item.PublicNoticeDescription</div>
                            </td>

                            @* 排程 *@
                            <td>
                                <div class="font-monospace small">
                                    <div class="text-cyan mb-1">
                                        <i class="bi bi-arrow-up-right-circle me-1"></i>上架: @(item.PublishTime?.ToString("yyyy-MM-dd") ?? "IMMEDIATE")
                                    </div>
                                    <div class="text-danger opacity-100">
                                        <i class="bi bi-arrow-down-left-circle me-1"></i>下架: @(item.RemovalTime?.ToString("yyyy-MM-dd") ?? "PERSISTENT")
                                    </div>
                                </div>
                            </td>

                           

                            @* 狀態標籤：套用右圓角戰術樣式 *@
                            <td class="text-center">
                                @if (item.PublicNoticeStatus)
                                {
                                    <div class="status-badge" style="cursor: pointer;" onclick="toggleNoticeStatus('@item.PublicNoticeID')">
                                        <span class="status-badge-icon"></span> 已上架
                                    </div>
                                }
                                else
                                {
                                    <div class="status-badge" style="cursor: pointer; color: #ff3333; border-color: #ff3333; background-color: rgba(26, 0, 0, 0.6) !important;" onclick="toggleNoticeStatus('@item.PublicNoticeID')">
                                        <span class="status-badge-icon" style="background-color: #ff3333;"></span> 未上架
                                    </div>
                                }
                            </td>

                            @* 負責人 *@
                            <td class="text-center font-monospace small text-info opacity-100">
                                @(item.Employee?.Name ?? "無")
                            </td>

                            @* 操作按鈕 *@
                            <td class="text-end pe-4">
                                <div class="d-flex gap-2 justify-content-end">
                                    <a asp-action="Edit" asp-route-id="@item.PublicNoticeID" class="btn-cyber-icon" title="編輯">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.PublicNoticeID" class="btn-cyber-icon" title="詳細資料">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button type="button" class="btn-cyber-icon border-danger text-danger"
                                            onclick="globalDelete('@item.PublicNoticeID', '@item.PublicNoticeTitle', 'PublicNotices')">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

