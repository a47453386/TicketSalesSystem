@model IEnumerable<TicketSalesSystem.Models.PublicNotice>
@Html.AntiForgeryToken()

@{
    ViewData["Title"] = "公告後台管理";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center my-4">
        <h1 class="h3 m-0">@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg"></i> 新增公告
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted">
                        <tr>
                            <th class="ps-4">公告標題</th>
                            <th style="width: 25%;">摘要</th>
                            <th>排程期間</th>
                            <th>系統紀錄</th>
                            <th class="text-center">狀態</th>
                            <th class="text-center">負責人</th>
                            <th class="text-end pe-4">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold text-dark">@item.PublicNoticeTitle</span>
                                </td>
                                <td>
                                    <p class="text-muted small mb-0 text-truncate" style="max-width: 200px;">
                                        @item.PublicNoticeDescription
                                    </p>
                                </td>
                                <td>
                                    <div class="small">
                                        <div class="text-primary">
                                            <i class="bi bi-calendar-check"></i> 上：@(item.PublishTime?.ToString("yyyy/MM/dd") ?? "未設定")
                                        </div>
                                        <div class="text-danger">
                                            <i class="bi bi-calendar-x"></i> 下：@(item.RemovalTime?.ToString("yyyy/MM/dd") ?? "永久")
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small text-muted">
                                        <div>建：@item.CreatedTime.ToString("yyyy/MM/dd HH:mm")</div>
                                        @if (item.UpdatedAt.HasValue)
                                        {
                                            <div class="fst-italic text-info">更：@item.UpdatedAt.Value.ToString("yyyy/MM/dd HH:mm")</div>
                                        }
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-inline-block">
                                        <input class="form-check-input status-toggle" type="checkbox"
                                               id="switch_@item.PublicNoticeID"
                                               data-id="@item.PublicNoticeID"
                                               @(item.PublicNoticeStatus ? "checked" : "")>
                                        <label class="form-check-label small" for="switch_@item.PublicNoticeID" id="label_@item.PublicNoticeID">
                                            @(item.PublicNoticeStatus ? "已發佈" : "待發佈")
                                        </label>
                                    </div>
                                </td>
                                <td class="text-center text-muted small">
                                    @item.Employee?.EmployeeID
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@item.PublicNoticeID" class="btn btn-outline-secondary" title="編輯">
                                            編輯
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.PublicNoticeID" class="btn btn-outline-secondary" title="詳情">
                                            詳情
                                        </a>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                data-delete-id="@item.PublicNoticeID"
                                                onclick="globalDelete('@item.PublicNoticeID', '@item.PublicNoticeTitle', 'PublicNotices')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>

                                    @* 隱藏的刪除 Form *@
                                    <form id="delete-form-@item.PublicNoticeID" asp-action="Delete" method="post" class="d-none">
                                        <input type="hidden" name="id" value="@item.PublicNoticeID" />
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
