@model TicketSalesSystem.Models.PublicNotice
@Html.AntiForgeryToken()

@{
    ViewData["Title"] = "公告詳細資訊";
}
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/PublicNotice/PublicEdit.css" asp-append-version="true" />

@* 🚩 確保外層套用 admin-body 基底 *@
<div class="order-management-scope admin-body p-4">

    @* --- [1. 頂部標頭：HUD 儀表板風格] --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-info border-opacity-25 pb-3">
        <div>
            @* <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb m-0 p-0 bg-transparent">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-info text-decoration-none opacity-50">NOTICE_LIST</a></li>
                    <li class="breadcrumb-item active text-white">FILE_DIAGNOSTICS</li>
                </ol>
            </nav> *@
            <h1 class="neon-header m-0">
                <i class="bi bi-info-circle me-3"></i>@ViewData["Title"]
        </div>
        <div class="d-flex gap-3">
            <a asp-action="Edit" asp-route-id="@Model?.PublicNoticeID" class="btn-cyber">
                <i class="bi bi-pencil-square me-2"></i>公告更新
            </a>
            <a asp-action="Index" class="btn-cyber btn-cyber-warning">
                <i class="bi bi-arrow-left me-2"></i>回公告清單
            </a>
        </div>
    </div>

    <div class="row g-4">
        @* --- [2. 左側：公告主體內容 (Core Data Stream)] --- *@
        <div class="col-lg-8">
            <div class="cyber-card p-4 h-100">
                <div class="tech-key mb-4">公告資料</div>

                <h2 class="text-info fw-bold mb-4 font-monospace" style="letter-spacing: 2px;">
                    @Model.PublicNoticeTitle
                </h2>

                <div class="terminal-window p-4 custom-scroll">
                    @Model.PublicNoticeDescription
                </div>
            </div>
        </div>

        @* --- [3. 右側：發佈管理與日誌 (Metadata Panel)] --- *@
        <div class="col-lg-4">
            @* 發佈管理卡片 *@
            <div class="cyber-card p-4 mb-4">
                <div class="tech-key mb-4">發佈資訊</div>

                <div class="d-flex flex-column gap-4">
                    @* 狀態切換區 *@
                    <div class="info-block">
                        <small class="text-info opacity-100 d-block font-monospace mb-2">公告狀態</small>
                        <div class="d-flex align-items-center justify-content-between bg-dark bg-opacity-50 p-3 border border-info border-opacity-10">
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input status-toggle" type="checkbox"
                                       id="statusSwitch"
                                       data-id="@Model.PublicNoticeID"
                                       @(Model.PublicNoticeStatus ? "checked" : "")>
                            </div>
                            <div id="statusIndicator">
                                @if (Model.PublicNoticeStatus)
                                {
                                    <div class="status-badge"><span class="status-badge-icon">✓</span> 已上架</div>
                                }
                                else
                                {
                                    <div class="status-badge" style="color: #ff3333; border-color: #ff3333; background-color: rgba(26, 0, 0, 0.6) !important;">
                                        <span class="status-badge-icon" style="background-color: #ff3333;">✕</span> 未上架
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    @* 負責人與時間 *@
                    <div class="info-block">
                        <small class="text-info opacity-100 d-block font-monospace mb-1">負責人</small>
                        <div class="fs-5 text-white fw-bold"># @(Model.Employee?.EmployeeID ?? "SYSTEM_AUTO")</div>
                    </div>

                    <div class="info-block">
                        <small class="text-info opacity-100 d-block font-monospace mb-1">上架時間</small>
                        <div class="text-cyan font-monospace">
                            <i class="bi bi-calendar-event me-2"></i>@(Model.PublishTime?.ToString("yyyy-MM-dd HH:mm") ?? "IMMEDIATE")
                        </div>
                    </div>

                    <div class="info-block">
                        <small class="text-info opacity-100 d-block font-monospace mb-1">下架時間</small>
                        <div class="font-monospace @(Model.RemovalTime < DateTime.Now ? "text-danger" : "text-white")">
                            <i class="bi bi-calendar-x me-2"></i>@(Model.RemovalTime?.ToString("yyyy-MM-dd HH:mm") ?? "MANUAL_ONLY")
                        </div>
                    </div>
                </div>
            </div>

            @* 系統日誌卡片 *@
            <div class="cyber-card p-4">
                <div class="tech-key mb-4" style="background: linear-gradient(90deg, #ffcc00, transparent 120%); color: #fff;">系統日誌</div>
                <div class="font-monospace" style="font-size: 0.8rem;">
                    <div class="mb-3 p-2 border-start border-info">
                        <div class="opacity-100">建立日期:</div>
                        <div class="text-info">@Model.CreatedTime.ToString("yyyy-MM-dd HH:mm:ss")</div>
                    </div>
                    <div class="p-2 border-start border-warning">
                        <div class="opacity-100">最後更新日期:</div>
                        <div class="text-warning">@(Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "無")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $('.status-toggle').change(function () {
            const checkbox = $(this);
            const noticeId = checkbox.data('id');
            const indicator = $('#statusIndicator');
            const token = $('input[name="__RequestVerificationToken"]').val();

            // 視覺預饋
            indicator.css('opacity', '0.5');

            $.ajax({
                url: '@Url.Action("ToggleStatus", "PublicNotices")',
                type: 'POST',
                data: { id: noticeId, __RequestVerificationToken: token },
                success: function (res) {
                    indicator.css('opacity', '1');
                    if (res.success) {
                        // 🚩 動態更新為符合 CSS 規範的 Badge
                        if (res.newStatus) {
                            indicator.html('<div class="status-badge"><span class="status-badge-icon">✓</span> 已上架</div>');
                        } else {
                            indicator.html('<div class="status-badge" style="color: #ff3333; border-color: #ff3333; background-color: rgba(26, 0, 0, 0.6) !important;"><span class="status-badge-icon" style="background-color: #ff3333;">✕</span> 未上架</div>');
                        }
                    } else {
                        alert(res.message);
                        checkbox.prop('checked', !checkbox.prop('checked'));
                    }
                },
                error: function () {
                    indicator.css('opacity', '1');
                    alert("連線失敗 / PROTOCOL_ERR");
                    checkbox.prop('checked', !checkbox.prop('checked'));
                }
            });
        });
    </script>
}