@model IEnumerable<TicketSalesSystem.Models.PublicNotice>

@{
    ViewData["Title"] = "最新消息";
    // 這裡通常使用前端的 Layout
    Layout = "_UserLayout";
}
<style>
    /* 公告卡片樣式優化 */
    .notice-card {
        transition: transform 0.3s, box-shadow 0.3s;
        border-radius: 12px;
    }

        .notice-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.1) !important;
        }

    /* 標題懸浮效果 */
    .hover-primary:hover {
        color: #0d6efd !important;
    }

    /* 文字截斷（最多顯示兩行） */
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* 中間的分隔線（僅在電腦版顯示） */
    @@media (min-width: 768px) {
        .border-end-md {
            border-right: 1px solid #dee2e6 !important;
        }
    }
</style>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold display-5">最新消息</h1>
        <p class="text-muted">掌握最新活動資訊與系統重要公告</p>
        <div class="mx-auto bg-primary" style="width: 60px; height: 4px; border-radius: 2px;"></div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            @if (!Model.Any())
            {
                <div class="text-center py-5 border rounded bg-light">
                    <i class="bi bi-megaphone text-secondary display-1"></i>
                    <p class="mt-3 text-muted fs-5">目前尚無任何公告</p>
                </div>
            }
            else
            {
                <div class="notice-list">
                    @foreach (var item in Model)
                    {
                        <div class="card border-0 shadow-sm mb-4 notice-card">
                            <div class="card-body p-4">
                                <div class="row align-items-center">
                                    <div class="col-md-3 border-end-md text-center text-md-start">
                                        <div class="text-primary fw-bold mb-0">
                                            <i class="bi bi-calendar-event me-2"></i>@item.CreatedTime.ToString("yyyy / MM / dd")
                                        </div>
                                    </div>

                                    <div class="col-md-9 ps-md-4 mt-3 mt-md-0">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <h5 class="fw-bold mb-0 ">
                                                <a asp-action="UserDetails" asp-route-id="@item.PublicNoticeID" class="text-decoration-none text-dark hover-primary">
                                                    @item.PublicNoticeTitle
                                                </a>
                                            </h5>
                                            <a asp-action="UserDetails" asp-route-id="@item.PublicNoticeID" class="text-decoration-none text-primary fw-bold small">
                                                閱讀更多 <i class="bi bi-arrow-right"></i>
                                            </a>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

