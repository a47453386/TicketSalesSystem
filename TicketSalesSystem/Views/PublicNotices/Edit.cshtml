@model TicketSalesSystem.Models.PublicNotice

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>PublicNotice</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="PublicNoticeID" />
            <div class="form-group">
                <label asp-for="PublicNoticeTitle" class="control-label"></label>
                <input asp-for="PublicNoticeTitle" class="form-control" />
                <span asp-validation-for="PublicNoticeTitle" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PublicNoticeDescription" class="control-label"></label>
                <textarea asp-for="PublicNoticeDescription" class="form-control"></textarea>
                <span asp-validation-for="PublicNoticeDescription" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CreatedTime" class="control-label"></label>
                <input asp-for="CreatedTime" class="form-control" />
                <span asp-validation-for="CreatedTime" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UpdatedAt" class="control-label"></label>
                <input asp-for="UpdatedAt" class="form-control" />
                <span asp-validation-for="UpdatedAt" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="PublicNoticeStatus" /> @Html.DisplayNameFor(model => model.PublicNoticeStatus)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="EmployeeID" class="control-label"></label>
                <select asp-for="EmployeeID" class="form-control" asp-items="ViewBag.EmployeeID"></select>
                <span asp-validation-for="EmployeeID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
