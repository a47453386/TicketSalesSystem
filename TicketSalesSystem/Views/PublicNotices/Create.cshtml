@model TicketSalesSystem.Models.PublicNotice

@{
    ViewData["Title"] = "新增公告";
}
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/PublicNotice/PublicCreate.css" asp-append-version="true" />
@* 🚩 確保外層套用 admin-body 基底與作用域 *@
<div class="order-management-scope admin-body p-4">

    @* --- [1. 頂部標頭：霓虹發光感] --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-info border-opacity-25 pb-3">
        <div>
           @*  <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb m-0 p-0 bg-transparent">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-info text-decoration-none opacity-50">NOTICE_LIST</a></li>
                    <li class="breadcrumb-item active text-white">CREATE_NEW</li>
                </ol>
            </nav> *@
            <h1 class="neon-header m-0">
                <i class="bi bi-plus-circle me-3"></i>@ViewData["Title"]
            </h1>
        </div>
        <a asp-action="Index" class="btn-cyber btn-cyber-warning">
            <i class="bi bi-arrow-left me-2"></i>回清單
        </a>
    </div>

    @* --- [2. 主編輯卡片：Cyber-Card] --- *@
    <div class="cyber-card p-5">
        <form asp-action="Create">
            @* 隱藏欄位與驗證摘要 *@
            <div asp-validation-summary="ModelOnly" class="text-danger small font-monospace mb-4"></div>
            <input asp-for="PublicNoticeID" type="hidden" value="@Guid.NewGuid().ToString()" />

            <div class="row g-4">
                @* --- A. 核心標題區 --- *@
                <div class="col-12">
                    <div class="tech-key">公告標題</div>
                    <div class="mt-2">
                        <input asp-for="PublicNoticeTitle" class="form-control order-input"
                               placeholder="請輸入標題..." />
                        <span asp-validation-for="PublicNoticeTitle" class="text-danger small"></span>
                    </div>
                </div>

                @* --- B. 詳細內容區 --- *@
                <div class="col-12">
                    <div class="tech-key">公告內容</div>
                    <div class="mt-2">
                        <textarea asp-for="PublicNoticeDescription" class="form-control order-input custom-scroll"
                                  rows="6" placeholder="請輸入公告內容..."></textarea>
                        <span asp-validation-for="PublicNoticeDescription" class="text-danger small"></span>
                    </div>
                </div>

                @* --- C. 排程設定區 --- *@
                <div class="col-md-6">
                    <div class="tech-key">預計上架日</div>
                    <div class="mt-2">
                        <input asp-for="PublishTime" class="form-control order-input" type="datetime-local" />
                        <span asp-validation-for="PublishTime" class="text-danger small"></span>
                        <div class="small text-info opacity-50 mt-1 font-monospace">時間到即自動上架</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="tech-key">預計下架日</div>
                    <div class="mt-2">
                        <input asp-for="RemovalTime" class="form-control order-input" type="datetime-local" />
                        <span asp-validation-for="RemovalTime" class="text-danger small"></span>
                        <div class="small text-danger opacity-50 mt-1 font-monospace">時間到即自動下架</div>
                    </div>
                </div>

                @* --- D. 底部提交區 --- *@
                <div class="col-12 mt-5 pt-4 border-top border-info border-opacity-10 text-center">
                    <button type="submit" class="btn-cyber px-5 py-2 fs-5">
                        <i class="bi bi-cloud-upload-fill me-2"></i>新增並儲存
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}