@model TicketSalesSystem.Models.PublicNotice

@{
    ViewData["Title"] = "新增公告";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-plus-circle me-2"></i>新增公告</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">返回列表</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input asp-for="PublicNoticeID" type="hidden" value="@Guid.NewGuid().ToString()" />
                
                @* <input asp-for="FAQID" type="hidden" value="@Guid.NewGuid().ToString()" /> *@
                <div class="row">
                    <div class="col-md-12 mb-3">
                    </div>
                    <div class="col-md-12 mb-3">
                        <label asp-for="PublicNoticeTitle" class="form-label fw-bold">公告標題</label>
                        <input asp-for="PublicNoticeTitle" class="form-control" placeholder="例如：系統維護公告" />
                        <span asp-validation-for="PublicNoticeTitle" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="PublicNoticeDescription" class="form-label fw-bold">公告內容</label>
                        <textarea asp-for="PublicNoticeDescription" class="form-control" rows="5" placeholder="請輸入詳細公告內容..."></textarea>
                        <span asp-validation-for="PublicNoticeDescription" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col">
                            <label asp-for="PublishTime" class="control-label"></label>
                            <input asp-for="PublishTime" class="form-control" />
                            <span asp-validation-for="PublishTime" class="text-danger"></span>
                        </div>
                        <div class="col">
                            <label asp-for="RemovalTime" class="control-label"></label>
                            <input asp-for="RemovalTime" class="form-control" />
                            <span asp-validation-for="RemovalTime" class="text-danger"></span>
                        </div>
                    </div>



                    <div class="mt-4 border-top pt-3">
                        <button type="submit" class="btn btn-success px-5">新增</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<div asp-validation-summary="All" class="text-danger"></div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
