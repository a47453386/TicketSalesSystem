@model TicketSalesSystem.Models.Member

@{
    ViewData["Title"] = "PLAYER PROFILE";
    Layout = "_UserLayout";
}

@* 🚩 引入像素風 CSS (建議已放在 site.css) *@
<style>
    /* 🚩 亮綠色霓虹文字 */
    .text-pixel-success-bright {
        color: #00ff66 !important; /* 極亮霓虹綠 */
        text-shadow: 0 0 5px rgba(0, 255, 102, 0.5); /* 輕微發光感 */
    }
    .pixel-profile-card {
        background-color: #212529;
        border: 4px solid #fff;
        box-shadow: 8px 8px 0px #000;
        color: white;
    }

    .pixel-table th {
        background-color: #343a40 !important;
        color: var(--pixel-yellow) !important;
        border-bottom: 2px dashed #555 !important;
    }

    .pixel-table td {
        background-color: #212529 !important;
        color: #fff !important;
        border-bottom: 2px dashed #555 !important;
    }
    /* 簡訊驗證盒 */
    .verify-pixel-box {
        background-color: #000;
        border: 2px solid var(--pixel-blue);
        padding: 15px;
        margin-top: 10px;
    }
   
    /* 自定義科技按鈕 */
    .btn-cyber-tech {
        background: rgba(0, 242, 255, 0.1);
        color: #00f2ff;
        border: 1px solid #00f2ff;
        border-radius: 2px;
        font-family: 'Share Tech Mono', monospace;
        letter-spacing: 2px;
        text-transform: uppercase;
        box-shadow: 0 0 10px rgba(0, 242, 255, 0.3);
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        /* 移除 hover 的顏色跳變，改為維持原樣 */
        .btn-cyber-tech:hover,
        .btn-cyber-tech:active,
        .btn-cyber-tech:focus {
            background: rgba(0, 242, 255, 0.15) !important;
            color: #00f2ff !important;
            border-color: #00f2ff !important;
            box-shadow: 0 0 15px rgba(0, 242, 255, 0.5) !important;
            outline: none;
        }

        /* 禁用狀態（發送中） */
        .btn-cyber-tech:disabled {
            border-color: #555;
            color: #555;
            background: rgba(255, 255, 255, 0.05);
            box-shadow: none;
        }
</style>

<div class="container mt-4 mb-5 font-pixel">

    <div class="row">
        @* --- 左側：玩家頭像與驗證狀態 --- *@
        <div class="col-lg-4">
            <div class="card pixel-profile-card text-center py-5 mb-4">
                <div class="pixel-icon-box mx-auto mb-3" style="width: 100px; height: 100px; background-color: var(--pixel-blue);">
                    <i class="bi bi-person-fill display-3 text-white"></i>
                </div>
                <h3 class="fw-bold text-pixel-yellow">@Model.Name</h3>


                <div class="px-3">
                    <label class="pixel-label d-block">手機驗證狀態</label>

                    @if (Model.IsPhoneVerified)
                    {
                        <div class="p-2 border text-pixel-success-bright">
                            <i class="bi bi-check-all"></i>身分已認證
                        </div>
                    }
                    else
                    {
                        <div class="input-group">
                            <input type="text" value="@Model.Tel" class="form-control pixel-input bg-dark text-white" readonly />
                            <button type="button" class="btn btn-cyber-tech btn-sm" id="btnSendSMS">發送驗證碼</button>
                        </div>

                        @* 驗證輸入框 *@
                        <div class="verify-pixel-box mt-3" id="verifyBox" style="display:none;">
                            <p class="small text-pixel-blue">認證碼(6位數):</p>
                            <div class="input-group mb-2">
                                <input type="text" id="inputVerifyCode" class="form-control pixel-input text-center" maxlength="6" placeholder="000000">
                                <button type="button" class="btn btn-success btn-pixel-sm" id="btnSubmitSMS">發送</button>
                            </div>
                            <small class="text-white-50" id="timerText"></small>
                        </div>
                    }
                </div>

                @* --- 帳號狀態與導覽連結 --- *@
                <div class="row text-start px-4 mt-2">
                    <div class="col">
                        <small class="text-white d-block">帳號狀態</small>

                        @if (Model.AccountStatusID == "A")
                        {
                            <span class="text-pixel-success-bright fw-bold">● 正常</span>
                        }
                        else if (Model.AccountStatusID == "B")
                        {
                            <span class="text-danger fw-bold">● 停權</span>
                        }
                        else
                        {
                            <span class="text-secondary fw-bold">● 離線</span>
                        }
                    </div>

                    @* 🚩 新增：側邊導覽選單 *@
                    <div class="col">
                        <small class="text-white d-block">快速跳轉</small>
                        <div class="list-unstyled">
                            <div class="mb-1">
                                <a asp-controller="Home" asp-action="Index" class="pixel-link-green">
                                    <i class="bi bi-house-fill me-2"></i>首頁
                                </a>
                            </div>
                            <div class="mb-1">
                                <a asp-controller="UserOrders" asp-action="UserIndex" class="pixel-link-green">
                                    <i class="bi bi-ticket-perforated-fill me-2"></i>訂單查詢
                                </a>
                            </div>
                            <div>
                                <a asp-controller="UserMembers" asp-action="Index" asp-route-id="@Model.MemberID" class="pixel-link-green">
                                    <i class="bi bi-arrow-left-square-fill me-2"></i>回到會員中心
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        @* --- 右側：詳細屬性表 --- *@
        <div class="col-lg-8">
            <div class="card pixel-profile-card">
                <div class="card-header border-bottom border-secondary bg-transparent py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-pixel-yellow fw-bold"><i class="bi bi-controller me-2"></i>會員資料</h5>
                     <a asp-action="UserEdit" asp-route-id="@Model.MemberID" class="pixel-link-green">
                        <i class="bi bi-gear-fill me-1"></i>更新資料
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table pixel-table mb-0">
                            <tbody>
                                <tr>
                                    <th class="ps-4 py-3" style="width: 35%;">身分證字號</th>
                                    <td class="ps-4 py-3">@Model.NationalID</td>
                                </tr>

                                <tr>
                                    <th class="ps-4 py-3">性別 </th>
                                    <td class="ps-4 py-3">@(Model.Gender == true ? "男 " : "女 ")</td>
                                </tr>
                                <tr>
                                    <th class="ps-4 py-3">出生日期</th>
                                    <td class="ps-4 py-3">@Model.Birthday.ToString("yyyy-MM-dd")</td>
                                </tr>
                                <tr>
                                    <th class="ps-4 py-3">電子郵件</th>
                                    <td class="ps-4 py-3">@Model.Email</td>
                                </tr>
                                <tr>
                                    <th class="ps-4 py-3">通訊地址</th>
                                    <td class="ps-4 py-3 text-break">@Model.Address</td>
                                </tr>
                                <tr>
                                    <th class="ps-4 py-3">建立時間</th>
                                    <td class="ps-4 py-3 text-white-50">@Model.CreatedDate.ToString("yyyy-MM-dd")</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>



        <div class="mt-2 py-2 border-top border-bottom border-secondary text-white-50 overflow-hidden" style="white-space: nowrap;">
            <marquee scrollamount="5">>>> 系統訊息: 預售票請先手機認證...無手機驗證無法購買票券... <<<</marquee>
        </div>


    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            // --- 簡訊發送邏輯 ---
            $(document).on("click", "#btnSendSMS", function() {
                var $btn = $(this);
                $btn.prop('disabled', true).text("SENDING...");

                $.post("/UserMembers/SendSmsCode", { id: "@Model.MemberID" }, function(res) {
                    if (res.success) {
                        $("#inputVerifyCode").val("");
                        $("#verifyBox").fadeIn(); // 像素風建議用 fadeIn 或直接顯示
                        startTimer(60, $btn);
                    } else {
                        alert("⚠️ " + res.message);
                        $btn.prop('disabled', false).text("RETRY");
                    }
                });
            });

            // --- 倒數計時器 ---
            function startTimer(duration, $button) {
                var timer = duration;
                var interval = setInterval(function () {
                    $button.text(timer + "s ");
                    if (--timer < 0) {
                        clearInterval(interval);
                        $button.prop('disabled', false).text("RESEND CODE");
                    }
                }, 1000);
            }

            // --- 驗證碼提交 ---
            $(document).on("click", "#btnSubmitSMS", function() {
                var code = $("#inputVerifyCode").val();
                if (code.length < 6) { alert("ENTER 6 DIGITS!"); return; }

                $.post("/UserMembers/SubmitVerifyCode", { id: "@Model.MemberID", inputCode: code }, function(res) {
                    if (res.success) {
                        alert("🎉 LEVEL UP! 驗證成功");
                        location.reload();
                    } else {
                        alert("❌ 驗證碼輸入錯誤!");
                        $("#inputVerifyCode").val("");
                    }
                });
            });
        });
    </script>
}