@model TicketSalesSystem.Models.Member
@{
    ViewData["Title"] = "PLAYER DASHBOARD";
    Layout = "_UserLayout";
}

<style>
    /* 核心背景：深色網格 */
    body {
        background-color: #0a0a0a;
        background-image: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
        background-size: 100% 2px, 3px 100%;
    }

    /* 像素方塊核心 */
    .dashboard-tile {
        background: rgba(20, 20, 20, 0.8);
        border: 3px solid var(--pixel-blue);
        box-shadow: 0 0 15px rgba(0, 153, 255, 0.3);
        margin-bottom: 20px;
        position: relative;
        padding: 15px;
        transition: transform 0.2s;
    }

        .dashboard-tile:hover {
            transform: scale(1.02);
            border-color: var(--pixel-yellow);
        }

    /* 方塊標題 */
    .tile-header {
        font-family: 'Press Start 2P', cursive;
        font-size: 0.7rem;
        color: var(--pixel-blue);
        border-bottom: 2px dashed #444;
        margin-bottom: 15px;
        padding-bottom: 5px;
        display: flex;
        justify-content: space-between;
    }

    /* 螢光文字 */
    .neon-text {
        text-shadow: 0 0 5px var(--pixel-blue);
        color: #fff;
    }

    .neon-yellow {
        color: var(--pixel-yellow);
        text-shadow: 0 0 5px var(--pixel-yellow);
    }

    /* 頂部狀態列 */
    .top-status-bar {
        border: 2px solid #fff;
        padding: 10px;
        margin-bottom: 30px;
        font-size: 0.8rem;
        background: #000;
    }
</style>

<div class="container mt-4 font-pixel">

    <div class="top-status-bar d-flex justify-content-between align-items-center">
        <div>
            <span class="text-success">● SYSTEM_STATUS: STABLE</span> |
            <span class="text-white-50">UPTIME: 99.9%</span>
        </div>
        @* <div class="text-pixel-yellow">
            <i class="bi bi-person-fill"></i> PLAYER: @ViewBag.MemberName
        </div> *@
    </div>

    <div class="row">

        <div class="col-md-3">
            <div class="dashboard-tile" style="border-color: #ff00ff;">
                <div class="tile-header"><span>訂單中心</span></div>
                <h4 class="neon-text">累績數量</h4>
                <div class="display-6 neon-yellow">@ViewBag.OrderCount</div>
                @* <p class="small text-white-50">訂單中心</p> *@
                <a asp-controller="UserOrders" asp-action="UserIndex" class="btn btn-sm btn-outline-info w-100 mt-2">訂單查詢</a>
            </div>

            <div class="dashboard-tile" style="border-color: var(--pixel-yellow);">
                <div class="tile-header"><span>問題中心</span></div>
                <h4 class="neon-text">發問數</h4>
                <div class="display-6 text-danger">@ViewBag.QuestionCount</div>
                @* <p class="small text-white-50">PENDING TASKS</p> *@
                <a asp-controller="Questions" asp-action="Index" class="btn btn-sm btn-outline-warning w-100 mt-2">查看</a>
            </div>
        </div>

        <div class="col-md-6">
            <div class="dashboard-tile" style="min-height: 410px;">
                @* <div class="tile-header">
                    <span><i class="bi bi-activity"></i> SYSTEM_CORE</span>
                    <span class="text-success">ACTIVE</span>
                </div> *@
                <div class="text-center py-4">
                    <div class="pixel-icon-box mx-auto mb-3" style="width:120px; height:120px; background: #000; border: 4px solid var(--pixel-blue);">
                        <i class="bi bi-shield-shaded display-1 text-pixel-blue"></i>
                    </div>
                    <h2 class="text-white fw-bold">@ViewBag.MemberName</h2>
                    <h2 class="text-white fw-bold">會員中心</h2>
                    <p class="text-white-50">手機認證 
                        <span class="text-success">
                            @if (Model.IsPhoneVerified)
                            {
                                <span class="text-success">[ <i class="bi bi-check-pixel"></i> 已認證 ]</span>
                            }
                            else
                            {
                                <span class="text-danger">[ <i class="bi bi-x-pixel"></i> 尚未認證 ]</span>
                            }
                        </span>
                    </p>

                    <div class="mt-4 px-3">
                       @*  <a asp-action="UserDetails" asp-route-id="@Model.MemberID" class="btn btn-pixel-primary w-100 py-3 mb-3">
                            <i class="bi bi-person-bounding-box me-2"></i> 詳細資訊
                        </a>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-secondary btn-sm flex-grow-1">DEBUG</button>
                            <button class="btn btn-outline-danger btn-sm flex-grow-1">LOGOUT</button>
                        </div> *@
                        
                        <div class="d-flex gap-2">
                            <a asp-action="UserDetails" asp-route-id="@Model.MemberID" class="btn btn-outline-secondary btn-sm flex-grow-1">
                                <i class="bi bi-person-bounding-box me-2"></i> 詳細資訊
                            </a>
                            <button class="btn btn-outline-danger btn-sm flex-grow-1">登出</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-tile" style="min-height: 410px; border-color: #00ffcc;">
                <div class="tile-header"><span>最新紀錄</span></div>
                <ul class="list-unstyled small">
                    <li class="mb-3 border-bottom border-secondary pb-2">
                        <span class="text-info">[登入]</span> 成功進入系統<br />
                        <span class="time-stamp text-white-50">@ViewBag.LoginTime</span>
                    </li>
                    <li class="mb-3 border-bottom border-secondary pb-2">
                        <span class="text-warning">[問題]</span> <br>
                        總提問數
                        <span class="time-stamp text-white-50">@ViewBag.QuestionTotal</span><br>
                        今日新增提問
                        <span class="time-stamp text-white-50">@ViewBag.QuestionToday</span>
                        最新提問時間
                        <span class="time-stamp text-white-50">@ViewBag.LatestQuestionTime</span>
                        
                    </li>
                    <li class="mb-3 border-bottom border-secondary pb-2">
                        <span class="text-success">[訂單]</span> 購買了 2 張門票<br />
                        <span class="time-stamp text-white-50">@ViewBag.LatestOrderTime</span>
                    </li>
                </ul>
            </div>
        </div>

    </div>

    <div class="mt-2 py-2 border-top border-bottom border-secondary text-white-50 overflow-hidden" style="white-space: nowrap;">
        <marquee scrollamount="5">>>> SYSTEM_MSG: 歡迎來到售票系統控制台... 請確保您的帳號安全... 下次搶票時間為 2026/03/01... <<<</marquee>
    </div>
</div>