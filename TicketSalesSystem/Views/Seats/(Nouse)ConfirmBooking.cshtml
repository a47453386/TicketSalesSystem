@model List<TicketSalesSystem.ViewModel.VMSeats>


<div class="container mt-5">
    <h3>測試購票流程</h3>
    <div class="card p-3 mb-3">
        <p>場次：<span class="badge bg-secondary">@ViewBag.SessionID</span></p>
        <p>票區：<span class="badge bg-info">@ViewBag.AreaID</span></p>
    </div>

    <div class="mb-3">
        <button id="autoBtn" class="btn btn-outline-success">自動配位 (2張)</button>
        <button id="submitBtn" class="btn btn-danger" disabled>送出訂單</button>
    </div>

    <div id="statusMsg" class="mt-3"></div>
    <div id="receipt" class="mt-3 border p-3" style="display:none;">
        <h5>訂單明細</h5>
        <hr>
        <div id="receiptContent"></div>
    </div>
</div>

<style>
    .btn-seat {
        width: 45px;
        height: 45px;
        font-size: 10px;
    }

        .btn-seat.selected {
            background-color: #ffc107 !important;
            color: black !important;
            border-color: #ffc107 !important;
        }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        let selectedSeats = [];
        let TotalAmount=0;

        // 1. 自動配位功能
        document.getElementById('autoBtn').onclick = async function() {
            const response = await fetch('/Seats/AutoAssign', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    SessionID: "@ViewBag.SessionID",
                    AreaID: "@ViewBag.AreaID",
                    VenueID: "V001", // 這裡要改為你資料庫實際有的 VenueID
                    Count: 2
                })
            });
            const result = await response.json();
            if(result.success) {
                selectedSeats = result.seats;
                document.getElementById('statusMsg').innerHTML = `<div class="alert alert-success">已自動選位：${selectedSeats.join(', ')}</div>`;
                document.getElementById('submitBtn').disabled = false;
            } else {
                alert(result.message);
            }
        };

        // 2. 送出訂單並產出明細
        document.getElementById('submitBtn').onclick = async function() {
            const bookingData = {
                SessionID: "@ViewBag.SessionID",
                AreaID: "@ViewBag.TicketsAreaID",
                MemberID: "83542560-1941-48b9-af77-00fc42536fed", // ⚠️ 重要：請確認資料庫 Member 表是否有 M001
                PaymentMethodID: "C", // ⚠️ 重要：請確認資料庫 PaymentMethod 表是否有 P01
                Seats: selectedSeats,
                TotalAmount=TotalAmount
            };

                try {
            // 2. 發送請求
            const response = await fetch('/Seats/ConfirmBooking', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bookingData) // 確保這裡變數名稱對了
            });

            // 3. 解析 JSON
            const result = await response.json();

            // 4. 根據結果執行跳轉或提示
            if (result.success) {
                // ✅ 既然要跳轉，就直接導向 Success Action
                // 注意：result.orderID 的大小寫需與後端 VMBookingResponse 定義一致
                window.location.href = '/Seats/Success/' + result.orderID;
            } else {
                alert("訂購失敗：" + result.message);
            }
        } catch (error) {
            console.error("發生錯誤:", error);
            alert("系統發生異常，請開啟 F12 檢查 Console");
        }
        };
    </script>
}
