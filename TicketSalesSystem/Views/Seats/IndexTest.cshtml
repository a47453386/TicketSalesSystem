@{
    ViewData["Title"] = "IndexTest";
}

<div class="container mt-5">
    <h2>1. 選擇場次</h2>
    <div class="list-group mb-4" id="sessionList">
        @foreach (var s in ViewBag.Sessions)
        {
            <button class="list-group-item list-group-item-action session-item"
                    data-id="@s.SessionID">
                @s.StartTime.ToString("yyyy/MM/dd HH:mm")
            </button>
        }
    </div>

    <div id="areaSection" style="display:none;">
        <h2>2. 選擇票區</h2>
        <div class="row" id="areaList">
        </div>
    </div>

    <div id="bookingSection" class="mt-4" style="display:none;">
        <div class="card bg-light p-3">
            <h4>3. 確認選擇並自動配位</h4>
            <p id="selectedInfo"></p>
            <div class="mb-3" style="max-width: 200px;">
                <label class="form-label">購買張數：</label>
                <select id="ticketCount" class="form-select">
                    <option value="1">1 張</option>
                    <option value="2">2 張</option>
                    <option value="3">3 張</option>
                    <option value="4">4 張</option>
                </select>
            </div>
            <button id="autoAndConfirmBtn" class="btn btn-primary btn-lg">一鍵自動配位並購票</button>
        </div>
    </div>
</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        let currentSession = "";
        let currentArea = "";
        let currentVenue = "";

        // 1. 點選場次
        document.querySelectorAll('.session-item').forEach(btn => {
            btn.onclick = async function() {
                currentSession = this.dataset.id;

                // 切換樣式
                document.querySelectorAll('.session-item').forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                // 抓取票區
                const res = await fetch(`/Seats/GetAreasBySession?sessionId=${currentSession}`);
                const areas = await res.json();

                console.log(areas);

                let areaHtml = areas.map(a => `
                    <div class="col-md-4 mb-3">
                        <div class="card area-card p-3 border-primary" style="cursor:pointer"
                             onclick="selectArea(
                                '${a.ticketsAreaID}',
                                '${a.ticketsAreaName}',
                                ${a.price},
                                '${a.venueID}'
                             )">
                            <h5>${a.ticketsAreaName}</h5>
                            <p class="text-danger">$${a.price}</p>
                        </div>
                    </div>
                `).join('');


                document.getElementById('areaList').innerHTML = areaHtml;
                document.getElementById('areaSection').style.display = 'block';
                document.getElementById('bookingSection').style.display = 'none';
            };
        });

        // 2. 選擇票區
        function selectArea(id, name, price, venueId) {
            currentArea = id;
            currentVenue = venueId;

            document.getElementById('selectedInfo').innerText = `已選場次：${currentSession} | 票區：${name} ($${price})`;
            document.getElementById('bookingSection').style.display = 'block';
        }

               // 3. 一鍵配位並購票 (直接呼叫整合了配位邏輯的 ConfirmBooking)
               document.getElementById('autoAndConfirmBtn').onclick = async function() {
            try {
                // 1. 抓取畫面上選單的張數 (這行一定要加！)
                const ticketCountElement = document.getElementById('ticketCount');
                const countValue = parseInt(ticketCountElement.value);

                // 2. 建立請求物件
                const bookingData = {
                    SessionID: currentSession,
                    AreaID: currentArea,
                    MemberID: "06a540b0-e768-4e8e-bb05-39288e3c5a3f",
                    PaymentMethodID: "A",
                    Count:countValue, // 確保名稱與後端 ViewModel 一致
                    Seat:[]
                };

                // 3. 發送請求
                const res = await fetch('/Seats/ConfirmBooking', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(bookingData)
                });

                // 如果伺服器回傳 404 或 500
                if (!res.ok) {
                    alert(`伺服器錯誤: ${res.status}`);
                    return;
                }

                const result = await res.json();

                if (result.success) {
                    // 將 1-1, 1-2 格式優化為 1排1號, 1排2號
                    const seatDisplay = result.seats.map(s => s.replace('-', '排') + '號').join(', ');
                    alert(`訂購成功！\n訂單編號：${result.orderID}\n分配座位：${seatDisplay}`);
                    window.location.href = "/Order/Success?id=" + result.orderID;
                } else {
                    alert("訂購失敗：" + result.message);
                }
            } catch (error) {
                // 在控制台印出真正的錯誤原因，方便我們除錯
                console.error("詳細錯誤訊息:", error);
                alert("執行過程發生錯誤，請按 F12 查看 Console 控制台");
            }
        };
    </script>
}

