@model TicketSalesSystem.Models.Session

@{
    ViewData["Title"] = "選擇票區 - " + Model.Programme.ProgrammeName;
    Layout = "_UserLayout";
}

<style>
    /* 拓元風格微調 */
    .bg-tixcraft {
        background-color: #003a8c !important;
    }

    .btn-primary {
        background-color: #003a8c;
        border: none;
    }

        .btn-primary:hover {
            background-color: #002766;
        }

    .area-card {
        border: 1px solid #dee2e6;
        cursor: pointer;
        transition: all 0.2s ease;
        border-radius: 4px;
    }

        .area-card:hover:not(.sold-out) {
            border-color: #003a8c;
            background-color: #f0f5ff;
            transform: translateX(5px);
        }

        .area-card.active {
            border-color: #003a8c;
            background-color: #003a8c;
            color: white;
        }

            .area-card.active .text-danger, .area-card.active .text-muted {
                color: #fff !important;
            }

        .area-card.sold-out {
            opacity: 0.6;
            cursor: not-allowed;
            background-color: #f8f9fa;
        }

    .seat-map-img {
        max-width: 100%;
        cursor: zoom-in;
    }

    .area-name {
        font-size: 1.1rem;
    }

    @@media (min-width: 992px) {
        .sticky-bottom-md {
            position: sticky;
            bottom: 20px;
        }
    }
</style>

<div class="bg-dark text-white py-3 mb-4 shadow-sm">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="h4 mb-1 fw-bold">@Model.Programme.ProgrammeName</h1>
                <p class="mb-0 small text-light">
                    <i class="bi bi-calendar3 me-1"></i> @Model.StartTime.ToString("yyyy/MM/dd (ddd) HH:mm")
                    <span class="mx-2">|</span>
                    <i class="bi bi-geo-alt-fill me-1"></i> @Model.Programme.Place?.PlaceName
                </p>
            </div>
            <div class="col-md-4 text-md-end">
                <div class="badge bg-primary px-3 py-2">步驟 2: 選擇票區</div>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold"><i class="bi bi-map me-2"></i>座位區域圖</div>
                <div class="card-body text-center bg-light">
                    @if (!string.IsNullOrEmpty(Model.Programme.SeatImage))
                    {
                        <img src="@Url.Content("~/Photos/SeatImage/" + Model.Programme.SeatImage)"
                             class="img-fluid rounded shadow-sm seat-map-img"
                             alt="座位圖" />
                    }
                    else
                    {
                        <div class="py-5 text-muted">暫無座位圖資訊</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <h2 class="h5 mb-3 fw-bold"><i class="bi bi-list-ul me-2"></i>請選擇票區</h2>
            <div class="area-list-container" id="areaList">
                @foreach (var area in Model.TicketsArea.OrderByDescending(a => a.Price))
                {
                    bool isSoldOut = area.SeatCount <= 0;

                    <div class="card area-card mb-2 @(isSoldOut ? "sold-out" : "")"
                         onclick="@(isSoldOut ? "" : $"selectArea('{area.TicketsAreaID}', '{area.TicketsAreaName}', {area.Price}, '{area.VenueID}')")">
                        <div class="card-body d-flex justify-content-between align-items-center py-3">
                            <div>
                                <div class="fw-bold area-name">@area.TicketsAreaName</div>
                                <div class="text-danger fw-bold">TWD $@area.Price.ToString("N0")</div>
                            </div>
                            <div class="text-end">
                                @* 🚩 修正：判斷基準改為 Remaining *@
                                @if (area.Remaining <= 0)
                                {
                                    <span class="badge bg-secondary">已售罄</span>
                                }
                                else if (area.Remaining < 10)
                                {
                                    <span class="badge bg-warning text-dark">最後少數</span>
                                    <div class="small text-muted mt-1">剩餘 @area.Remaining</div>
                                }
                                else
                                {
                                    <span class="badge bg-success">還有座位</span>
                                    @* 如果不想讓消費者看到精確數字（怕被猜出賣得好不好），通常大型訂票系統只會顯示「還有座位」 *@
                                    <div class="small text-muted mt-1">剩餘 @area.Remaining</div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div id="bookingSection" class="mt-4 sticky-bottom-md" style="display:none;">
                <div class="card border-primary shadow-lg overflow-hidden">
                    <div class="card-body p-0">
                        <div class="p-3 bg-light border-bottom">
                            <p id="selectedInfo" class="mb-0 fw-bold"></p>
                        </div>
                        <div class="p-3">
                            <label class="form-label small fw-bold">
                                購買張數 (本活動限購 @(Model.Programme.LimitPerOrder ?? 4) 張，您還可購買 @ViewBag.RemainingQuota 張)：
                            </label>

                            <div class="input-group mb-3">
                                @if (ViewBag.RemainingQuota > 0)
                                {
                                    <select id="ticketCount" class="form-select border-primary">
                                        @* 🚩 根據計算出來的「剩餘配額」產生選項 *@
                                        @for (int i = 1; i <= (int)ViewBag.RemainingQuota; i++)
                                        {
                                            <option value="@i">@i 張</option>
                                        }
                                    </select>
                                    <button id="autoAndConfirmBtn" class="btn btn-primary px-4 fw-bold">
                                        下一步，確認座位 <i class="bi bi-chevron-right"></i>
                                    </button>
                                }
                                else
                                {
                                    <div class="alert alert-danger w-100 mb-0">
                                        <i class="bi bi-exclamation-octagon-fill me-2"></i>
                                        您已達到本活動的購買上限，無法再購買。
                                    </div>
                                    @* 隱藏原本的按鈕區域 *@
                                    <script>
                                        document.addEventListener("DOMContentLoaded", function() {
                                            $("#bookingSection").show(); // 強制顯示讓警示框出來
                                        });
                                    </script>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        // 將 ID 直接從 Model 讀取到 JS 變數
        let currentSession = "@Model.SessionID";
        let currentArea = "";
        let currentVenue = "";
        let currentPrice = 0;

        // 2. 選擇票區
        function selectArea(id, name, price, venueId) {
            currentArea = id;
            currentVenue = venueId;
            currentPrice = price;

            // 樣式切換
           document.querySelectorAll('.area-card').forEach(c => c.classList.remove('active'));
            event.currentTarget.classList.add('active');

            document.getElementById('selectedInfo').innerHTML =
                `<i class="bi bi-check-circle-fill text-success"></i> 已選：${name} / 單價：$${price.toLocaleString()}`;

            $("#bookingSection").fadeIn();
        }

        // 3. 一鍵配位並購票 (簡化版：僅處理跳轉)
        document.getElementById('autoAndConfirmBtn').onclick = async function() {
            const ticketCountElement = document.getElementById('ticketCount');
            const countValue = parseInt(ticketCountElement.value);

            const remainingLimit = @(ViewBag.RemainingQuota ?? 0);
            if (countValue > remainingLimit) {
            alert(`❌ 您在此活動還能購買的票數剩餘 ${remainingLimit} 張，請重新選擇。`);
            return;
        }

            if (!currentArea) {
                alert("請先選擇票區！");
                return;
            }

            const bookingData = {
                VenueID: currentVenue,
                SessionID: currentSession,
                TicketsAreaID: currentArea,
                PaymentMethodID: "A",
                Count: countValue,
                TotalAmount: currentPrice * countValue,
                Seats: []
            };

            this.disabled = true;
            this.innerHTML = `<span class="spinner-border spinner-border-sm"></span> 處理中...`;

            try {
                const res = await fetch('/Seats/ConfirmBooking', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(bookingData)
                });

                const result = await res.json();

                if (result.success) {
                    // ✅ 核心改動：直接跳轉，不彈 alert，不啟動計時器
                    // 因為 Success 頁面會處理這些資訊
                    window.location.href = '/Seats/Payment/' + result.orderID;
                } else {
                    alert("❌ 訂購失敗：" + result.message);
                    this.disabled = false;
                    this.innerHTML = `<i class="bi bi-lightning-fill"></i> 一鍵自動配位並購票`;
                }
            } catch (error) {
                console.error(error);
                alert("⚠️ 系統異常，請稍後再試。");
                this.disabled = false;
                this.innerHTML = `<i class="bi bi-lightning-fill"></i> 一鍵自動配位並購票`;
            }
        }; 
              
    </script>
}