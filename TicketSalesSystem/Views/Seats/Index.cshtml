@model TicketSalesSystem.Models.Session

@{
    bool isPassed = ViewBag.IsVerified ?? false;
    Layout = "_UserLayout";
}

<style>
    /* 🚩 專屬：賽博購票介面微調 */
    #securityGate {
        display: @(isPassed ? "none" : "flex") !important;
        min-height: 60vh;
        align-items: center;
        justify-content: center;
    }

    /* 像素驗證碼畫布 */
    #captchaCanvas {
        background: #000;
        border: 2px solid var(--pixel-blue);
        cursor: pointer;
        image-rendering: pixelated;
    }

    /* 區域選擇卡片 - 像素化 */
    .pixel-area-card {
        background-color: rgba(0, 0, 0, 0.6) !important;
        border: 2px solid var(--pixel-blue) !important;
        border-radius: 0 !important;
        cursor: pointer;
        transition: all 0.1s;
        margin-bottom: 10px;
       
    }

    
        .pixel-area-card:hover:not(.sold-out) {
            border-color: var(--pixel-yellow) !important;
            transform: translateX(8px);
            background-color: rgba(255, 204, 0, 0.1) !important;
        }

        .pixel-area-card.active {
            border-color: var(--pixel-pink) !important;
            background-color: rgba(255, 0, 204, 0.2) !important;
            box-shadow: -4px 0 0 var(--pixel-pink);
        }

        .pixel-area-card.sold-out {
            opacity: 0.4;
            filter: grayscale(100%);
            cursor: not-allowed;
            border-color: #444 !important;
        }

    /* 全螢幕等候室 - 黑化 */
    #waitingRoom {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.95);
        z-index: 9999;
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
    }

    .seat-map-frame {
        border: 4px solid var(--pixel-blue);
        padding: 10px;
        background: #000;
        box-shadow: 10px 10px 0 #000;
    }

    .pixel-badge-status {
        font-family: 'Press Start 2P', cursive;
        font-size: 1.2rem;
        padding: 5px 10px;
    }

    .fs-pixel-small{
        font-size: 1.2rem !important;
    }

    .text-pixel-yellow {
        color: var(--pixel-yellow) !important;
    }

    .text-pixel-blue {
        color: var(--pixel-blue) !important;
    }

    .text-pixel-pink, .bg-pixel-pink {
        color: var(--pixel-pink) !important;
    }

    .text-pixel-muted {
        color: var(--pixel-text-muted) !important;
    }
</style>

@* --- 🚩 伺服器緩衝區 (Waiting Room) --- *@
<div id="waitingRoom">
    <div class="spinner-border text-pixel-blue" style="width: 5rem; height: 5rem; border-width: 0.5rem;"></div>
    <h3 class="text-pixel-yellow mt-5 fw-bold dot-blink">尋票中...</h3>
    <p class="text-pixel-muted fs-pixel-small">請勿重新整理(F5)...</p>
</div>

@* --- 🚩 頂部活動標頭 --- *@
<div class="pixel-container-box p-3 mb-4 bg-black">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="h4 text-pixel-yellow mb-1 fw-bold">節目名稱: @Model.Programme.ProgrammeName</h1>
            <p class="mb-0 fs-6 text-pixel-blue">
                <i class="bi bi-cpu me-2"></i>演出時間: @Model.StartTime.ToString("yyyy/MM/dd HH:mm")
            </p>
        </div>
        <div class="col-md-4 text-md-end">
            <div id="stepBadge" class="pixel-badge-status @(isPassed ? "text-pixel-blue" : "text-pixel-pink")">
                [ @(isPassed ? "第二步: 請選票區" : "第一步: 驗證碼") ]
            </div>
        </div>
    </div>
</div>

<div class="container">
    @* --- 🚩 第一階段：安全門口 (Captcha) --- *@
    <div id="securityGate">
        <div class="pixel-container-box" style="max-width: 450px; width: 100%;">
            <div class="text-center py-3 border-bottom border-secondary mb-4">
                <h5 class="text-pixel-blue mb-0">安全協議驗證</h5>
            </div>
            <div class="text-center">
                <p class="fs-pixel-small text-pixel-muted mb-4">請輸入解密金鑰以存取票務數據</p>
                <div class="mb-4">
                    <canvas id="captchaCanvas" width="200" height="60" onclick="generateCaptcha()"></canvas>
                    <div class="btn-pixel-text mt-3" onclick="generateCaptcha()">
                        <i class="bi bi-arrow-clockwise"></i> [ 重新產生  ]
                    </div>
                </div>
                <input type="text" id="captchaInput" class="form-control pixel-input text-center mb-4"
                       placeholder="KEY_CODE" maxlength="4" autocomplete="off">
                <button class="btn-pixel w-100 py-3" onclick="verifyGateCaptcha()">
                    執行驗證 <i class="bi bi-shield-lock ms-2"></i>
                </button>
            </div>
        </div>
    </div>

    @* --- 🚩 第二階段：選購區域 --- *@
    <div id="mainPurchaseContent" class="row">
        <div class="col-lg-7 mb-4">
            <div class="pixel-container-box">
                <h6 class="text-pixel-blue mb-3"><i class="bi bi-map me-2"></i>座位分佈圖</h6>
                <div class="seat-map-frame text-center">
                    @if (!string.IsNullOrEmpty(Model.Programme.SeatImage))
                    {
                        <img src="@Url.Content("~/Photos/SeatImage/" + Model.Programme.SeatImage)" class="img-fluid" alt="座位圖" />
                    }
                    else
                    {
                        <div class="py-5 text-pixel-muted">[ 無法讀取圖像數據 ]</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5 ">
            <h2 class="text-pixel-yellow h5 mb-4 fw-bold"><i class="bi bi-list-ul me-2"></i>選擇目標票區</h2>
            <div class="area-list-container">
                @foreach (var area in Model.TicketsArea.OrderByDescending(a => a.Price))
                {
                    bool isSoldOut = area.Remaining <= 0;
                    <div class="pixel-area-card @(isSoldOut ? "sold-out" : "")"
                         onclick="@(isSoldOut ? "" : $"selectArea('{area.TicketsAreaID}', '{area.TicketsAreaName}', {area.Price}, '{area.VenueID}', {area.Remaining})")">
                        <div class="p-3 d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-white fw-bold">@area.TicketsAreaName</div>
                                <div class="text-pixel-pink fw-bold fs-pixel-small">$@area.Price.ToString("N0")</div>
                            </div>
                            <div class="text-end">
                                @if (isSoldOut)
                                {
                                    <span class="text-pixel-muted fs-pixel-small">[ 已完售 ]</span>
                                }
                                else
                                {
                                    <span class="text-pixel-blue fs-pixel-small">[ 開賣中 ]</span>
                                    <div class="text-white-50 mt-1" style="font-size: 1rem;">剩餘數量: @area.Remaining</div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* --- 🚩 浮動訂購確認區 --- *@
            <div id="bookingSection" class="mt-4" style="display:none;">
                <div class="pixel-container-box border-pixel-pink p-0 overflow-hidden shadow-lg">
                    <div class="p-3 bg-pixel-pink text-dark fw-bold">
                        <i class="bi bi-check-circle-fill"></i> <span class="text-white" id="selectedInfo"></span>
                    </div>
                    <div class="p-3">
                        <label class="text-pixel-blue fs-pixel-small mb-2 d-block">數量 (您的剩餘額度: <span id="userQuota">@ViewBag.RemainingQuota</span> 張)</label>
                        <div class="input-group">
                            @* 🚩 改為由 JavaScript 動態生成的 select *@
                            <select id="ticketCount" class="form-select pixel-input">
                            </select>
                            <button id="confirmBtn" class="btn-pixel ms-2 px-4" onclick="confirmBooking()">
                                確認訂購
                            </button>
                        </div>
                        @* 預留一個區塊顯示錯誤訊息 *@
                        <div id="quotaError" class="text-pixel-pink fs-pixel-small mt-2" style="display:none;">
                            [ 警告：已達帳號購買上限 ]
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentSession = "@Model.SessionID";
        let currentArea = "";
        let currentVenue = "";
        let currentPrice = 0;
        let captchaCode = "";

        document.addEventListener("DOMContentLoaded", function() {
            if (document.getElementById('captchaCanvas')) {
                generateCaptcha();
            }
        });

        function generateCaptcha() {
            const canvas = document.getElementById('captchaCanvas');
            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.font = "bold 38px Arial"; ctx.fillStyle = "#003a8c";
            const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
            captchaCode = "";
            for (let i = 0; i < 4; i++) {
                let char = chars.charAt(Math.floor(Math.random() * chars.length));
                captchaCode += char;
                ctx.save(); ctx.translate(45 * i + 30, 45); ctx.rotate((Math.random() - 0.5) * 0.4);
                ctx.fillText(char, 0, 0); ctx.restore();
            }
        }

        // --- 🚩 修改點 1：增加按鈕狀態回饋 ---
        async function verifyGateCaptcha() {
               const input = document.getElementById('captchaInput').value.toUpperCase();
                if (input.length < 4) {
                    alert("請輸入完整驗證碼！");
                    return;
                }

            const btn = event.currentTarget;
            btn.disabled = true;
            btn.innerHTML = `<span class="spinner-border spinner-border-sm"></span> 驗證中...`;

            try {
                const res = await fetch(`/Seats/VerifyGateCaptcha`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({
                        id: currentSession,
                        captchaInput: input
                        // 🚩 注意：不要傳送正確答案給後端，後端應該自己從 MemoryCache 拿
                    })
                });
                const result = await res.json();

                if (result.success) {
                    // 驗證成功後的流程維持原樣...
                    document.getElementById('securityGate').style.display = 'none';
                    document.getElementById('waitingRoom').style.display = 'flex';
                    startQueuePolling();
                } else {
                    alert(result.message);
                    generateCaptcha(); // 失敗就換一張
                    btn.disabled = false;
                    btn.innerHTML = `驗證並進入選位 <i class="bi bi-shield-lock ms-1"></i>`;
                }
            } catch (e) {
                btn.disabled = false;
                btn.innerHTML = `驗證並進入選位 <i class="bi bi-shield-lock ms-1"></i>`;
                alert("連線異常，請重新整理頁面。");
            }
        }

        function startQueuePolling() {
            const pollInterval = setInterval(async () => {
                const res = await fetch(`/Seats/CheckQueueStatus?id=${currentSession}`);
                const data = await res.json();

                if (data.canEnter) {
                    clearInterval(pollInterval);
                    unlockContent();
                }
            }, 2500);
        }

        function unlockContent() {
            document.getElementById('waitingRoom').style.display = 'none';
            document.getElementById('mainPurchaseContent').style.display = 'flex';
            document.getElementById('stepBadge').innerHTML = "步驟 2: 選擇票區";
            document.getElementById('stepBadge').className = "badge bg-primary px-3 py-2";
        }

               function selectArea(id, name, price, venueId, areaRemaining) { // 🚩 增加傳入票區剩餘數
            currentArea = id;
            currentVenue = venueId;
            currentPrice = price;

            // 1. 處理樣式切換
            document.querySelectorAll('.pixel-area-card').forEach(c => c.classList.remove('active'));
            event.currentTarget.classList.add('active');

            // 2. 更新選取資訊
            document.getElementById('selectedInfo').innerHTML = `${name} - $${price.toLocaleString()}`;

            // 3. 🚩 重點：動態更新下拉選單數量
            const userMax = parseInt("@ViewBag.RemainingQuota"); // 帳號還能買幾張
            const areaMax = areaRemaining; // 該票區還剩幾張
            const finalMax = Math.min(userMax, areaMax, 4); // 取三者最小值 (假設單次最高4張)

            const countSelect = document.getElementById('ticketCount');
            const confirmBtn = document.getElementById('confirmBtn');
            const quotaError = document.getElementById('quotaError');

            countSelect.innerHTML = ""; // 清空舊選項

            if (userMax <= 0) {
                // 帳號額度已滿
                countSelect.style.display = "none";
                confirmBtn.style.display = "none";
                quotaError.style.display = "block";
            } else {
                // 產生正確數量的選項
                countSelect.style.display = "block";
                confirmBtn.style.display = "block";
                quotaError.style.display = "none";

                for (let i = 1; i <= finalMax; i++) {
                    let opt = document.createElement('option');
                    opt.value = i;
                    opt.innerHTML = i + " 張";
                    countSelect.appendChild(opt);
                }
            }

            $("#bookingSection").fadeIn();
        }

        // --- 🚩 修改點 2：增加防呆檢查、按鈕 Loading、增加全螢幕轉圈圈效果 ---
        async function confirmBooking() {
            // 1. 防呆檢查
            if (!currentArea) {
                alert("請先選擇票區！");
                return;
            }

            // 2. 取得全螢幕等候室元素
            const waitingRoom = document.getElementById('waitingRoom');
            const btn = event.currentTarget;
            const originalHtml = btn.innerHTML;

            // 3. 🚩 啟動全螢幕轉圈圈
            waitingRoom.style.display = 'flex';

            // 修改轉圈圈文字，讓使用者知道現在是「訂購中」
            const waitingText = waitingRoom.querySelector('h4');
            if (waitingText) waitingText.innerText = "正在為您預留座位，請稍候...";

            const count = parseInt(document.getElementById('ticketCount').value);
            const bookingData = {
                VenueID: currentVenue,
                SessionID: currentSession,
                TicketsAreaID: currentArea,
                PaymentMethodID: "A",
                Count: count,
                TotalAmount: currentPrice * count,
                Seats: []
            };

            try {
                // 🚩 Demo 亮點：人為延遲 1.2 秒，展現「流量削峰」排隊效果
                await new Promise(resolve => setTimeout(resolve, 1200));

                const res = await fetch('/Seats/ConfirmBooking', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(bookingData)
                });

                const result = await res.json();

                if (result.success) {
                    // ✅ 成功：直接導向付款頁面（不關閉轉圈，讓頁面自然切換）
                    window.location.href = '/Seats/Payment/' + result.orderID;
                } else {
                    // ❌ 失敗：隱藏全螢幕轉圈，恢復按鈕，並顯示錯誤
                    waitingRoom.style.display = 'none';
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                    alert("❌ 訂購失敗：" + result.message);
                }
            } catch (error) {
                // ⚠️ 異常：隱藏全螢幕轉圈
                waitingRoom.style.display = 'none';
                btn.disabled = false;
                btn.innerHTML = originalHtml;
                console.error("Booking Error:", error);
                alert("⚠️ 系統繁忙或連線異常，請稍後再試。");
            }
        }
    </script>
}