@{
    ViewData["Title"] = "IndexTest";
}

<div id="timerContainer" style="display:none;" class="alert alert-warning">
    請於 <span id="countdownTimer" class="fw-bold text-danger">10:00</span> 內完成付款，逾時位置將被釋出。
</div>

<div class="container mt-5">
    <h2>1. 選擇場次</h2>
    <div class="list-group mb-4" id="sessionList">
        @foreach (var s in ViewBag.Session)
        {
            <button class="list-group-item list-group-item-action session-item"
                    data-id="@s.SessionID">
                @s.StartTime.ToString("yyyy/MM/dd HH:mm")
            </button>
        }
    </div>

    <div id="areaSection" style="display:none;">
        <h2>2. 選擇票區</h2>
        <div class="row" id="areaList">
        </div>
    </div>

    <div id="bookingSection" class="mt-4" style="display:none;">
        <div class="card bg-light p-3">
            <h4>3. 確認選擇並自動配位</h4>
            <p id="selectedInfo"></p>
            <div class="mb-3" style="max-width: 200px;">
                <label class="form-label">購買張數：</label>
                <select id="ticketCount" class="form-select">
                    <option value="1">1 張</option>
                    <option value="2">2 張</option>
                    <option value="3">3 張</option>
                    <option value="4">4 張</option>
                </select>
            </div>
            <button id="autoAndConfirmBtn" class="btn btn-primary btn-lg">一鍵自動配位並購票</button>
        </div>
    </div>
</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        let currentSession = "";
        let currentArea = "";
        let currentVenue = "";
        let currentPrice=0;

        //倒數計時
        function startTimer(duration, display) {
            let timer = parseInt(duration);
            if (isNaN(timer))
            {
            timer = 600;
            }
            // 如果之前已經有計時器在跑，先清掉它以免疊加
            if (window.bookingInterval) clearInterval(window.bookingInterval);

            function updateDisplay()
            {
            let minutes = Math.floor(timer / 60);
            let seconds = timer%10;
             minutes = minutes < 10 ? "0" + minutes : minutes;
             seconds = seconds < 10 ? "0" + seconds : seconds;
             display.textContent = `${minutes}:${seconds}`;
            }

            updateDisplay();

            window.bookingInterval = setInterval(function () {
            if (timer-- < 0)
            {
                 clearInterval(window.bookingInterval);
                 display.textContent = "00:00";
                 alert("⏰ 時間到！您的訂位已被取消，請重新選擇座位。");
                 location.reload();
                 return;
            }
            updateDisplay();
            }, 1000);
        }

        // 1. 點選場次
        document.querySelectorAll('.session-item').forEach(btn => {
            btn.onclick = async function() {
                currentSession = this.dataset.id;

                // 切換樣式
                document.querySelectorAll('.session-item').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                try {
                // 抓取票區
                const res = await fetch(`/Seats/GetAreasBySession?sessionId=${currentSession}`);
                const areas = await res.json();

                console.log(areas);

                let areaHtml = areas.map(a => `
                    <div class="col-md-4 mb-3">
                        <div class="card area-card p-3 border-primary" style="cursor:pointer"
                             onclick="selectArea(
                                '${a.ticketsAreaID}',
                                '${a.ticketsAreaName}',
                                ${a.price},
                                '${a.venueID}'
                             )">
                            <h5>${a.ticketsAreaName}</h5>
                            <p class="text-danger">$${a.price}</p>
                        </div>
                    </div>
                `).join('');


                document.getElementById('areaList').innerHTML = areaHtml;
                document.getElementById('areaSection').style.display = 'block';
                document.getElementById('bookingSection').style.display = 'none';
                } catch (err) {
                console.error("抓取票區失敗:", err);
            }
            };
        });

        // 2. 選擇票區
        function selectArea(id, name, price, venueId) {
            currentArea = id;
            currentVenue = venueId;
            currentPrice = price;


            document.getElementById('selectedInfo').innerText = `已選場次：${currentSession} | 票區：${name} ($${price})`;
            document.getElementById('bookingSection').style.display = 'block';
        }

               // 3. 一鍵配位並購票 (直接呼叫整合了配位邏輯的 ConfirmBooking)
               document.getElementById('autoAndConfirmBtn').onclick = async function() {
            try {
                // 1. 抓取畫面上選單的張數 (這行一定要加！)
                const ticketCountElement = document.getElementById('ticketCount');
                const countValue = parseInt(ticketCountElement.value);

                // 2. 建立請求物件
                const bookingData = {
                    VenueID:currentVenue,
                    SessionID: currentSession,
                    TicketsAreaID: currentArea,
                    MemberID: "008783c7-31da-4d39-bba4-70ceed5939e4",
                    PaymentMethodID: "A",
                    Count:countValue, // 確保名稱與後端 ViewModel 一致
                    TotalAmount:currentPrice*countValue,
                    Seat:[]
                };

                // 3. 發送請求
                const res = await fetch('/Seats/ConfirmBooking', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(bookingData)
                });

                // 如果伺服器回傳 404 或 500
                if (!res.ok) {
                    alert(`伺服器錯誤: ${res.status}`);
                    return;
                }

                const result = await res.json();

            if (result.success) {
                console.log("後端回傳資料:", result);

                // 1. 將座位格式優化 (例如 1-1 變成 1排1號)
                const seatDisplay = result.seats.map(s => s.replace('-', '排') + '號').join(', ');

                // 2. 取得後端計算出的總金額 (假設後端回傳欄位名為 totalAmount)
                const formattedAmount = new Intl.NumberFormat('zh-TW',
                {
                    style: 'currency',
                    currency: 'TWD',
                    maximumFractionDigits: 0
                })
                .format(result.finalAmount);

                // 3. 在 Alert 中加入金額資訊
                alert(`🎉訂購成功！座位已為您保留 10 分鐘。\n\n` +
                      `📌 訂單編號：${result.orderID}\n` +
                      `💺 分配座位：${seatDisplay}\n` +
                      `💰 應付總額：${formattedAmount}`+`請在倒數結束前完成付款。`);

                //倒數計時器
                const timeDiv=document.getElementById('timerContainer');
                const display=document.querySelector('#countdownTimer');

                if(timeDiv&&display)
                {
                    timeDiv.style.display = 'block';
                    startTimer(result.RemainingSeconds, display);
                }

                // // 4. 跳轉至成功頁面
                // window.location.href = "/Orders/Details/" + result.orderID;

            } else {
                // 如果後端回傳失敗 (例如：連續座位不足、資料庫錯誤)
                alert("❌ 訂購失敗：" + result.message);
            }
        } catch (error) {
            // 捕捉 fetch 過程中的網路錯誤或程式執行錯誤
            console.error("詳細錯誤訊息:", error);
            alert("⚠️ 系統連線發生異常，請檢查網路狀態或聯繫管理員。");
        }
        };


    </script>
}

