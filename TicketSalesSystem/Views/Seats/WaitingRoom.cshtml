@model string
@{
    ViewData["Title"] = "安全驗證";
    Layout = "_UserLayout";
}
<style>
    .fs-pixel-smal{
        font-size: 1.2rem;
    }
</style>
<div class="container text-center" style="margin-top: 80px; max-width: 550px;">

    <div id="phoneVerifyModal" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 10000; align-items: center; justify-content: center;">
        <div class="pixel-container-box border-pixel-pink" style="max-width: 400px; width: 90%; background: #000;">
            <div class="text-center p-4">
                <h3 class="text-pixel-pink fw-bold mb-4">
                    <i class="bi bi-exclamation-triangle-fill"></i><br>[ 存取受限 ]
                </h3>
                <p class="text-white fs-5 mb-4">
                    偵測到您的帳號尚未完成「手機門號驗證」，請先完成驗證以啟動購票權限。
                </p>
                <div class="d-grid gap-3">
                    <a asp-controller="UserMembers" asp-action="Index" class="btn-pixel py-3" style="text-decoration: none; color: black; background-color: var(--pixel-yellow);">
                        前往驗證門號
                    </a>
                    <div class="btn-pixel-text fs-5" onclick="document.getElementById('phoneVerifyModal').style.display='none'">
                        [ 稍後再說 ]
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- 🚩 第一階段：驗證碼閘口 (Security Override) --- *@
    <div id="gateSection">
        <div class="pixel-container-box">
            @* 標題列 *@
            <div class="border-bottom border-secondary pb-3 mb-4">
                <h3 class="text-pixel-yellow fw-bold mb-0">
                    <i class="bi bi-shield-lock-fill me-2"></i>[ 安全驗證  ]
                </h3>
            </div>

            <div class="py-2">
                <p class="text-pixel-muted fs-pixel-small mb-4">
                    為維護公平購票環境，請輸入以下驗證碼：
                </p>

                @* 驗證碼畫布框 *@
                <div class="mb-4 position-relative d-inline-block">
                    <canvas id="captchaCanvas" width="200" height="70"
                            style="background:#000; border: 3px solid var(--pixel-blue); cursor:pointer;"
                            onclick="generateCaptcha()"></canvas>

                    <div class="btn-pixel-text mt-2 d-block fs-pixel-small" onclick="generateCaptcha()">
                        <i class="bi bi-arrow-clockwise"></i> [ 重新產生  ]
                    </div>
                </div>

                @* 輸入框：加強終端機輸入感 *@
                <div class="mb-4">
                    <label class="text-pixel-blue fs-pixel-small d-block mb-2">驗證碼:</label>
                    <input type="text" id="captchaInput"
                           class="form-control pixel-input text-center fw-bold"
                           style="font-size: 1.5rem; letter-spacing: 8px;"
                           placeholder="____" maxlength="4">
                </div>

                <button id="submitBtn" class="btn-pixel w-100 py-3" onclick="startQueue()">
                    確認送出
                </button>
            </div>
        </div>
    </div>

    @* --- 🚩 第二階段：排隊畫面 (Server Buffering) --- *@
    <div id="queueSection" style="display:none;">
        <div class="pixel-container-box">
            <div class="spinner-border text-pixel-blue mb-4" style="width: 5rem; height: 5rem; border-width: 0.5rem;"></div>

            <h3 class="text-pixel-yellow fw-bold mt-3 dot-blink">
                正在安排序位... 
            </h3>

            <div class="mt-4 p-3 bg-black bg-opacity-50 border border-pixel-blue">
                <p class="text-white mb-2">驗證通過！訊號穩定。</p>
                <p class="text-pixel-muted fs-pixel-small mb-0">
                    請勿中斷連線或重新整理頁面。<br>
                    系統即將為您導向選票區...
                </p>
            </div>

            <div class="mt-4 text-pixel-pink fs-pixel-small">
                [ 流量負載：高 ] 
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let captchaCode = "";
        const sessionId = '@Model';

        // 1. 生成像素風格驗證碼
        function generateCaptcha() {
            const canvas = document.getElementById('captchaCanvas');
            if(!canvas) return;
            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // 繪製背景噪點
            for(let i=0; i<100; i++){
                ctx.fillStyle = i % 2 === 0 ? "rgba(0, 204, 255, 0.1)" : "rgba(255, 0, 204, 0.1)";
                ctx.fillRect(Math.random()*canvas.width, Math.random()*canvas.height, 2, 2);
            }

            ctx.font = "bold 40px 'Courier New', Courier, monospace";
            ctx.fillStyle = "#00ccff";
            const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
            captchaCode = "";
            for (let i = 0; i < 4; i++) {
                let char = chars.charAt(Math.floor(Math.random() * chars.length));
                captchaCode += char;
                ctx.save();
                ctx.translate(45 * i + 35, 45);
                ctx.rotate((Math.random() - 0.5) * 0.3);
                ctx.shadowColor = "rgba(0, 204, 255, 0.5)";
                ctx.shadowBlur = 10;
                ctx.fillText(char, 0, 0);
                ctx.restore();
            }
        }

        // 2. 核心：驗證與排隊邏輯 (只保留一個 startQueue)
        async function startQueue() {
            const inputField = document.getElementById('captchaInput');
            const input = inputField.value.toUpperCase();

            // 前端初步擋下錯誤驗證碼
            if (input !== captchaCode) {
                alert("❌ ACCESS_DENIED: 驗證碼錯誤！");
                generateCaptcha();
                inputField.value = "";
                return;
            }

            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = "UPLOADING...";

            try {
                const response = await fetch(`/Seats/VerifyGateCaptcha`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({
                        id: sessionId,
                        captchaInput: input,
                        sessionCaptcha: captchaCode
                    })
                });

                const result = await response.json();

                // 🚩 A. 檢查手機驗證狀態
                if (result.phoneNotVerified === true) {
                    document.getElementById('phoneVerifyModal').style.display = 'flex';
                    btn.disabled = false;
                    btn.innerHTML = "確認送出 (RETRY)";
                    return;
                }

                // 🚩 B. 檢查一般錯誤
                if (!result.success) {
                    alert("❌ SERVER_REJECTED: " + result.message);
                    btn.disabled = false;
                    btn.innerHTML = "確認送出 (RETRY)";
                    generateCaptcha();
                    return;
                }

                // 🚩 C. 進入排隊或直接導向
                if (result.isQueuing === false) {
                    window.location.href = `/Seats/Index/${sessionId}`;
                } else {
                    document.getElementById('gateSection').style.display = 'none';
                    document.getElementById('queueSection').style.display = 'block';
                    startPolling();
                }

            } catch (error) {
                console.error(error);
                alert("⚠️ CONNECTION_ERROR: 系統連線異常");
                btn.disabled = false;
                btn.innerHTML = "確認送出";
            }
        }

        // 3. 輪詢排隊狀態
        function startPolling() {
            const check = setInterval(() => {
                fetch(`/Seats/CheckQueueStatus?id=${sessionId}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.canEnter) {
                            clearInterval(check);
                            window.location.href = data.redirectUrl || `/Seats/Index/${sessionId}`;
                        }
                    })
                    .catch(err => console.warn("Polling error:", err));
            }, 2500);
        }

        // --- 🚩 關鍵修改：頁面載入時自動偵測 ViewBag 狀態 ---
        document.addEventListener("DOMContentLoaded", function() {
            // 初始化驗證碼
            generateCaptcha();

            // 檢查後端傳來的手機驗證狀態 (需搭配 Controller ViewBag.IsPhoneVerified)
            const isVerified = "@ViewBag.IsPhoneVerified".toLowerCase() === "true";

            // 如果後端說沒驗證，或者這是一個 null 值（代表沒抓到）
            if ("@ViewBag.IsPhoneVerified" !== "" && !isVerified) {
                document.getElementById('phoneVerifyModal').style.display = 'flex';
                const btn = document.getElementById('submitBtn');
                btn.disabled = true;
                btn.innerHTML = "[ 請先驗證手機門號 ]";
                btn.style.opacity = "0.6";
            }
        });
    </script>
}