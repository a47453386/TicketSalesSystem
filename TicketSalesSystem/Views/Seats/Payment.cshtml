@model TicketSalesSystem.ViewModel.Booking.VMBookingResponse

@{
    ViewData["Title"] = "支付訂單";
    Layout = "_UserLayout";
}

<style>
    /* 🚩 專屬：賽博交易介面樣式 */
    .pixel-timer-bar {
        background-color: #000;
        border-bottom: 4px solid var(--pixel-pink);
        z-index: 1020;
        box-shadow: 0 5px 15px rgba(255, 0, 204, 0.3);
    }

    .timer-text {
        font-family: 'Press Start 2P', cursive;
        color: var(--pixel-pink);
        text-shadow: 0 0 5px var(--pixel-pink);
    }

    /* 支付方式像素按鈕 */
    .payment-pixel-box label {
        border: 2px solid var(--pixel-blue);
        background-color: rgba(0, 0, 0, 0.6);
        color: #fff;
        border-radius: 0;
        transition: all 0.2s;
        cursor: pointer;
    }

        .payment-pixel-box label:hover {
            background-color: rgba(0, 204, 255, 0.1);
            border-color: var(--pixel-yellow);
        }

    .btn-check:checked + label {
        border-color: var(--pixel-yellow) !important;
        background-color: rgba(255, 204, 0, 0.15) !important;
        box-shadow: -5px 0 0 var(--pixel-yellow);
    }

    .check-mark-pixel {
        display: none;
        font-family: 'Press Start 2P', cursive;
        font-size: 0.7rem;
    }

    .btn-check:checked + label .check-mark-pixel {
        display: block;
        color: var(--pixel-yellow);
    }

    .pixel-status-circle {
        width: 100px;
        height: 100px;
        background-color: #000;
        border: 4px solid var(--pixel-blue);
        color: var(--pixel-blue);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        box-shadow: 0 0 15px var(--pixel-blue);
    }

    .text-pixel-yellow {
        color: var(--pixel-yellow) !important;
    }

    .text-pixel-blue {
        color: var(--pixel-blue) !important;
    }

    .text-pixel-pink, .bg-pixel-pink {
        color: var(--pixel-pink) !important;
    }

    .text-pixel-muted {
        color: var(--pixel-text-muted) !important;
    }

    /* 1. 欄位標籤 (左側的：活動名稱、日期等) */
    .pixel-label {
        font-size: 1.1rem !important;
        color: var(--pixel-blue) !important;
        letter-spacing: 1px;
        margin-bottom: 5px;
        display: block;
    }

    /* 2. 數據數值 (右側的：@Model.ProgrammeName 等) */
    .pixel-value {
        font-size: 1.5rem !important; /* 核心數據要最大 */
        color: #ffffff !important;
        font-weight: bold;
        text-shadow: 2px 2px 0px #000;
    }

    /* 3. 修改原本覺得太小的 fs-pixel-small */
    .fs-pixel-small {
        font-size: 1.2rem !important; /* 這是最低限度，低於這個就看不清了 */
    }

    /* 4. 針對支付授權區的小字 (原 0.7rem 太小了) */
    .pixel-legal-text {
        font-size: 1rem !important;
        line-height: 1.6;
        color: var(--pixel-muted) !important;
    }
    
</style>

@* --- 🚩 頂部自爆倒數計時列 --- *@
<div class="pixel-timer-bar sticky-top">
    <div class="container d-flex justify-content-between align-items-center py-2">
        <span class="text-pixel-pink fs-pixel-small dot-blink">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>請於時間內付款
        </span>
        <div class="d-flex align-items-center bg-black border border-pixel-pink px-3 py-1">
            <span class="text-white small me-3 font-monospace">倒數計時:</span>
            <span id="countdownTimer" class="timer-text fs-4">--:--</span>
        </div>
    </div>
</div>

<div class="container mt-5 mb-5">
    @* --- 🚩 狀態顯示 --- *@
    <div class="row mb-5">
        <div class="col-12 text-center">
            <div class="pixel-status-circle mb-4 mx-auto">
                <i class="bi bi-hdd-network"></i>
            </div>
            <h2 class="text-pixel-yellow fw-bold">訂單建立成功</h2>
            <div class="pixel-container-box d-inline-block py-2 px-4 mt-2">
                訂單號碼: <span class="text-pixel-blue">@Model.OrderID</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @* --- 🚩 左側：數據摘要 --- *@
        <div class="col-lg-7">
            <div class="pixel-container-box h-100">
                <h5 class="text-pixel-yellow mb-4 pb-2 border-bottom border-secondary">
                    [ 訂購內容 ]
                </h5>
                <div class="card-body">
                    @* 使用自定義的 pixel-label 與 pixel-value *@
                    <div class="mb-4">
                        <span class="pixel-label">活動名稱E</span>
                        <div class="pixel-value">@Model.ProgrammeName</div>
                    </div>

                    <div class="mb-4">
                        <span class="pixel-label">演唱日期</span>
                        <div class="pixel-value">@Model.StartTime</div>
                    </div>

                    <div class="mb-4">
                        <span class="pixel-label">演出地點</span>
                        <div class="pixel-value text-pixel-blue">@Model.PlaceName</div>
                    </div>

                    <div class="mb-4">
                        <span class="pixel-label">選定座位</span>
                        <div class="d-flex flex-wrap gap-2 mt-2">
                            @foreach (var seatInfo in Model.Seats)
                            {
                                @* 座位標籤也放大 *@
                                <span class="border border-pixel-blue px-3 py-2 text-pixel-blue fw-bold" style="font-size: 1.2rem;">
                                    @seatInfo
                                </span>
                            }
                        </div>
                    </div>

                    @* 應付總額區塊 *@
                    <div class="border-top border-secondary pt-4 mt-5">
                        <div class="d-flex justify-content-between align-items-end">
                            <span class="text-pixel-muted fs-pixel-small">應付總額</span>
                            <span class="fw-bold text-pixel-pink shadow-glow" style="font-size: 3rem;">
                                $@Model.FinalAmount.ToString("N0")
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* --- 🚩 右側：支付授權 --- *@
        <div class="col-lg-5">
            <div class="pixel-container-box h-100 border-pixel-pink">
                <h5 class="text-pixel-pink mb-4 pb-2 border-bottom border-secondary">
                    [ 支付方式 ]
                </h5>
                <div class="payment-group">
                    @if (ViewData["PaymentMethods"] != null)
                    {
                        var methods = (List<TicketSalesSystem.Models.PaymentMethod>)ViewData["PaymentMethods"];
                        for (int i = 0; i < methods.Count; i++)
                        {
                            @* 🚩 根據名稱決定圖示與顏色類別 *@
                            string iconClass = "bi-shield-lock"; // 預設
                            string colorClass = "text-pixel-blue"; // 預設藍色

                            if (methods[i].PaymentMethodID.Contains("A") || methods[i].PaymentMethodName.Contains("轉帳"))
                            {
                                iconClass = "bi-bank2";
                                colorClass = "text-pixel-blue"; // ATM 配藍色
                            }
                            else if (methods[i].PaymentMethodID.Contains("C") || methods[i].PaymentMethodName.Contains("Card"))
                            {
                                iconClass = "bi-credit-card-2-front";
                                colorClass = "text-pixel-pink"; // 信用卡配粉色
                            }

                            <div class="payment-pixel-box mb-3">
                                <input type="radio" class="btn-check" name="payType"
                                       id="pay_@methods[i].PaymentMethodID"
                                       value="@methods[i].PaymentMethodID"
                                       @(i == 0 ? "checked" : "")>
                                <label class="btn d-flex align-items-center p-3 text-start w-100"
                                       for="pay_@methods[i].PaymentMethodID">

                                    @* 🚩 這裡會動態切換圖示與顏色 *@
                                    <i class="bi @iconClass fs-3 me-3 @colorClass shadow-glow-@(colorClass.Contains("pink") ? "pink" : "blue")"></i>

                                    <div class="flex-grow-1">
                                        <div class="fw-bold text-white">@methods[i].PaymentMethodName</div>
                                    </div>
                                    <span class="check-mark-pixel">SELECTED</span>
                                </label>
                            </div>
                        }
                    }
                </div>

                <div class="mt-5">
                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" id="agreeTerms" checked style="transform: scale(1.5); margin-right: 15px;">
                        <label class="pixel-legal-text ms-2" for="agreeTerms">
                            我已閱畢並同意數據傳輸條款
                        </label>
                    </div>

                    <button type="button" onclick="confirmPayment()" class="btn-pixel w-100 py-4" style="font-size: 1.6rem;">
                        確認付款
                    </button>

                    <div class="mt-4 text-center">
                        <form asp-controller="UserOrders" asp-action="UserCancelOrder" asp-route-id="@Model.OrderID" method="post" id="cancelForm">
                            <button type="button" id="btnCancel" class="btn-pixel-text text-pixel-pink fs-pixel-small" onclick="confirmCancel()">
                                [ 我要取消訂單 ]
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // 🚩 統一 SweetAlert 風格為深色
        const PixelSwal = Swal.mixin({
            background: '#000',
            color: '#fff',
            confirmButtonColor: '#ff00cc',
            cancelButtonColor: '#00ccff',
            customClass: {
                popup: 'border-pixel-pink border-4'
            }
        });

        function confirmCancel() {
            PixelSwal.fire({
                title: '確定要取消訂單？',
                text: "座位即將釋放!!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: '確定取消',
                cancelButtonText: '繼續支付',
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    PixelSwal.fire({
                        title: '正在清理數據...',
                        html: 'DELETING_ASSET_RESERVATION...',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); }
                    });
                    document.getElementById('cancelForm').submit();
                }
            })
        }

        (function () {
            const timerDisplay = document.getElementById("countdownTimer");
            const expireTimeStr = "@Model.ExpireTimeText";
            const expireTime = new Date(expireTimeStr).getTime();

            const timerFunc = setInterval(function () {
                const now = new Date().getTime();
                const distance = expireTime - now;

                if (distance < 0) {
                    clearInterval(timerFunc);
                    timerDisplay.innerHTML = "00:00";
                    PixelSwal.fire("系統逾時", "數據連結已遺失，訂單失效。", "error").then(() => {
                        window.location.href = "/Home/Index";
                    });
                    return;
                }

                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                timerDisplay.innerHTML =
                    (minutes < 10 ? "0" : "") + minutes + ":" +
                    (seconds < 10 ? "0" : "") + seconds;

                // 剩餘一分鐘變色警告
                if (minutes < 1) {
                    timerDisplay.style.animation = "dot-blink 0.5s infinite";
                }
            }, 1000);
        })();

        window.confirmPayment = async function() {
            const selectedPayType = document.querySelector('input[name="payType"]:checked');
            if (!selectedPayType) {
                PixelSwal.fire("錯誤", "請選擇傳輸協定 (支付方式)", "error");
                return;
            }

            const btn = document.querySelector('.btn-pixel');
            btn.disabled = true;
            btn.innerHTML = 'UPLOADING_AUTH...';

            try {
                const res = await fetch('/Seats/Payment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        OrderID: "@Model.OrderID",
                        PaymentMethodID: selectedPayType.value
                    })
                });

                const result = await res.json();
                if (result.success) {
                    PixelSwal.fire("成功", "✅ 授權成功！數據同步中。", "success").then(() => {
                        window.location.href = "/UserOrders/UserIndex";
                    });
                } else {
                    PixelSwal.fire("拒絕", "❌ 授權失敗：" + result.message, "error");
                    btn.disabled = false;
                    btn.innerHTML = '重新授權 (RETRY)';
                }
            } catch (error) {
                PixelSwal.fire("異常", "⚠️ 訊號中斷，請檢查網路狀態。", "error");
                btn.disabled = false;
            }
        };
    </script>
}