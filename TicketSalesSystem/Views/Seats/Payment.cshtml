@model TicketSalesSystem.ViewModel.Booking.VMBookingResponse

@{
    ViewData["Title"] = "支付訂單 - tixCraft 拓元風格";
    Layout = "_UserLayout";
}
<style>
    :root {
        --tixcraft-blue: #003a8c;
        --tixcraft-hover: #002766;
    }

    /* 倒數計時列 */
    .timer-bar {
        background-color: #d9534f;
        z-index: 1020;
    }

    /* 拓元色調 */
    .bg-tixcraft {
        background-color: var(--tixcraft-blue);
    }

    .text-primary {
        color: var(--tixcraft-blue) !important;
    }

    /* 狀態圖示 */
    .status-icon-circle {
        width: 80px;
        height: 80px;
        background-color: #e8f5e9;
        color: #2e7d32;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
    }

    /* 支付方式選項 */
    .payment-box label {
        border-color: #dee2e6;
        background-color: #fff;
        border-width: 2px;
        transition: 0.2s;
        border-radius: 0;
    }

        .payment-box label:hover {
            background-color: #f8f9fa;
            border-color: #ced4da;
        }

    .btn-check:checked + label {
        border-color: var(--tixcraft-blue);
        background-color: #f0f7ff;
    }

    .check-mark {
        display: none;
    }

    .btn-check:checked + label .check-mark {
        display: block;
    }

    /* 操作按鈕 */
    .btn-tixcraft-action {
        background-color: var(--tixcraft-blue);
        color: white;
        border-radius: 4px;
        letter-spacing: 1px;
    }

        .btn-tixcraft-action:hover {
            background-color: var(--tixcraft-hover);
            color: white;
        }

    /* 字體微調 */
    .font-monospace {
        font-family: 'Courier New', Courier, monospace;
    }
</style>
<div class="timer-bar sticky-top shadow-sm">
    <div class="container d-flex justify-content-between align-items-center py-2">
        <span class="text-white small"><i class="bi bi-info-circle-fill me-2"></i>請於時限內完成付款，逾時訂單將失效。</span>
        <div class="d-flex align-items-center bg-white text-danger px-3 py-1 rounded-pill">
            <span class="small fw-bold me-2">結帳剩餘時間</span>
            <span id="countdownTimer" class="fw-bold fs-5 font-monospace">--:--</span>
        </div>
    </div>
</div>

<div class="container mt-5 mb-5">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <div class="status-icon-circle mb-3 mx-auto">
                <i class="bi bi-cart-check"></i>
            </div>
            <h2 class="fw-bold">訂單建立成功，待支付</h2>
            <p class="text-secondary">請確認以下訂購資訊並選擇付款方式</p>
            <div class="d-inline-block px-4 py-2 bg-light border rounded text-dark">
                訂單編號：<span class="fw-bold">@Model.OrderID</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-0 h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold border-start border-primary border-4 ps-3">訂購內容摘要</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted">活動節目</div>
                        <div class="col-sm-8 fw-bold fs-5 text-primary">@Model.ProgrammeName</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted">場次時間</div>
                        <div class="col-sm-8">@Model.StartTime</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted">演出地點</div>
                        <div class="col-sm-8">@Model.PlaceName</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted">座位資訊</div>
                        <div class="col-sm-8">
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var seatInfo in Model.Seats)
                                {
                                    <span class="badge bg-light text-dark border p-2 fw-normal">@seatInfo</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="border-top pt-4 mt-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fs-5 text-secondary">應付總金額</span>
                            <span class="fs-1 fw-bold text-danger">TWD $@Model.FinalAmount.ToString("N0")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-0 h-100">
                <div class="card-header bg-tixcraft text-white py-3">
                    <h5 class="mb-0 fw-bold">選擇支付方式</h5>
                </div>
                <div class="card-body p-4">
                    <div class="payment-group">
                        @if (ViewData["PaymentMethods"] != null)
                        {
                            var methods = (List<TicketSalesSystem.Models.PaymentMethod>)ViewData["PaymentMethods"];
                            for (int i = 0; i < methods.Count; i++)
                            {
                                <div class="payment-box mb-3">
                                    <input type="radio" class="btn-check" name="payType"
                                           id="pay_@methods[i].PaymentMethodID"
                                           value="@methods[i].PaymentMethodID"
                                           @(i == 0 ? "checked" : "")>
                                    <label class="btn btn-outline-light d-flex align-items-center p-3 text-start w-100"
                                           for="pay_@methods[i].PaymentMethodID">
                                        <i class="bi bi-credit-card-2-front fs-3 me-3"></i>
                                        <div class="flex-grow-1">
                                            <div class="fw-bold pay-name text-dark">@methods[i].PaymentMethodName</div>
                                            <small class="text-muted">安全且加密的支付環境</small>
                                        </div>
                                        <i class="bi bi-check-circle-fill check-mark fs-4 text-primary"></i>
                                    </label>
                                </div>
                            }
                        }
                    </div>

                    <div class="mt-5">
                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" id="agreeTerms" checked>
                            <label class="form-check-label small text-muted" for="agreeTerms">
                                我已閱讀並同意購票須知與服務條款
                            </label>
                        </div>
                        <button type="button" onclick="confirmPayment()"
                                class="btn btn-tixcraft-action btn-lg w-100 py-3 shadow-sm fw-bold">
                            確認付款並完成訂購
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<form asp-controller="Orders" asp-action="UserCancelOrder" id="cancelForm">
    <input type="hidden" name="id" value="@Model.OrderID" />
    <button type="button" class="btn btn-outline-danger" onclick="confirmCancel()">
        我不要了，取消訂單
    </button>
   
</form>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmCancel() {
            Swal.fire({
                title: '確定要取消訂單嗎？',
                text: "取消後，您選購的座位將立即釋出給其他購票者！",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: '確定取消',
                cancelButtonText: '再考慮一下'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('cancelForm').submit();
                }
            })
        }
        // 1. 倒數計時
        (function () {
            const timerDisplay = document.getElementById("countdownTimer");
            const expireTimeStr = "@Model.ExpireTimeText";
            const expireTime = new Date(expireTimeStr).getTime();

            const timerFunc = setInterval(function () {
                const now = new Date().getTime();
                const distance = expireTime - now;

                if (distance < 0) {
                    clearInterval(timerFunc);
                    timerDisplay.innerHTML = "00:00";
                    alert("付款逾時，訂單已自動失效。");
                    window.location.href = "/Home/Index";
                    return;
                }

                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                timerDisplay.innerHTML =
                    (minutes < 10 ? "0" : "") + minutes + ":" +
                    (seconds < 10 ? "0" : "") + seconds;
            }, 1000);
        })();

        // 2. 確認付款
        window.confirmPayment = async function() {
            const selectedPayType = document.querySelector('input[name="payType"]:checked');
            if (!selectedPayType) {
                alert("請選擇支付方式");
                return;
            }

            const btn = document.querySelector('.btn-tixcraft-action');
            btn.disabled = true;
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> 處理中...';

            try {
                const res = await fetch('/Seats/Payment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        OrderID: "@Model.OrderID",
                        PaymentMethodID: selectedPayType.value
                    })
                });

                const result = await res.json();
                if (result.success) {
                    alert("✅ 付款成功！系統將為您跳轉至訂單記錄。");
                    window.location.href = "/Orders/UserIndex";
                } else {
                    alert("❌ 付款失敗：" + result.message);
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                }
            } catch (error) {
                alert("⚠️ 連線異常，請檢查網路狀態。");
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        };
    </script>
}