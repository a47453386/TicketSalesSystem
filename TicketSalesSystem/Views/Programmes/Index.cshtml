@model IEnumerable<TicketSalesSystem.ViewModel.Programme.VMProgramme>

@{
    ViewData["Title"] = "節目活動";
    Layout = "_UserLayout";
}

<style>
    /* 🚩 賽博像素卡片核心樣式 */
    .pixel-ticket-card {
        background-color: var(--pixel-bg-light) !important;
        border: 2px solid var(--pixel-blue) !important;
        border-radius: 0 !important;
        transition: all 0.2s;
        position: relative;
        overflow: hidden;
    }

        .pixel-ticket-card:hover {
            transform: translate(-4px, -4px);
            box-shadow: 8px 8px 0px var(--pixel-pink) !important;
            border-color: var(--pixel-pink) !important;
        }

    /* 圖片掃描線特效 */
    .pixel-img-container {
        height: 200px;
        position: relative;
        border-bottom: 2px solid var(--pixel-blue);
        overflow: hidden;
    }

        .pixel-img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: saturate(1.2) contrast(1.1); /* 增加色彩鮮艷度 */
        }

    /* 圖片上的狀態標籤 */
    .pixel-status-tag {
        position: absolute;
        top: 0;
        right: 0;
        background-color: var(--pixel-pink);
        color: #fff;
        padding: 5px 10px;
        font-size: 0.8rem;
        z-index: 5;
    }

    .pixel-card-body {
        background-color: rgba(0, 0, 0, 0.4);

    }

    .fs-pixel-small{
        font-size: 1.2rem !important;
    }

    /* 霓虹文字效果 */
    .glow-text-blue {
        color: var(--pixel-blue);
        text-shadow: 0 0 5px var(--pixel-blue);
    }

    /* 文字截斷 */
    .pixel-line-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 2.5rem;
        font-family: 'Press Start 2P', cursive;
        font-size: 0.8rem;
        line-height: 1.4;
    }
</style>

<div class="container py-5">
    @* 🚩 標題區塊：任務選擇介面 *@
    <div class="pixel-container-box mb-5">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 class="text-pixel-yellow mb-0">[節目資訊]</h2>
            </div>
            <div class="col-md-4 text-md-end d-none d-md-block">
                <i class="bi bi-controller display-6 text-pixel-blue dot-blink"></i>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="pixel-container-box text-center py-5">
            <i class="bi bi-calendar-x text-pixel-muted display-1 d-block mb-3"></i>
            <h4 class="text-pixel-muted">系統更新中...</h4>
            @* <p class="text-white-50 fs-pixel-small">請掃描其他頻段或等待系統更新...</p> *@
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 pixel-ticket-card">

                        @* 🚩 圖片區塊 *@
                        <div class="pixel-img-container">
                            <div class="pixel-status-tag">熱賣中..</div>
                            @if (!string.IsNullOrEmpty(item.CoverImage))
                            {
                                <img src="@Url.Content("~/Photos/CoverImage/" + item.CoverImage)" alt="@item.ProgrammeName">
                            }
                            else
                            {
                                <div class="bg-dark d-flex align-items-center justify-content-center text-pixel-blue h-100">
                                    <i class="bi bi-image fs-1"></i>
                                </div>
                            }

                           
                        </div>

                        @* 🚩 內容區塊 *@
                        <div class="card-body pixel-card-body p-4">
                            <h5 class="card-title text-pixel-yellow  fs-pixel-small pixel-line-clamp mb-3" title="@item.ProgrammeName">
                                @item.ProgrammeName
                            </h5>

                            <div class="d-flex flex-column gap-3">
                                <div class="text-white-50 fs-pixel-small d-flex align-items-center">
                                    <i class="bi bi-geo-alt-fill glow-text-blue me-2"></i> @item.PlaceName
                                </div>
                                <div class="text-white-50 fs-pixel-small d-flex align-items-center">
                                    <i class="bi bi-calendar3 glow-text-blue me-2"></i>
                                    @(item.StartTime.HasValue? item.StartTime.Value.ToString("yyyy.MM.dd") : "COMMING_SOON")
                                </div>
                            </div>
                        </div>

                        @* 🚩 底部按鈕 *@
                        <div class="card-footer bg-transparent border-0 p-4 pt-0">
                            <div class="d-grid">
                                <a asp-action="Details" asp-route-id="@item.ProgrammeID"
                                   class="btn-pixel">
                                   立即購票
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>