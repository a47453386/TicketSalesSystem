@model IEnumerable<TicketSalesSystem.ViewModel.Programme.VMProgramme>

@{
    ViewData["Title"] = "節目活動";
    Layout = "_UserLayout";
}
<style>
    /* 拓元風格微調：強調方正與俐落感 */
    .ticket-card {
        border-radius: 0; /* 拓元多用方正設計 */
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .ticket-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.12) !important;
        }

    .img-container {
        height: 220px;
        overflow: hidden;
    }

        .img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

    .ticket-card:hover .img-container img {
        transform: scale(1.05);
    }

    /* 漸層黑底強化文字讀取 */
    .bg-gradient-dark {
        background: linear-gradient(transparent, rgba(0,0,0,0.7));
    }

    .purchase-btn {
        background-color: #003a8c;
        border: none;
        letter-spacing: 2px;
    }

        .purchase-btn:hover {
            background-color: #002766;
        }

    /* 限制標題高度與行數 */
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 3rem;
    }

    .text-primary {
        color: #003a8c !important;
    }
</style>






<div class="container py-5">
    <div class="row align-items-end mb-5">
        <div class="col">
            <h2 class="fw-bold text-dark mb-0" style="letter-spacing: 1px;">
                <span class="border-start border-primary border-5 ps-3">熱門節目</span>
                <small class="text-secondary fw-normal fs-5 ms-2">Hot Programs</small>
            </h2>
        </div>
        <div class="col-auto">
            <p class="text-muted small mb-0">目前共有 @Model.Count() 個活動售票中</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-light rounded-4 shadow-sm">
            <i class="bi bi-calendar-x text-secondary display-1"></i>
            <h4 class="mt-4 text-secondary">目前暫時沒有售票中的節目</h4>
            <p class="text-muted">請稍後再回來看看，或關注我們的官方公告。</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm ticket-card transition-all">

                        <div class="position-relative">
                            <div class="img-container">
                                @if (!string.IsNullOrEmpty(item.CoverImage))
                                {
                                    <img src="@Url.Content("~/Photos/CoverImage/" + item.CoverImage)" class="card-img-top" alt="@item.ProgrammeName">
                                }
                                else
                                {
                                    <div class="bg-secondary d-flex align-items-center justify-content-center text-white" style="height: 200px;">
                                        <i class="bi bi-image fs-1"></i>
                                    </div>
                                }
                            </div>

                            <div class="position-absolute bottom-0 start-0 p-3 w-100 bg-gradient-dark text-white">
                                <small class="fw-bold"><i class="bi bi-ticket-perforated me-1"></i> 立即購票</small>
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold text-dark mb-3 line-clamp-2" title="@item.ProgrammeName">
                                @item.ProgrammeName
                            </h5>

                            <div class="d-flex flex-column gap-2">
                                <div class="text-muted small d-flex align-items-center">
                                    <i class="bi bi-geo-alt-fill text-primary me-2"></i> @item.PlaceName
                                </div>
                                <div class="text-muted small d-flex align-items-center">
                                    <i class="bi bi-calendar3 text-primary me-2"></i>
                                    @(item.StartTime.HasValue? item.StartTime.Value.ToString("yyyy/MM/dd HH:mm") : "時間未定")
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 p-4 pt-0">
                            <div class="d-grid">
                                @* 統一導向場次選擇頁 *@
                                <a asp-action="Details" asp-route-id="@item.ProgrammeID"
                                   class="btn btn-primary fw-bold py-2 rounded-0 shadow-sm purchase-btn">
                                    立即購票
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

