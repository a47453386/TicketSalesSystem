@model IEnumerable<TicketSalesSystem.ViewModel.Programme.Index.VMprogrammeIndex>

@{
    ViewData["Title"] = "活動管理";
}

<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Index.css" asp-append-version="true" />

<div class="admin-body p-4 custom-scroll">

    @* --- 1. 頂部標頭系統 --- *@
    <div class="d-flex justify-content-between align-items-end mb-4 pb-3 border-bottom border-info border-opacity-25">
        <div>
            <h2 class="neon-header m-0">@ViewData["Title"]</h2>
        </div>

        <a asp-controller="ProgrammeDTO" asp-action="CreateStep1" class="btn-cyber">
            <i class="bi bi-plus-lg me-2"></i>[ 新增活動 ]
        </a>
    </div>

    @* --- 2. 數據封鎖區塊 (Cyber-Card) --- *@
    <div class="cyber-card p-3">
        <div class="table-responsive">
            <table class="table cyber-table align-middle border-0">
                <thead>
                    <tr class="border-0">
                        <th style="width: 110px;" class="ps-4 border-0"><div class="tech-key1">活動編號</div></th>
                        <th style="width: 90px;" class="border-0"><div class="tech-key1">封面圖</div></th>
                        <th style="width: 25%;" class="border-0"><div class="tech-key1">活動名稱</div></th>
                        <th style="width: 15%;" class="border-0"><div class="tech-key1">演出地點</div></th>
                        <th style="width: 140px;" class="border-0"><div class="tech-key1">演出時間</div></th>
                        <th style="width: 130px;" class="border-0"><div class="tech-key1">銷售概況</div></th>
                        <th style="width: 140px;" class="border-0"><div class="tech-key1">狀態</div></th>
                        <th style="width: 130px;" class="border-0 pe-4"><div class="tech-key1">操作</div></th>
                    </tr>
                </thead>
                <tbody class="custom-scroll">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                @* 1. UID *@
                                <td class="ps-4 font-monospace">
                                    <span style="color: var(--tech-border);">#</span><span style="color: var(--tech-cyan); font-weight: bold;">@item.ProgrammeID</span>
                                </td>

                                @* 2. 縮圖 *@
                                <td class="text-center">
                                    <div class="img-frame">
                                        <img src="@Url.Content("~/Photos/CoverImage/" + item.CoverImage)"
                                             style="width: 80px; height: 50px; object-fit: cover; filter: grayscale(20%) brightness(0.9);"
                                             onerror="this.onerror=null; this.src='https://via.placeholder.com/60x40?text=VOID'">
                                    </div>
                                </td>

                                @* 3. 名稱 *@
                                <td class="text-start">
                                    <div class="fw-bold text-white mb-0" style="font-size: 1rem; letter-spacing: 0.5px;">@item.ProgrammeName</div>
                                    <div class="font-monospace opacity-50" style="font-size: 0.65rem; color: var(--tech-cyan);">ACCESS_LEVEL: ADMIN_ONLY</div>
                                </td>

                                @* 4. 場館 *@
                                <td class="text-start">
                                    <div class="text-white opacity-75 small">
                                        <i class="bi bi-geo-alt-fill me-1" style="color: var(--tech-cyan);"></i>@item.PlaceName
                                    </div>
                                </td>

                                @* 5. 時間 (取第一場) *@
                                <td class="font-monospace text-center">
                                    @if (item.Session != null && item.Session.Any())
                                    {
                                        <div class="d-flex flex-column gap-2">
                                            @foreach (var sess in item.Session.OrderBy(s => s.StartTime))
                                            {
                                                <div class="session-item pb-1 border-bottom border-info border-opacity-10 last-child-border-0">
                                                    <div class="text-white" style="font-size: 0.85rem;">
                                                        @sess.StartTime?.ToString("yyyy.MM.dd")
                                                    </div>
                                                    <div class="text-info opacity-75" style="font-size: 0.75rem;">
                                                        <i class="bi bi-clock-history me-1"></i>@sess.StartTime?.ToString("HH:mm")
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-white opacity-25 small">
                                            <i class="bi bi-exclamation-triangle me-1"></i>無場次資料
                                        </div>
                                    }
                                </td>

                                @* 6. 票數監控 *@
                                <td class="text-center font-monospace">
                                    <div style="font-size: 0.9rem;">
                                        <span class="opacity-50">總:</span><span class="text-white">@item.Capacity.ToString("D3")</span>
                                    </div>
                                    <div style="font-size: 0.85rem;">
                                        <span class="opacity-50">剩:</span>
                                        <span style="color: @(item.Remaining < 10 && item.Remaining > 0 ? "var(--tech-danger)" : "var(--tech-cyan)");">
                                            @item.Remaining.ToString("D3")
                                        </span>
                                    </div>
                                </td>

                                @* 7. 狀態 *@
                                <td class="text-center">
                                    @* 注意：這裡使用的是 status-@item.StatusColor *@
                                    <div class="status-badge status-@item.StatusColor">
                                        <span class="pulse-dot"></span>
                                        @item.ProgrammeStatusName
                                    </div>
                                </td>

                                @* 8. 操作 *@
                                <td class="text-center">
                                    <div class="d-flex justify-content-center align-items-center gap-3">
                                        <a asp-controller="ProgrammeDTO" asp-action="Edit" asp-route-id="@item.ProgrammeID" class="btn-action-icon text-info" title="編輯">
                                            <i class="bi bi-cpu-fill"></i>
                                        </a>
                                        <a asp-action="AdminDetail" asp-route-id="@item.ProgrammeID" class="btn-action-icon text-white" title="詳細資訊">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <button type="button" class="btn-action-icon text-danger bg-transparent border-0 p-0"
                                                onclick="globalDelete('@item.ProgrammeID', '@item.ProgrammeName', 'Programmes')">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>