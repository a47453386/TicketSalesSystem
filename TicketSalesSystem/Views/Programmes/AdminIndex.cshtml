@model IEnumerable<TicketSalesSystem.ViewModel.Programme.VMProgramme>

@{
    ViewData["Title"] = "活動管理";
}

<link rel="stylesheet" href="~/css/Admin/Programme/ProgrammeIndex.css" asp-append-version="true" />
<div class="admin-body p-3">
    @* --- 頂部標題與操作 --- *@
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-info border-opacity-25 pb-2">
        <h3 class="neon-text-sharp m-0" style="font-size: 1.4rem;">
            <i class="bi bi-gear-fill me-2"></i>活動節目管理
        </h3>
        <a asp-controller="ProgrammeDTO" asp-action="CreateStep1" class="btn-cyber-sm">
            <i class="bi bi-plus-lg me-1"></i>[ 新增活動 ]
        </a>
    </div>

    @* --- 數據表格主體 --- *@
    <div class="cyber-card p-2">
        <div class="table-responsive">
            <table class="cyber-table align-middle">
                <thead>
                    <tr>
                        <th style="width: 80px;" class="ps-3">ID</th>
                        <th style="width: 70px;">縮圖</th>
                        <th style="width: 30%;">活動名稱</th>
                        <th>場館</th>
                        <th>開演時間</th>
                        <th class="text-center">庫存 / 餘票</th>
                        <th class="text-center">狀態</th>
                        <th class="text-center">系統操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 text-info opacity-75 font-monospace">#@item.ProgrammeID</td>
                                <td>
                                    <img src="@Url.Content("~/Photos/CoverImage/" + item.CoverImage)"
                                         class="cover-img-tech"
                                         onerror="this.onerror=null; this.src='https://via.placeholder.com/50x35?text=NA'">
                                </td>
                                <td>
                                    <div class="neon-text-sm">@item.ProgrammeName</div>
                                </td>
                                <td class="text-white">@item.PlaceName</td>
                                <td class="font-monospace" style="font-size: 0.8rem;">
                                    @(item.StartTime?.ToString("yyyy-MM-dd HH:mm") ?? "N/A")
                                </td>
                                <td class="text-center">
                                    <span class="fw-bold">@item.Capacity</span>
                                    <span class="opacity-25 mx-1">/</span>
                                    <span class="@(item.Remaining < 10 && item.Remaining > 0 ? "text-danger fw-bold shadow-glow" : "text-info")">
                                        @item.Remaining
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge-tech text-@item.StatusColor">
                                        ● @item.ProgrammeStatusName
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a asp-controller="ProgrammeDTO" asp-action="Edit" asp-route-id="@item.ProgrammeID" class="tech-link-icon px-2" title="編輯數據">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="AdminDetail" asp-route-id="@item.ProgrammeID" class="tech-link-icon px-2" title="查看日誌">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <button type="button"
                                                class="tech-link-icon px-2 bg-transparent border-0 text-danger"
                                                onclick="globalDelete('@item.ProgrammeID', '@item.ProgrammeName', 'Programmes')">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
