@using TicketSalesSystem.ViewModel.Programme.ProgrammeAdminDetail
@model VMProgrammeAdminDetail

<link rel="stylesheet" href="~/css/Admin/Programme/ProgrammeAdminDetail.css" asp-append-version="true" />

<div class="admin-body p-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <div class="tech-sub-label mb-1">節目資料</div>
            <div class="neon-header">@Model.ProgrammeName</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="AdminIndex" class="btn btn-outline-secondary">回活動列表</a>
            <a asp-action="Edit" asp-route-id="@Model.ProgrammeID" class="btn btn-cyber-submit">編輯節目</a>
        </div>
    </div>
    @* --- [第一列] 封面 + 基本資料 (名稱、地點、時間) + 總量統計 --- *@
    <div class="row g-4 mb-4">
        <div class="col-lg-3">
            <div class="cyber-card p-2 h-100 text-center">
                <div class="tech-key small">封面</div>
                <img src="/Photos/CoverImage/@Model.CoverImage" class="w-100 media-preview" style="height: 250px; object-fit: cover;">
            </div>
        </div>
        <div class="col-lg-6">
            <div class="cyber-card p-4 h-100">
                <div class="tech-key small mb-3">基本資料</div>
                <div class="row g-3">
                    <div class="col-12"><div class="text-info small">活動名稱</div><div class="h4 text-white">@Model.ProgrammeName</div></div>
                    <div class="col-6"><div class="text-white-50 small">演出地點</div><div>@Model.PlaceName</div></div>
                    <div class="col-6"><div class="text-white-50 small">上架時間</div><div class="font-monospace">@Model.OnShelfTime.ToString("yyyy-MM-dd HH:mm")</div></div>
                    @foreach (var s in Model.Sessions)
                    {
                        <div class="col-6"><div class="text-warning small">開演時間</div><div class="font-monospace">@s.StartTime.ToString("yyyy-MM-dd HH:mm")</div></div>
                        <div class="col-6"><div class="text-danger small">停售預計</div><div class="font-monospace">@s.StartTime.AddHours(-1).ToString("yyyy-MM-dd HH:mm")</div></div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="cyber-card p-4 h-100 border-info border-opacity-50 text-center d-flex flex-column">
                @* --- 上半部：全域指標 (Grand Total) --- *@
                <div class="mb-3">
                    <div class="text-info small mb-1">總票數</div>
                    <div class="display-5 fw-bold font-monospace text-white">@Model.Sessions.Sum(s => s.TotalCapacity)</div>
                    <div class="mt-1 text-white-50" style="font-size: 1.1rem;">
                        已售總量: <span class="text-info">@Model.Sessions.Sum(s => s.TotalSold)</span>
                    </div>
                </div>

                @* 分隔線 *@
                <hr class="border-info opacity-25 my-3">

                @* --- 下半部：各場次明細 (Session Breakdown) --- *@
                <div class="flex-grow-1 overflow-auto pe-2" style="max-height: 250px;">
                    <div class="text-info tiny-label mb-3" style="font-size: 0.8rem; letter-spacing: 2px; opacity: 0.7; text-align: left;">
                       各場次銷售情形
                    </div>

                    @foreach (var session in Model.Sessions)
                    {
                        @* 🚩 解決 RZ1010: 在 code block 內宣告變數不需要加 @ *@
                        var sPercent = session.TotalCapacity > 0 ? (session.TotalSold * 100) / session.TotalCapacity : 0;
                        var sColor = sPercent >= 90 ? "prog-high" : (sPercent >= 50 ? "prog-mid" : "prog-low");

                        <div class="mb-3 p-2 border-start border-info border-opacity-25" style="background: rgba(255,255,255,0.02);">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="text-white-50" style="font-size: 0.95rem;">@session.StartTime.ToString("MM/dd HH:mm")</span>
                                <span class="font-monospace text-info" style="font-size: 1rem;">@session.TotalSold / @session.TotalCapacity</span>
                            </div>

                            @* 迷你進度條 *@
                            <div class="cyber-progress" style="height: 6px; background: rgba(255,255,255,0.05);">
                                <div class="cyber-progress-bar @sColor" style="width: @sPercent%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* --- [第二列] 銷售矩陣 (HUD 節點) + 座位圖 --- *@
    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="cyber-card p-4 h-100">
                <div class="tech-key">1: 銷售數據</div>
                @foreach (var session in Model.Sessions)
                {
                    <div class="session-node mb-4">
                        <div class="d-flex justify-content-between mb-3 border-bottom border-white border-opacity-10 pb-2">
                            <span class="text-info font-monospace">場次序號: @session.SessionID</span>
                            <span class="text-white opacity-75">銷售情形: @session.TotalSold / @session.TotalCapacity</span>
                        </div>
                        <table class="table table-borderless text-white mb-0">
                            <thead class="text-white-50 small">
                                <tr>
                                    <th>票區</th>
                                    <th class="text-center">座位數 (行 x 座)</th>
                                    <th style="width: 45%">即時進度</th>
                                    <th class="text-end">剩餘票數</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var area in session.TicketsAreas)
                                {
                                    // 🚩 修正 RZ1010: 在代碼塊內直接定義變數，不需要多加 @
                                    var percent = area.Capacity > 0 ? (area.Sold * 100) / area.Capacity : 0;
                                    var colorClass = percent >= 90 ? "prog-high" : (percent >= 50 ? "prog-mid" : "prog-low");

                                    <tr class="align-middle">
                                        <td class="fw-bold">@area.TicketsAreaName</td>
                                        <td class="text-center font-monospace opacity-50">@area.RowCount x @area.SeatCount</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="cyber-progress flex-grow-1">
                                                    <div class="cyber-progress-bar @colorClass" style="width: @percent%"></div>
                                                </div>
                                                <span class="font-monospace small" style="min-width: 40px;">@percent%</span>
                                            </div>
                                        </td>
                                        <td class="text-end font-monospace text-info">@area.Remaining</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-4">
            <div class="cyber-card p-3 h-100 text-center">
                <div class="tech-key small mb-3">座位配置圖</div>
                <img src="/Photos/SeatImage/@Model.SeatImage" class="w-100 seat-map-bg" style="height: 450px; object-fit: contain;">
            </div>
        </div>
    </div>

    @* --- [第三列] 文本內容 --- *@
    <div class="cyber-card p-4 mb-4">
        <div class="tech-key">2.: 活動詳細介紹及規範</div>
        <div class="desc-block"><div class="text-info small mb-1">活動簡介</div><p>@Model.ProgrammeDescription</p></div>
        <div class="row g-3">
            <div class="col-md-6"><div class="desc-block warning"><div class="text-warning small mb-1">注意事項</div><div>@Model.Notice</div></div></div>
            <div class="col-md-6"><div class="desc-block danger"><div class="text-danger small mb-1">退票政策</div><div>@Model.RefundPolicy</div></div></div>
        </div>
    </div>

    @* --- [第四列] 附件藝廊 --- *@
    <div class="cyber-card p-4 mb-4">
        <div class="tech-key small">3: 說明圖片</div>
        <div class="row g-3 mt-1">
            @foreach (var imgName in Model.DescriptionImages)
            {
                <div class="col-md-2 col-4">
                    @* 🚩 修正 CS1061: 直接使用 imgName (string) *@
                    <img src="/Photos/DescriptionImage/@imgName" class="w-100 gallery-thumb" style="height: 150px;">
                </div>
            }
        </div>
    </div>

    @* --- [最後一列] 系統資訊 --- *@
    <div class="d-flex justify-content-between p-2 opacity-50 font-monospace border-top border-info border-opacity-20" style="font-size: 1rem;">
        <span>發佈人: @Model.EmployeeName</span>
        <span class="text-info">最後更新: @Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
    </div>
</div>