@using TicketSalesSystem.ViewModel.Programme.EditProgramme
@model VMProgrammeEdit

@{
    ViewData["Title"] = "編輯活動項目";
}

<div class="container mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-pencil-square"></i> 編輯活動</h2>
        <a asp-controller="Programmes" asp-action="Index" class="btn btn-secondary">返回列表</a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>        
        <input type="hidden" asp-for="ProgrammeID" />
        <input type="hidden" asp-for="CoverImage" />
        <input type="hidden" asp-for="SeatImage" />

        <div class="row">
            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">活動封面圖</div>
                    <div class="card-body text-center">
                        <img id="coverPreview" src="/Photos/CoverImage/@Model.CoverImage" class="img-fluid rounded mb-3 shadow-sm" style="max-height: 300px; width: 100%; object-fit: cover;" />
                        <div class="input-group">
                            <input type="file" asp-for="CoverImageFile" class="form-control" accept="image/*" onchange="previewImage(this, 'coverPreview')" />
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">座位參考圖</div>
                    <div class="card-body text-center">
                        <img id="seatPreview" src="/Photos/SeatImage/@Model.SeatImage" class="img-fluid rounded mb-3 shadow-sm" style="max-height: 200px; width: 100%; object-fit: contain;" />
                        <div class="input-group">
                            <input type="file" asp-for="SeatImageFile" class="form-control" accept="image/*" onchange="previewImage(this, 'seatPreview')" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">基本資訊</div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-12 mb-3">
                                <label asp-for="ProgrammeName" class="form-label fw-bold">活動名稱</label>
                                <input asp-for="ProgrammeName" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">地區</label>
                                <select asp-for="PlaceID" class="form-select" id="PlaceID" asp-items="ViewBag.PlaceID">
                                    <option value="">-- 請選擇地區 --</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">活動狀態</label>
                                <select asp-for="ProgrammeStatusID" class="form-select" asp-items="ViewBag.ProgrammeStatusID"></select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="OnShelfTime" class="form-label fw-bold">上架時間</label>
                                <input asp-for="OnShelfTime" class="form-control" type="datetime-local" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LimitPerOrder" class="form-label fw-bold">每單限購</label>
                                <input asp-for="LimitPerOrder" class="form-control" type="number" min="1" />
                            </div>
                            <div class="col-12 mb-3">
                                <label asp-for="ProgrammeDescription" class="form-label fw-bold">活動簡介</label>
                                <textarea asp-for="ProgrammeDescription" class="form-control" rows="4"></textarea>
                            </div>
                            <div class="card shadow-sm mb-4">
                                <div class="card-header bg-dark text-white">活動描述圖 (多圖)</div>
                                <div class="card-body">
                                    <div class="row g-2 mb-3">
                                        @for (int k = 0; k < Model.DescriptionImage.Count; k++)
                                        {
                                            <div class="col-3 text-center position-relative">
                                                @* 🚩 必須加入隱藏欄位，後端才知道這張圖已經存在 *@
                                                <input type="hidden" name="DescriptionImage[@k].DescriptionImageID" value="@Model.DescriptionImage[k].DescriptionImageID" />
                                                <input type="hidden" name="DescriptionImage[@k].DescriptionImageName" value="@Model.DescriptionImage[k].DescriptionImageName" />

                                                <img src="/Photos/DescriptionImage/@Model.DescriptionImage[k].TempUrl" class="img-thumbnail" style="height: 100px; width: 100%; object-fit: cover;" />
                                                <div class="mt-1">
                                                    <div class="form-check form-check-inline">
                                                        <input class="form-check-input" type="checkbox" name="DeleteImageIds" value="@Model.DescriptionImage[k].DescriptionImageID" id="del_@k">
                                                        <label class="form-check-label small text-danger" for="del_@k">刪除</label>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <label class="form-label fw-bold">上傳新描述圖</label>
                                    <input type="file" asp-for="NewDescriptionFiles" class="form-control" multiple accept="image/*" />
                                    <div class="form-text">可多選，新圖將會追加到活動描述中。</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">場次與票區管理</h5>
                <button type="button" class="btn btn-light btn-sm fw-bold" id="add-session">+ 新增場次</button>
            </div>
            <div class="card-body p-0" id="session-container">
                @for (int i = 0; i < Model.Session.Count; i++)
                {
                    <div class="session-item border-bottom p-4" data-index="@i">
                        <input type="hidden" name="Session[@i].ProgrammeID" value="@Model.ProgrammeID" />
                        <input type="hidden" name="Session[@i].SessionID" value="@Model.Session[i].SessionID" class="session-id-input" />
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="text-success"><i class="bi bi-calendar-event"></i> 場次 #<span class="session-num">@(i + 1)</span></h5>
                            <button type="button" class="btn btn-outline-danger btn-sm remove-session">刪除此場次</button>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="small fw-bold">演出開始時間</label>
                                <input type="datetime-local" name="Session[@i].StartTime" value="@Model.Session[i].StartTime.ToString("yyyy-MM-ddTHH:mm")" class="form-control shadow-sm" required />
                            </div>
                            <div class="col-md-4">
                                <label class="small fw-bold">售票開始時間</label>
                                <input type="datetime-local" name="Session[@i].SaleStartTime" value="@Model.Session[i].SaleStartTime.ToString("yyyy-MM-ddTHH:mm")" class="form-control shadow-sm" required />
                            </div>
                            <div class="col-md-4">
                                <label class="small fw-bold">售票結束時間</label>
                                <input type="datetime-local" name="Session[@i].SaleEndTime" value="@Model.Session[i].SaleEndTime.ToString("yyyy-MM-ddTHH:mm")" class="form-control shadow-sm" required />
                            </div>
                        </div>

                        <div class="table-responsive rounded shadow-sm">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr class="small text-center">
                                        <th style="width: 20%">場館</th>
                                        <th>票區名稱</th>
                                        <th style="width: 15%">價格</th>
                                        <th style="width: 10%">排數</th>
                                        <th style="width: 10%">座/排</th>
                                        <th style="width: 5%"></th>
                                    </tr>
                                </thead>
                                <tbody class="area-tbody">
                                    @if (Model.Session[i].TicketsArea != null && Model.Session[i].TicketsArea.Any())
                                    {
                                        @for (int j = 0; j < Model.Session[i].TicketsArea.Count; j++)
                                        {
                                            var area = Model.Session[i].TicketsArea[j];

                                            <tr>
                                                @* 隱藏欄位確保 ID 能傳回後端進行更新而非新增 *@
                                               
                                                <input type="hidden" name="Session[@i].TicketsArea[@j].TicketsAreaID" value="@area.TicketsAreaID" class="area-id-input" />
                                                <input type="hidden" name="Session[@i].TicketsArea[@j].SessionID" value="@Model.Session[i].SessionID" />
                                                <input type="hidden" name="Session[@i].TicketsArea[@j].TicketsAreaStatusID" value="@(area.TicketsAreaStatusID ?? "A")" />
                                                <td>
                                                    <select name="Session[@i].TicketsArea[@j].VenueID"
                                                            class="form-select form-select-sm venue-select"
                                                            data-init-value="@area.VenueID"
                                                            asp-items="@(new SelectList(ViewBag.VenueID as SelectList, "Value", "Text", area.VenueID))">
                                                        <option value="">-- 選擇場館 --</option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input name="Session[@i].TicketsArea[@j].TicketsAreaName" value="@area.TicketsAreaName" class="form-control form-control-sm" />
                                                </td>
                                                <td>
                                                    <input name="Session[@i].TicketsArea[@j].Price" value="@area.Price" type="number" class="form-control form-control-sm text-end" />
                                                </td>
                                                <td>
                                                    <input name="Session[@i].TicketsArea[@j].RowCount" value="@area.RowCount" type="number" class="form-control form-control-sm" />
                                                </td>
                                                <td>
                                                    <input name="Session[@i].TicketsArea[@j].SeatCount" value="@area.SeatCount" type="number" class="form-control form-control-sm" />
                                                </td>
                                                <td>
                                                    <button type="button" class="btn btn-link text-danger remove-area p-0">×</button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        <button type="button" class="btn btn-outline-info btn-sm mt-2 add-ticket-area">+ 新增票區</button>
                    </div>
                }
            </div>
        </div>

        <div class="text-center mt-5 mb-5">
            <button type="submit" class="btn btn-primary btn-lg px-5 shadow-lg">確認更新活動資料</button>
        </div>
    </form>
    <div asp-validation-summary="All" class="text-danger"></div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    @* 加入驗證腳本 *@

    <script>
        const getVenuesUrl = '@Url.Action("GetVenues")';
        let cachedVenues = [];

        function previewImage(input, previewId) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) { $('#' + previewId).attr('src', e.target.result); }
                reader.readAsDataURL(input.files[0]);
            }
        }

        // 將工具函數放在 Ready 外面
        function reIndexAll() {
            console.log("正在重整索引...");
            $(".session-item").each(function (sIdx) {
                const $session = $(this);
                $session.attr("data-index", sIdx); // 確保 data-index 也被更新
                $session.find(".session-num").text(sIdx + 1);

                $session.find("input, select, textarea").each(function () {
                    let name = $(this).attr("name");
                    if (name) {
                        // 使用 /g 旗標確保替換所有匹配項
                        let newName = name.replace(/Session\[\d+\]/g, `Session[${sIdx}]`);

                        if (newName.includes("TicketsArea")) {
                            const $tr = $(this).closest("tr");
                            if ($tr.length > 0) {
                                const tIdx = $tr.index();
                                newName = newName.replace(/TicketsArea\[\d+\]/g, `TicketsArea[${tIdx}]`);
                            }
                        }
                        $(this).attr("name", newName);
                    }
                });
            });
        }

        $(document).ready(function () {
            console.log("頁面初始化中...");

            // 1. 初始化場館
            const initialPid = $("#PlaceID").val();
            console.log("初始 PlaceID:", initialPid);
            if (initialPid) {
                loadVenues(initialPid, true);
            }else {
            console.warn("未抓到初始 PlaceID，請檢查 HTML id 是否為 PlaceID");
            }

            // 2. 地區切換
            $("#PlaceID").on("change", function () {
                loadVenues($(this).val(), false);
            });

            function loadVenues(placeId, isInitial) {
                if (!placeId) {
                    cachedVenues = [];
                    updateVenueSelects(isInitial);
                    return;
                }
                $.ajax({
                    url: getVenuesUrl,
                    type: 'GET',
                    data: { placeId: placeId },
                    success: function (data) {
                        cachedVenues = data;
                        window.cachedVenues = data; // 確保全域可存取
                        updateVenueSelects(isInitial);
                    },
                    error: function(err) {
                        console.error("無法取得場館資料", err);
                    }
                });
            }

            function updateVenueSelects(isInitial) {
                $(".venue-select").each(function () {
                    const $s = $(this);
                    const initValue = $s.attr("data-init-value");
                    const currentValue = $s.val();
                    const savedVal = isInitial ? initValue : currentValue;

                    let opt = '<option value="">-- 選擇場館 --</option>';
                    if (cachedVenues && cachedVenues.length > 0) {
                        cachedVenues.forEach(v => {
                            const vID = String(v.venueID || v.VenueID || "").trim(); // 👈 同時檢查小寫與大寫
                            const vName = v.venueName || v.VenueName;               // 👈 同時檢查小寫與大寫

                            const sVal = String(savedVal || "").trim();
                            const isSelected = (vID === sVal && sVal !== "") ? 'selected' : '';
                            opt += `<option value="${vID}" ${isSelected}>${vName}</option>`;
                        });
                    }
                    $s.html(opt);
                });
            }

            // 3. 新增場次
            $("#add-session").on("click", function (e) {
                e.preventDefault();
                const sIdx = $(".session-item").length;
                const html = `
                <div class="session-item border border-secondary rounded p-3 mb-3" data-index="${sIdx}">
                    <input type="hidden" name="Session[${sIdx}].SessionID" value="" />
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="mb-0">場次 #<span class="session-num">${sIdx + 1}</span></h5>
                        <button type="button" class="btn btn-danger btn-sm remove-session">刪除場次</button>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4"><label class="form-label small">演出時間</label><input type="datetime-local" name="Session[${sIdx}].StartTime" class="form-control form-control-sm" required /></div>
                        <div class="col-md-4"><label class="form-label small">開賣時間</label><input type="datetime-local" name="Session[${sIdx}].SaleStartTime" class="form-control form-control-sm" required /></div>
                        <div class="col-md-4"><label class="form-label small">結束時間</label><input type="datetime-local" name="Session[${sIdx}].SaleEndTime" class="form-control form-control-sm" required /></div>
                    </div>
                    <table class="table table-sm">
                        <thead><tr><th>場館</th><th>票區</th><th>價格</th><th>排</th><th>座</th><th></th></tr></thead>
                        <tbody class="area-tbody"></tbody>
                    </table>
                    <button type="button" class="btn btn-secondary btn-sm add-ticket-area">+ 新增票區</button>
                </div>`;
                $("#session-container").append(html);
            });

            // 4. 新增票區 (使用事件委派)
            $(document).on("click", ".add-ticket-area", function (e) {
                e.preventDefault();
                const $session = $(this).closest(".session-item");
                const sIdx = $session.attr("data-index");
                const $tbody = $session.find(".area-tbody");
                const tIdx = $tbody.find("tr").length;

                let opts = '<option value="">-- 選擇場館 --</option>';
                if (cachedVenues && cachedVenues.length > 0) {
                    cachedVenues.forEach(v => {
                        opts += `<option value="${v.venueID || v.VenueID}">${v.venueName || v.VenueName}</option>`;
                    });
                }

                const row = `
                <tr>
                    <input type="hidden" name="Session[${sIdx}].TicketsArea[${tIdx}].TicketsAreaID" value="" />
                    <input type="hidden" name="Session[${sIdx}].TicketsArea[${tIdx}].TicketsAreaStatusID" value="A" />
                    <td><select name="Session[${sIdx}].TicketsArea[${tIdx}].VenueID" class="form-select form-select-sm venue-select" required>${opts}</select></td>
                    <td><input name="Session[${sIdx}].TicketsArea[${tIdx}].TicketsAreaName" class="form-control form-control-sm" required /></td>
                    <td><input type="number" name="Session[${sIdx}].TicketsArea[${tIdx}].Price" class="form-control form-control-sm text-end" required /></td>
                    <td><input type="number" name="Session[${sIdx}].TicketsArea[${tIdx}].RowCount" class="form-control form-control-sm text-center" required /></td>
                    <td><input type="number" name="Session[${sIdx}].TicketsArea[${tIdx}].SeatCount" class="form-control form-control-sm text-center" required /></td>
                    <td><button type="button" class="btn btn-sm btn-outline-danger remove-area">×</button></td>
                </tr>`;
                $tbody.append(row);
            });

            // 5. 刪除
            $(document).on("click", ".remove-area", function () {
                $(this).closest("tr").remove();
                reIndexAll();
            });

            $(document).on("click", ".remove-session", function () {
                if(confirm("確定刪除？")) {
                    $(this).closest(".session-item").remove();
                    reIndexAll();
                }
            });

            $('#editForm').on('submit', function() {
            reIndexAll(); // 送出前最後校正一次
            });


        }); // Ready 結尾
    </script>
}