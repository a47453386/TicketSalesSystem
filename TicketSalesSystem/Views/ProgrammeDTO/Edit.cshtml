@using TicketSalesSystem.ViewModel.Programme.EditProgramme
@model VMProgrammeEdit

@{
    ViewData["Title"] = "編輯活動項目";
    
}

<div class="container mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-pencil-square"></i> 編輯活動</h2>
        <a asp-controller="Programmes" asp-action="Index" class="btn btn-secondary">返回列表</a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>        
        <input type="hidden" asp-for="ProgrammeID" />
        <input type="hidden" asp-for="CoverImage" />
        <input type="hidden" asp-for="SeatImage" />

        <div class="row">
            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">活動封面圖</div>
                    <div class="card-body text-center">
                        <img id="coverPreview" src="/Photos/CoverImage/@Model.CoverImage" class="img-fluid rounded mb-3 shadow-sm" style="max-height: 300px; width: 100%; object-fit: cover;" />
                        <div class="input-group">
                            <input type="file" asp-for="CoverImageFile" class="form-control" accept="image/*" onchange="previewImage(this, 'coverPreview')" />
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">座位參考圖</div>
                    <div class="card-body text-center">
                        <img id="seatPreview" src="/Photos/SeatImage/@Model.SeatImage" class="img-fluid rounded mb-3 shadow-sm" style="max-height: 200px; width: 100%; object-fit: contain;" />
                        <div class="input-group">
                            <input type="file" asp-for="SeatImageFile" class="form-control" accept="image/*" onchange="previewImage(this, 'seatPreview')" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">基本資訊</div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-12 mb-3">
                                <label asp-for="ProgrammeName" class="form-label fw-bold">活動名稱</label>
                                <input asp-for="ProgrammeName" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">地區</label>
                                <select asp-for="PlaceID" class="form-select" id="PlaceID" asp-items="ViewBag.PlaceID">
                                    <option value="">-- 請選擇地區 --</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">活動狀態</label>
                                <select asp-for="ProgrammeStatusID" class="form-select" asp-items="ViewBag.ProgrammeStatusID"></select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="OnShelfTime" class="form-label fw-bold">上架時間</label>
                                <input asp-for="OnShelfTime" class="form-control" type="datetime-local" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LimitPerOrder" class="form-label fw-bold">每單限購</label>
                                <input asp-for="LimitPerOrder" class="form-control" type="number" min="1" />
                            </div>
                            <div class="col-12 mb-3">
                                <label asp-for="ProgrammeDescription" class="form-label fw-bold">活動簡介</label>
                                <textarea asp-for="ProgrammeDescription" class="form-control" rows="4"></textarea>
                            </div>
                            <div class="card shadow-sm mb-4">
                                <div class="card-header bg-dark text-white">活動描述圖 (多圖)</div>
                                <div class="card-body">
                                    <div class="row g-2 mb-3">
                                        @for (int k = 0; k < Model.DescriptionImage.Count; k++)
                                        {
                                            <div class="col-3 text-center position-relative">
                                                @* 🚩 必須加入隱藏欄位，後端才知道這張圖已經存在 *@
                                                <input type="hidden" name="DescriptionImage[@k].DescriptionImageID" value="@Model.DescriptionImage[k].DescriptionImageID" />
                                                <input type="hidden" name="DescriptionImage[@k].DescriptionImageName" value="@Model.DescriptionImage[k].DescriptionImageName" />

                                                <img src="/Photos/DescriptionImage/@Model.DescriptionImage[k].TempUrl" class="img-thumbnail" style="height: 100px; width: 100%; object-fit: cover;" />
                                                <div class="mt-1">
                                                    <div class="form-check form-check-inline">
                                                        <input class="form-check-input" type="checkbox" name="DeleteImageIds" value="@Model.DescriptionImage[k].DescriptionImageID" id="del_@k">
                                                        <label class="form-check-label small text-danger" for="del_@k">刪除</label>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <label class="form-label fw-bold">上傳新描述圖</label>
                                    <input type="file" asp-for="NewDescriptionFiles" class="form-control" multiple accept="image/*" />
                                    <div class="form-text">可多選，新圖將會追加到活動描述中。</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">場次與票區管理</h5>
                <button type="button" class="btn btn-light btn-sm fw-bold" id="add-session">+ 新增場次</button>
            </div>
            <div class="card-body p-0" id="session-container">
                @for (int i = 0; i < Model.Session.Count; i++)
                {
                    <div class="session-item border-bottom p-4" data-index="@i">
                        <input type="hidden" name="Session[@i].ProgrammeID" value="@Model.ProgrammeID" />
                        <input type="hidden" name="Session[@i].SessionID" value="@Model.Session[i].SessionID" class="session-id-input" />
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="text-success"><i class="bi bi-calendar-event"></i> 場次 #<span class="session-num">@(i + 1)</span></h5>
                            <button type="button" class="btn btn-outline-danger btn-sm remove-session">刪除此場次</button>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="small fw-bold">演出開始時間</label>
                                <input type="datetime-local" name="Session[@i].StartTime" value="@Model.Session[i].StartTime.ToString("yyyy-MM-ddTHH:mm")" class="form-control shadow-sm" required />
                            </div>
                            <div class="col-md-4">
                                <label class="small fw-bold">售票開始時間</label>
                                <input type="datetime-local" name="Session[@i].SaleStartTime" value="@Model.Session[i].SaleStartTime.ToString("yyyy-MM-ddTHH:mm")" class="form-control shadow-sm" required />
                            </div>
                            <div class="col-md-4">
                                <label class="small fw-bold">售票結束時間</label>
                                <input type="datetime-local" name="Session[@i].SaleEndTime" value="@Model.Session[i].SaleEndTime.ToString("yyyy-MM-ddTHH:mm")" class="form-control shadow-sm" required />
                            </div>
                        </div>

                        <div class="table-responsive rounded shadow-sm">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr class="small text-center">
                                        <th style="width: 15%">場館</th>
                                        <th>票區名稱</th>
                                        <th style="width: 12%">價格</th>
                                        <th style="width: 8%">排數</th>
                                        <th style="width: 8%">座/排</th>
                                        <th style="width: 10%">總量</th> @* 🚩 新增 *@
                                        <th style="width: 10%">剩餘</th> @* 🚩 新增 *@
                                        <th style="width: 5%"></th>
                                    </tr>
                                </thead>
                                <tbody class="area-tbody">
                                    @if (Model.Session[i].TicketsArea != null && Model.Session[i].TicketsArea.Any())
                                    {
                                        @for (int j = 0; j < Model.Session[i].TicketsArea.Count; j++)
                                        {
                                            var area = Model.Session[i].TicketsArea[j];

                                            <tr>
                                                @* 隱藏欄位確保 ID 能傳回後端進行更新而非新增 *@
                                               
                                                <input type="hidden" name="Session[@i].TicketsArea[@j].TicketsAreaID" value="@area.TicketsAreaID" class="area-id-input" />
                                                <input type="hidden" name="Session[@i].TicketsArea[@j].SessionID" value="@Model.Session[i].SessionID" />
                                                <input type="hidden" name="Session[@i].TicketsArea[@j].TicketsAreaStatusID" value="@(area.TicketsAreaStatusID ?? "A")" />
                                                <td>
                                                    <select name="Session[@i].TicketsArea[@j].VenueID"
                                                            class="form-select form-select-sm venue-select"
                                                            data-init-value="@Model.Session[i].TicketsArea[j].VenueID">
                                                        @* 🚩 這是給 JS 看的備忘錄 *@
                                                        <option value="">-- 選擇場館 --</option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input name="Session[@i].TicketsArea[@j].TicketsAreaName" value="@area.TicketsAreaName" class="form-control form-control-sm" />
                                                </td>
                                                <td>
                                                    <input name="Session[@i].TicketsArea[@j].Price" value="@area.Price" type="number" class="form-control form-control-sm text-end" />
                                                </td>
                                                <td>
                                                    <input name="Session[@i].TicketsArea[@j].RowCount"
                                                           value="@area.RowCount" type="number"
                                                           class="form-control form-control-sm row-count-input" /> @* 🚩 加上 row-count-input *@
                                                </td>
                                                <td>
                                                    <input name="Session[@i].TicketsArea[@j].SeatCount"
                                                           value="@area.SeatCount" type="number"
                                                           class="form-control form-control-sm seat-count-input" /> @* 🚩 加上 seat-count-input *@
                                                </td>
                                                <td>
                                                    <input name="Session[@i].TicketsArea[@j].Capacity" value="@area.Capacity" class="form-control form-control-sm text-center capacity-input bg-light" readonly />
                                                </td>
                                                <td>
                                                    <input name="Session[@i].TicketsArea[@j].Remaining" value="@area.Remaining" class="form-control form-control-sm text-center bg-light fw-bold @(area.Remaining < 10 ? "text-danger" : "text-primary")" readonly />
                                                </td>
                                                <td>
                                                    <button type="button" class="btn btn-link text-danger remove-area p-0">×</button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        <button type="button" class="btn btn-outline-info btn-sm mt-2 add-ticket-area">+ 新增票區</button>
                    </div>
                }
            </div>
        </div>

        <div class="text-center mt-5 mb-5">
            <button type="submit" class="btn btn-primary btn-lg px-5 shadow-lg">確認更新活動資料</button>
        </div>
    </form>
    <div asp-validation-summary="All" class="text-danger"></div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const getVenuesUrl = '@Url.Action("GetVenues")';
        let cachedVenues = []; // 快取當前地區的所有場館資料

        // 1. 圖片預覽功能
        function previewImage(input, previewId) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) { $('#' + previewId).attr('src', e.target.result); }
                reader.readAsDataURL(input.files[0]);
            }
        }

        // 🚩 2. 核心驗證函數：即時產出「物理上限」警示訊息
        function validateRow($row) {
            const $select = $row.find(".venue-select");
            const $selectedOpt = $select.find("option:selected");

            // 從選中的 option 讀取物理上限 (data 屬性)
            const maxR = parseInt($selectedOpt.data("max-row")) || 0;
            const maxS = parseInt($selectedOpt.data("max-seat")) || 0;
            const vName = $selectedOpt.text().split('(')[0].trim() || "該區域";

            // 取得目前輸入值
            const currR = parseInt($row.find(".row-count-input").val()) || 0;
            const currS = parseInt($row.find(".seat-count-input").val()) || 0;

            // 計算並更新總量
            const total = currR * currS;
            $row.find(".capacity-input").val(total);

            // 如果是「新票區」(無 ID)，同步更新剩餘票數
            const areaId = $row.find(".area-id-input").val();
            if (!areaId) {
                $row.find("input[name*='Remaining']").val(total);
            }

            let errorMsg = "";
            // 🚩 物理上限邏輯判斷
            if (maxR > 0 && currR > maxR) {
                errorMsg = `區域【${vName}】物理上限為 ${maxR} 排，您的設定已超出限制。`;
            } else if (maxS > 0 && currS > maxS) {
                errorMsg = `區域【${vName}】物理上限為每排 ${maxS} 座，您的設定已超出限制。`;
            }

            if (errorMsg !== "") {
                $row.addClass("table-danger");
                if (!$row.find(".error-msg").length) {
                    // 訊息插入在「總量」那一格 (第 6 欄) 下方
                    $row.find("td:nth-child(6)").append(`<div class="error-msg text-danger fw-bold mt-1" style="font-size: 0.75rem; line-height: 1.2;">${errorMsg}</div>`);
                } else {
                    $row.find(".error-msg").text(errorMsg);
                }
            } else {
                $row.removeClass("table-danger");
                $row.find(".error-msg").remove();
            }

            // 只要有錯誤，就鎖定提交按鈕
            $('#editForm button[type="submit"]').prop("disabled", $(".table-danger").length > 0);
        }

        // 🚩 3. 渲染選單：解決「抓不到 VenueID」並執行選取
        function updateVenueSelects(isInitial) {
            $(".venue-select").each(function () {
                const $select = $(this);
                // 優先從標籤的 data-init-value 拿原始值 (資料庫值)
                const originalValue = $select.attr("data-init-value") || $select.val();

                let opt = '<option value="">-- 選擇場館 --</option>';
                if (cachedVenues && cachedVenues.length > 0) {
                    cachedVenues.forEach(v => {
                        const vID = String(v.venueID || v.VenueID || "").trim();
                        const vName = v.venueName || v.VenueName;
                        const mR = v.rowCount || v.RowCount;
                        const mS = v.seatCount || v.SeatCount;
                        opt += `<option value="${vID}" data-max-row="${mR}" data-max-seat="${mS}">${vName}</option>`;
                    });
                }

                // 🚩 覆蓋掉 Razor 產生的舊選單，換成有 data-max 屬性的新選單
                $select.html(opt);

                // 🚩 補救選取動作
                if (isInitial && originalValue) {
                    $select.val(originalValue);
                    // 針對 GUID 大小寫不一致的二次檢查
                    if ($select.val() === null) {
                        $select.find("option").each(function() {
                            if ($(this).val().toLowerCase() === String(originalValue).toLowerCase()) {
                                $(this).prop("selected", true);
                            }
                        });
                    }
                }
                // 渲染完立即驗證
                validateRow($select.closest("tr"));
            });
        }

        // 🚩 4. 索引重整 (確保 Model Binding 成功)
        function reIndexAll() {
            $(".session-item").each(function (sIdx) {
                const $session = $(this);
                $session.attr("data-index", sIdx);
                $session.find(".session-num").text(sIdx + 1);

                $session.find("input, select, textarea").each(function () {
                    let name = $(this).attr("name");
                    if (name) {
                        let newName = name.replace(/Session\[\d+\]/g, `Session[${sIdx}]`);
                        if (newName.includes("TicketsArea")) {
                            const $tr = $(this).closest("tr");
                            if ($tr.length > 0) {
                                const tIdx = $tr.index();
                                newName = newName.replace(/TicketsArea\[\d+\]/g, `TicketsArea[${tIdx}]`);
                            }
                        }
                        $(this).attr("name", newName);
                    }
                });
            });
        }

        $(document).ready(function () {
            // --- A. 初始化載入 ---
            const initialPid = $("#PlaceID").val();
            if (initialPid) {
                $.get(getVenuesUrl, { placeId: initialPid }, function (data) {
                    cachedVenues = data;
                    updateVenueSelects(true);
                });
            }

            // --- B. 地區切換 ---
            $("#PlaceID").on("change", function () {
                const newPlaceId = $(this).val();
                if(confirm("切換地區將清空目前票區的所有區域設定，確定嗎？")) {
                    $.get(getVenuesUrl, { placeId: newPlaceId }, function (data) {
                        cachedVenues = data;
                        updateVenueSelects(false);
                    });
                } else {
                    $(this).val($(this).data('prev'));
                }
            }).on("focus", function () { $(this).data('prev', $(this).val()); });

            // --- C. 即時監聽變動 ---
            $(document).on("input change", ".row-count-input, .seat-count-input, .venue-select", function () {
                validateRow($(this).closest("tr"));
            });

            // 🚩 D. 新增場次邏輯 (HTML 拼接)
            $("#add-session").on("click", function (e) {
                e.preventDefault();
                const sIdx = $(".session-item").length;
                const html = `
                <div class="session-item border-bottom p-4" data-index="${sIdx}">
                    <input type="hidden" name="Session[${sIdx}].SessionID" value="" />
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="text-success"><i class="bi bi-calendar-plus"></i> 場次 #<span class="session-num">${sIdx + 1}</span> (新)</h5>
                        <button type="button" class="btn btn-outline-danger btn-sm remove-session">刪除此場次</button>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4"><label class="small fw-bold">演出時間</label><input type="datetime-local" name="Session[${sIdx}].StartTime" class="form-control shadow-sm" required /></div>
                        <div class="col-md-4"><label class="small fw-bold">售票開始時間</label><input type="datetime-local" name="Session[${sIdx}].SaleStartTime" class="form-control shadow-sm" required /></div>
                        <div class="col-md-4"><label class="small fw-bold">售票結束時間</label><input type="datetime-local" name="Session[${sIdx}].SaleEndTime" class="form-control shadow-sm" required /></div>
                    </div>
                    <table class="table table-sm">
                        <thead><tr class="small text-center"><th>場館</th><th>票區</th><th>價格</th><th style="width:80px">排</th><th style="width:80px">座</th><th style="width:120px">總量</th><th></th></tr></thead>
                        <tbody class="area-tbody"></tbody>
                    </table>
                    <button type="button" class="btn btn-outline-info btn-sm add-ticket-area">+ 新增票區</button>
                </div>`;
                $("#session-container").append(html);
                reIndexAll();
            });

            // 🚩 E. 新增票區邏輯 (HTML 拼接)
            $(document).on("click", ".add-ticket-area", function (e) {
                e.preventDefault();
                const $session = $(this).closest(".session-item");
                const sIdx = $session.attr("data-index");
                const $tbody = $session.find(".area-tbody");
                const tIdx = $tbody.find("tr").length;

                let venueOpts = '<option value="">-- 選擇場館 --</option>';
                cachedVenues.forEach(v => {
                    venueOpts += `<option value="${v.venueID || v.VenueID}" data-max-row="${v.rowCount || v.RowCount}" data-max-seat="${v.seatCount || v.SeatCount}">${v.venueName || v.VenueName}</option>`;
                });

                const row = `
                <tr>
                    <input type="hidden" name="Session[${sIdx}].TicketsArea[${tIdx}].TicketsAreaID" value="" class="area-id-input" />
                    <td><select name="Session[${sIdx}].TicketsArea[${tIdx}].VenueID" class="form-select form-select-sm venue-select" required>${venueOpts}</select></td>
                    <td><input name="Session[${sIdx}].TicketsArea[${tIdx}].TicketsAreaName" class="form-control form-control-sm" required /></td>
                    <td><input type="number" name="Session[${sIdx}].TicketsArea[${tIdx}].Price" class="form-control form-control-sm text-end" value="0" /></td>
                    <td><input type="number" name="Session[${sIdx}].TicketsArea[${tIdx}].RowCount" class="form-control form-control-sm text-center row-count-input" value="0" /></td>
                    <td><input type="number" name="Session[${sIdx}].TicketsArea[${tIdx}].SeatCount" class="form-control form-control-sm text-center seat-count-input" value="0" /></td>
                    <td><input name="Session[${sIdx}].TicketsArea[${tIdx}].Capacity" class="form-control form-control-sm text-center capacity-input bg-light" readonly /></td>
                    <td><button type="button" class="btn btn-link text-danger remove-area p-0">×</button></td>
                </tr>`;
                $tbody.append(row);
                reIndexAll();
            });

            // --- F. 刪除邏輯 ---
            $(document).on("click", ".remove-area, .remove-session", function () {
                const target = $(this).closest( $(this).hasClass("remove-area") ? "tr" : ".session-item" );
                target.fadeOut(200, function() { $(this).remove(); reIndexAll(); });
            });

            $('#editForm').on('submit', function() { reIndexAll(); });
        });
    </script>
}