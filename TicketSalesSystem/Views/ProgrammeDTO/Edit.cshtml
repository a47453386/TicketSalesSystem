@using TicketSalesSystem.ViewModel.Programme.EditProgramme
@model VMProgrammeEdit

@{
    ViewData["Title"] = "活動更新";
}

@* 🚩 引用統一的透明科技感 CSS *@
<link rel="stylesheet" href="~/css/Admin/Programme/ProgrammeEdit.css" asp-append-version="true" />

<div class="admin-body p-4">
    @* --- 頂部標題與返回鈕 --- *@
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="neon-header mb-0"><i class="bi bi-cpu-fill me-2"></i>@ViewData["Title"]</h2>
        <a asp-controller="Programmes" asp-action="AdminIndex" class="btn btn-outline-secondary font-monospace">
            <i class="bi bi-arrow-left"></i> 返回列表
        </a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">
        @Html.AntiForgeryToken()

        @* 🚩 核心隱藏欄位 *@
        <input type="hidden" asp-for="ProgrammeID" />
        <input type="hidden" asp-for="CoverImage" />
        <input type="hidden" asp-for="SeatImage" />
        <input type="hidden" asp-for="PlaceID" />
        @* --- [第一部份] 雙欄佈局：基本資料 (左 8) 與 核心媒體 (右 4) --- *@
        <div class="row g-4 align-items-stretch">
            @* 左側：核心資料區 *@
            <div class="col-lg-8">
                <div class="cyber-card p-4 h-100">
                    <div class="tech-key">第一部份: 基本資料</div>
                    <div class="row g-3">
                        <div class="col-12 mb-3">
                            <label asp-for="ProgrammeName" class="tech-key small">活動名稱</label>
                            <input asp-for="ProgrammeName" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="tech-key small">演出地點</label>
                            <select asp-for="PlaceID" class="form-select" id="PlaceID" asp-items="ViewBag.PlaceID"></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="tech-key small">活動狀態</label>
                            <select asp-for="ProgrammeStatusID" class="form-select" asp-items="ViewBag.ProgrammeStatusID"></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="OnShelfTime" class="tech-key small">預計上架時間</label>
                            <input asp-for="OnShelfTime" class="form-control" type="datetime-local" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="LimitPerOrder" class="tech-key small">購票上限</label>
                            <input asp-for="LimitPerOrder" class="form-control" type="number" />
                        </div>
                    </div>
                </div>
            </div>

            @* 右側：主要媒體資產 *@
            <div class="col-lg-4">
                <div class="cyber-card p-3 mb-3">
                    <div class="tech-key small">主視覺封面</div>
                    <div class="img-preview-tech mb-2">
                        <img id="coverPreview" src="/Photos/CoverImage/@Model.CoverImage" class="w-100" style="height: 150px; object-fit: cover;" />
                    </div>
                    <input type="file" asp-for="CoverImageFile" class="form-control form-control-sm" accept="image/*" onchange="previewImage(this, 'coverPreview')" />
                </div>
                <div class="cyber-card p-3">
                    <div class="tech-key small">場地配置圖</div>
                    <div class="img-preview-tech mb-2">
                        <img id="seatPreview" src="/Photos/SeatImage/@Model.SeatImage" class="w-100" style="height: 100px; object-fit: contain; background: #000;" />
                    </div>
                    <input type="file" asp-for="SeatImageFile" class="form-control form-control-sm" accept="image/*" onchange="previewImage(this, 'seatPreview')" />
                </div>
            </div>
        </div>

        @* --- [第二部份] 全寬說明文字區塊 --- *@
        <div class="cyber-card p-4 mt-4">
            <div class="tech-key mb-4">第二部份: 詳細說明</div>
            <div class="desc-block mb-4">
                <label asp-for="ProgrammeDescription" class="tech-key small">活動簡介</label>
                <textarea asp-for="ProgrammeDescription" class="form-control" rows="3"></textarea>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="desc-block warning mb-3">
                        <label asp-for="Notice" class="tech-key small text-warning">注意事項</label>
                        <textarea asp-for="Notice" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="desc-block mb-3">
                        <label asp-for="PurchaseReminder" class="tech-key small">購票提醒</label>
                        <textarea asp-for="PurchaseReminder" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="desc-block mb-3">
                        <label asp-for="CollectionReminder" class="tech-key small">取票提醒</label>
                        <textarea asp-for="CollectionReminder" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="desc-block danger mb-3">
                        <label asp-for="RefundPolicy" class="tech-key small text-danger">退票政策</label>
                        <textarea asp-for="RefundPolicy" class="form-control" rows="3"></textarea>
                    </div>
                </div>
            </div>
        </div>

        @* --- [第三部份] 說明圖片藝廊 --- *@
        <div class="cyber-card p-4 mt-4">
            <div class="tech-key mb-4">第三部份:說明圖片</div>
            <div class="row g-3 mb-4">
                @if (Model.DescriptionImage != null && Model.DescriptionImage.Count > 0)
                {
                    @for (int k = 0; k < Model.DescriptionImage.Count; k++)
                    {
                        var currentImg = Model.DescriptionImage[k];
                        @* 🚩 核心修正：處理特殊字元檔名 *@
                        var imageUrl = Url.Content("~/Photos/DescriptionImage/" + Uri.EscapeDataString(currentImg.DescriptionImageName ?? ""));

                        <div class="col-md-2 text-center">
                            <div class="img-preview-tech mb-2 position-relative">
                                <img src="@imageUrl" class="w-100" style="height: 120px; object-fit: cover; border-radius: 4px;" onerror="this.src='https://placehold.co/120x120/000000/00f2ff?text=NOT_FOUND'" />
                                <div class="position-absolute top-0 end-0 p-1">
                                    <input class="form-check-input bg-danger border-danger" type="checkbox" name="DeleteImageID" value="@currentImg.DescriptionImageID" id="del_@k">
                                    <label class="badge bg-danger cursor-pointer" for="del_@k" style="cursor:pointer">刪除</label>
                                </div>
                            </div>
                            <input type="hidden" name="DescriptionImage[@k].DescriptionImageID" value="@currentImg.DescriptionImageID" />
                            <input type="hidden" name="DescriptionImage[@k].DescriptionImageName" value="@currentImg.DescriptionImageName" />
                            <div class="small text-info opacity-50 text-truncate font-monospace" style="font-size: 0.6rem;">@currentImg.DescriptionImageName</div>
                        </div>
                    }
                }
            </div>
            <div class="p-3 bg-transparent img-preview-tech">
                <label asp-for="NewDescriptionFiles" class="tech-key small"><i class="bi bi-cloud-plus"></i> 新增圖片</label>
                <input type="file" asp-for="NewDescriptionFiles" class="form-control form-control-sm" multiple accept="image/*" />
            </div>
        </div>

        @* --- [第四部份] 場次、票區、票價矩陣 --- *@
        <div class="cyber-card p-0 mt-4 mb-5 overflow-hidden">
            <div class="card-header bg-dark text-info d-flex justify-content-between align-items-center p-3">
                <h5 class="mb-0 font-monospace">第四部份: 場次、票區、票價</h5>
                <button type="button" class="btn btn-info btn-sm fw-bold" id="add-session">+ 新增場次</button>
            </div>
            <div class="card-body p-0" id="session-container">
                @for (int i = 0; i < Model.Session.Count; i++)
                {
                    <div class="session-item border-bottom border-info border-opacity-10 p-4" data-index="@i">
                        <input type="hidden" name="Session[@i].SessionID" value="@Model.Session[i].SessionID" />

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="badge bg-info text-dark font-monospace">場次序號 #@(i + 1)</span>
                            <button type="button" class="btn btn-outline-danger btn-sm remove-session">終止場次</button>
                        </div>

                        <div class="row g-3 mb-4 font-monospace">
                            <div class="col-md-4">
                                <label class="small text-info">開演時間</label>
                                <input type="datetime-local" name="Session[@i].StartTime" value="@Model.Session[i].StartTime.ToString("yyyy-MM-ddTHH:mm")" class="form-control shadow-sm" required />
                            </div>
                            <div class="col-md-4">
                                <label class="small text-info">開賣時間</label>
                                <input type="datetime-local" name="Session[@i].SaleStartTime" value="@Model.Session[i].SaleStartTime.ToString("yyyy-MM-ddTHH:mm")" class="form-control shadow-sm" required />
                            </div>
                            <div class="col-md-4">
                                <label class="small text-info">停售時間</label>
                                <input type="datetime-local" name="Session[@i].SaleEndTime" value="@Model.Session[i].SaleEndTime.ToString("yyyy-MM-ddTHH:mm")" class="form-control shadow-sm" required />
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="cyber-table-edit text-center">
                                <thead>
                                    <tr>
                                        <th style="width: 18%">場館區域</th>
                                        <th>票區名稱</th>
                                        <th style="width: 10%">顏色</th>
                                        <th style="width: 12%">價格</th>
                                        <th style="width: 15%">規格 (RxS)</th>
                                        <th style="width: 10%">小計</th>
                                        <th style="width: 5%"></th>
                                    </tr>
                                </thead>
                                <tbody class="area-tbody">
                                    @for (int j = 0; j < Model.Session[i].TicketsArea.Count; j++)
                                    {
                                        var area = Model.Session[i].TicketsArea[j];
                                        <tr>
                                            <input type="hidden" name="Session[@i].TicketsArea[@j].TicketsAreaID" value="@area.TicketsAreaID" class="area-id-input" />
                                            <td>
                                                <select name="Session[@i].TicketsArea[@j].VenueID" class="form-select form-select-sm venue-select" data-init-value="@area.VenueID">
                                                    <option value="">-- 選取區域 --</option>
                                                </select>
                                            </td>
                                            <td><input name="Session[@i].TicketsArea[@j].TicketsAreaName" value="@area.TicketsAreaName" class="form-control form-control-sm" /></td>
                                            <td>
                                                @* 🚩 顏色預覽與隱藏欄位 *@
                                                <div class="area-color-preview mx-auto shadow-sm" style="background-color: @(area.AreaColor ?? "#00f2ff"); width: 25px; height: 25px; border-radius: 4px; border: 1px solid rgba(255,255,255,0.2);"></div>
                                                <input type="hidden" name="Session[@i].TicketsArea[@j].AreaColor" value="@area.AreaColor" />
                                            </td>
                                            <td><input name="Session[@i].TicketsArea[@j].Price" value="@area.Price" type="number" class="form-control form-control-sm text-end text-info fw-bold" /></td>
                                            <td>
                                                <div class="input-group input-group-sm">
                                                    <input name="Session[@i].TicketsArea[@j].RowCount" value="@area.RowCount" type="number" class="form-control text-center row-count-input" />
                                                    <span class="input-group-text bg-dark text-white-50 border-0">x</span>
                                                    <input name="Session[@i].TicketsArea[@j].SeatCount" value="@area.SeatCount" type="number" class="form-control text-center seat-count-input" />
                                                </div>
                                            </td>
                                            <td><input class="form-control form-control-sm text-center bg-transparent border-0 capacity-display text-white" value="@area.Remaining" readonly /></td>
                                            <td><button type="button" class="btn btn-link text-danger remove-area p-0">×</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <button type="button" class="btn btn-outline-info btn-sm mt-3 add-ticket-area">+ 新增票區</button>
                    </div>
                }
            </div>
        </div>

        @* --- 底部提交按鈕 --- *@
        <div class="text-center mt-5 mb-5">
            <button type="submit" class="btn-cyber-submit btn-lg px-5 shadow-lg">
                <i class="bi bi-cloud-upload-fill me-2"></i> 更新
            </button>
        </div>
    </form>
</div>
<div asp-validation-summary="All" class="text-danger"></div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // 🚩 在 View 裡解析 URL 變數，供給外部 JS 使用
        window.getVenuesUrl = '@Url.Action("GetVenues", "ProgrammeDTO")';
    </script>
    @* 🚩 引用外部 JS 控制邏輯 *@
    <script src="~/js/Programme/ProgrammeEdit.js" asp-append-version="true"></script>
}