@model TicketSalesSystem.DTOs.ProgrammeDTO

@{
    ViewData["Title"] = "最後確認 - 建立活動";
   
}

<div class="container mt-4">
    @await Component.InvokeAsync("VCSteps", new { currentStep = 5 }) @* 假設你進度條有第五步 *@

    <div class="alert alert-info shadow-sm d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-3 fs-3"></i>
        <div>
            請再次確認以下資訊是否正確。一旦按下「正式發布」，系統將會建立活動並開放購票設定。
        </div>
    </div>

    @* 1. 基本資料確認 *@
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white"><h5>1. 基本資料</h5></div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-2">活動名稱</dt>
                <dd class="col-sm-10">@Model.ProgrammeName</dd>

                <dt class="col-sm-2">場地 ID</dt>
                <dd class="col-sm-4">@ViewData["PlaceName"]</dd>

                <dt class="col-sm-2">單筆限購</dt>
                <dd class="col-sm-4">@Model.LimitPerOrder 張</dd>

                <dt class="col-sm-2">上架時間</dt>
                <dd class="col-sm-10">@Model.OnShelfTime.ToString("yyyy-MM-dd HH:mm")</dd>
            </dl>
        </div>
    </div>

    @* 2. 場次與票區彙整 *@
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-secondary text-white">
            <h5>3. 場次與票區詳細設定</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Session != null && Model.Session.Any())
            {
                @foreach (var session in Model.Session)
                {
                    <div class="p-3 border-bottom bg-light">
                        <span class="fw-bold text-primary">
                            <i class="bi bi-clock-history me-2"></i>
                            場次開演時間：@session.StartTime.ToString("yyyy-MM-dd HH:mm")
                        </span>
                        <span class="ms-3 badge bg-info">場地：@ViewData["VenueName"]</span>
                    </div>
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr class="small">
                                <th class="ps-4">票區名稱</th>
                                <th class="text-center">價格</th>
                                <th class="text-center">排數</th>
                                <th class="text-center">每排座位</th>
                                <th class="text-center">該場次總座位</th>
                            </tr>
                        </thead>
                        <tbody class="align-middle">
                            @if (Model.Session != null && Model.Session.Any())
                            {
                                @foreach (var sessions in Model.Session)
                                {
                                    @* 🚩 增加一個小標題行，標示這是哪一個場次的票區 *@
                                    <tr class="table-secondary">
                                        <td colspan="4" class="fw-bold">
                                            <i class="bi bi-clock-fill me-2"></i>
                                            場次：@sessions.StartTime.ToString("yyyy-MM-dd HH:mm")
                                        </td>
                                    </tr>

                                    @foreach (var area in sessions.TicketsArea)
                                    {
                                        <tr>
                                            <td class="ps-4">@area.TicketsAreaName</td>
                                            <td>
                                                @* 🚩 顯示場館名稱 (若 ViewData 有傳入名稱對照) *@
                                                <span class="badge bg-light text-dark border">
                                                    <i class="bi bi-geo-alt-fill me-1"></i>
                                                    @area.VenueID
                                                </span>
                                            </td>
                                            <td class="text-danger fw-bold">$@area.Price.ToString("N0")</td>
                                            <td>
                                                @((area.RowCount * area.SeatCount).ToString("N0")) <span class="small text-muted">(位)</span>
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">目前尚未設定任何場次或票區。</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="4" class="text-end fw-bold">該場次總計售票數：</td>
                                <td class="text-center fw-bold text-decoration-underline">
                                    @session.TicketsArea?.Sum(a => a.RowCount * a.SeatCount).ToString("N0")
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                }
            }
            else
            {
                <div class="p-5 text-center text-muted">
                    請回上一步確認場次設定。
                </div>
            }
        </div>
    </div>

    @* 3. 圖片預覽 *@
    @* 4. 已上傳圖片 *@
    <div class="card shadow-sm mb-5">
        <div class="card-header bg-secondary text-white"><h5>4. 已上傳圖片</h5></div>
        <div class="card-body">
            <div class="row g-2">
                @* 🚩 這裡加上 null 檢查 *@
                @if (Model.DescriptionImage != null && Model.DescriptionImage.Any())
                {
                    @foreach (var img in Model.DescriptionImage)
                    {
                        <div class="col-md-2 text-center">
                            @* 檢查 TempUrl 是否有值，否則顯示預設圖 *@
                            <img src="~/Photos/DescriptionImage/@img.DescriptionImageName"
                                 class="img-thumbnail" style="height: 100px; width: 100%; object-fit: cover;" />
                            <div class="small text-muted text-truncate">@img.DescriptionImageName</div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-4">
                        <p class="text-muted">（此活動未上傳描述圖片）</p>
                    </div>
                }
            </div>
        </div>
    </div>

    @* 最後提交表單 *@
    <form asp-action="CreateConfirm" method="post">
        <div class="d-flex justify-content-between align-items-center mb-5 border-top pt-4">
            <a asp-action="CreateStep4" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left"></i> 回上一步修改
            </a>

            <button type="submit" class="btn btn-success btn-lg px-5 shadow">
                <i class="bi bi-check-circle-fill me-2"></i> 確認無誤，正式發布
            </button>
        </div>
    </form>
</div>