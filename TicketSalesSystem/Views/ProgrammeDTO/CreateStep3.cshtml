@using TicketSalesSystem.ViewModel.Programme.CreateProgramme.CreateProgrammeStep
@model VMProgrammeStep3

@{
    ViewData["Title"] = "票區參數配置 / TICKET_AREA_CONFIG";
}

<link rel="stylesheet" href="~/css/Admin/Programme/Create/step3.css" asp-append-version="true" />


@* 🚩 核心樣板：保持隱藏，供 JS 複製場館數據 *@
<select id="venue-template" style="display:none;">
    <option value="">-- 請選擇區域 --</option>
    @if (ViewBag.RawVenues != null)
    {
        @foreach (var item in (List<TicketSalesSystem.Models.Venue>)ViewBag.RawVenues)
        {
            <option value="@item.VenueID"
                    data-max-row="@item.RowCount"
                    data-max-seat="@item.SeatCount">
                @item.VenueName (MAX: @(item.RowCount* item.SeatCount))
            </option>
        }
    }
</select>


<div class="admin-body p-4">
    @await Component.InvokeAsync("VCSteps", new { currentStep = 3 })

    <form asp-action="CreateStep3" id="step3Form">
        @Html.AntiForgeryToken()

        @* --- 標題區 --- *@
        <div class="d-flex justify-content-between align-items-center mb-5 tech-label border-bottom border-info border-opacity-25 pb-3">
            <h3 class="neon-text-sharp m-0">
                <i class="bi bi-geo-fill me-2"></i>步驟三: 票價與場地
            </h3>
            <div class="text-info small">[ 各票區可單獨指派場館區域 ]</div>
        </div>

        @for (int i = 0; i < Model.Session.Count; i++)
        {
            <div class="session-container cyber-card p-4 mb-5" data-session-index="@i">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-info border-opacity-10 pb-2">
                    <h5 class="text-white fw-bold m-0">
                        <i class="bi bi-calendar-check me-2 text-info"></i>
                        場次 @(i + 1)：<span class="neon-text-sharp" style="font-size: 1.1rem;">@Model.Session[i].StartTime.ToString("yyyy/MM/dd HH:mm")</span>
                    </h5>
                    <input type="hidden" asp-for="Session[i].SessionID" />
                    <input type="hidden" asp-for="Session[i].StartTime" />
                </div>

                <div class="table-responsive">
                    <table class="cyber-table align-middle area-table">
                        <thead>
                            <tr class="text-center">
                                <th style="width: 20%">場館區域</th>
                                <th style="width: 20%">票區名稱</th>
                                <th style="width: 12%">排數</th>
                                <th style="width: 12%">每排座位</th>
                                <th style="width: 12%">小計</th>
                                <th style="width: 16%">價格 (TWD)</th>
                                <th style="width: 8%">操作</th>
                            </tr>
                        </thead>
                        <tbody class="area-tbody">
                            @if (Model.Session[i].TicketsArea != null)
                            {
                                @for (int j = 0; j < Model.Session[i].TicketsArea.Count; j++)
                                {
                                    <tr class="area-row text-center">
                                        <td>
                                            <select asp-for="Session[i].TicketsArea[j].VenueID"
                                                    asp-items="@(ViewBag.VenueList as SelectList)"
                                                    class="form-select tech-input">
                                                <option value="">-- 請選擇 --</option>
                                            </select>
                                        </td>
                                        <td>
                                            <input name="Session[@i].TicketsArea[@j].TicketsAreaName" class="form-control tech-input" value="@Model.Session[i].TicketsArea[j].TicketsAreaName" required placeholder="如：搖滾A區" />
                                        </td>
                                        <td>
                                            <input asp-for="Session[i].TicketsArea[j].RowCount" type="number" class="form-control tech-input text-center row-count" min="1" />
                                        </td>
                                        <td>
                                            <input asp-for="Session[i].TicketsArea[j].SeatCount" type="number" class="form-control tech-input text-center seat-count" min="1" />
                                        </td>
                                        <td>
                                            <span class="total-seats neon-text-sharp text-info">0</span>
                                        </td>
                                        <td>
                                            <div class="input-group">
                                                <span class="input-group-text bg-transparent text-info border-info border-opacity-25">$</span>
                                                <input name="Session[@i].TicketsArea[@j].Price" type="number" class="form-control tech-input text-end" value="@Model.Session[i].TicketsArea[j].Price" min="0" />
                                            </div>
                                        </td>
                                        <td>
                                            <button type="button" class="bg-transparent border-0 text-danger remove-area" title="移除票區">
                                                <i class="bi bi-trash3-fill fs-4"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <button type="button" class="btn-cyber mt-3 add-area-btn" style="padding: 5px 15px; font-size: 0.9rem; border-width: 1px;">
                    <i class="bi bi-plus-circle me-1"></i>增加票區
                </button>
            </div>
        }

        @* --- 底部導覽 --- *@
        <div class="d-flex justify-content-between mt-5 pt-4 border-top border-info border-opacity-10">
            <a asp-action="CreateStep2" class="btn-cyber border-secondary text-secondary">
                <i class="bi bi-chevron-left me-2"></i>上一步 
            </a>
            <button type="submit" id="btnSubmit" class="btn-cyber">
                下一步：圖片上傳 <i class="bi bi-chevron-right ms-2"></i>
            </button>
        </div>
    </form>
</div>  



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {

            // 初始化
            $(".area-table select").each(function() { syncDataFromTemplate($(this)); });
            updateAllTotalsAndValidation();

            // 🚩 同步場館物理限制數據
            function syncDataFromTemplate($select) {
                const val = $select.val();
                if (!val) return;
                const $templateOpt = $(`#venue-template option[value="${val}"]`);
                const $currentOpt = $select.find("option:selected");
                $currentOpt.data("max-row", $templateOpt.data("max-row"));
                $currentOpt.data("max-seat", $templateOpt.data("max-seat"));
            }

            // 🚩 驗證單行邏輯 (加入紅色警戒樣式)
            function validateRow($row) {
                const $selectOpt = $row.find("select option:selected");
                const maxR = parseInt($selectOpt.data("max-row")) || 0;
                const maxS = parseInt($selectOpt.data("max-seat")) || 0;
                const currR = parseInt($row.find(".row-count").val()) || 0;
                const currS = parseInt($row.find(".seat-count").val()) || 0;

                const total = currR * currS;
                $row.find(".total-seats").text(total.toLocaleString());

                let errorMsg = "";
                if (maxR > 0 && currR > maxR) errorMsg = `排數上限溢出 (MAX: ${maxR})`;
                else if (maxS > 0 && currS > maxS) errorMsg = `座位上限溢出 (MAX: ${maxS})`;

                if (errorMsg !== "") {
                    $row.find(".tech-input").addClass("row-error");
                    if (!$row.find(".error-msg").length) {
                        $row.find("td:nth-child(5)").append(`<span class="error-msg">${errorMsg}</span>`);
                    } else {
                        $row.find(".error-msg").text(errorMsg);
                    }
                } else {
                    $row.find(".tech-input").removeClass("row-error");
                    $row.find(".error-msg").remove();
                }
                checkFormValidity();
            }

            function checkFormValidity() {
                const hasError = $(".row-error").length > 0;
                $('#btnSubmit').prop("disabled", hasError);
            }

            function updateAllTotalsAndValidation() {
                $(".area-row").each(function () { validateRow($(this)); });
            }

            // 事件監聽
            $(document).on("input change", ".row-count, .seat-count, .area-table select", function () {
                const $row = $(this).closest("tr");
                if ($(this).is("select")) syncDataFromTemplate($(this));
                validateRow($row);
            });

            // 增加票區 (JS 模板同步套用 tech-input)
            $(document).on("click", ".add-area-btn", function () {
                const container = $(this).closest(".session-container");
                const sIdx = container.data("session-index");
                const tbody = container.find(".area-tbody");
                const tIdx = tbody.find(".area-row").length;
                const venueOptions = $('#venue-template').html();

                const newRow = `
                    <tr class="area-row text-center">
                        <td><select name="Session[${sIdx}].TicketsArea[${tIdx}].VenueID" class="form-select tech-input" required>${venueOptions}</select></td>
                        <td><input name="Session[${sIdx}].TicketsArea[${tIdx}].TicketsAreaName" class="form-control tech-input" placeholder="區塊名稱" required /></td>
                        <td><input name="Session[${sIdx}].TicketsArea[${tIdx}].RowCount" type="number" class="form-control tech-input text-center row-count" value="1" min="1" /></td>
                        <td><input name="Session[${sIdx}].TicketsArea[${tIdx}].SeatCount" type="number" class="form-control tech-input text-center seat-count" value="1" min="1" /></td>
                        <td><span class="total-seats neon-text-sharp text-info">1</span></td>
                        <td>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent text-info border-info border-opacity-25">$</span>
                                <input name="Session[${sIdx}].TicketsArea[${tIdx}].Price" type="number" class="form-control tech-input text-end" value="0" min="0" />
                            </div>
                        </td>
                        <td><button type="button" class="bg-transparent border-0 text-danger remove-area"><i class="bi bi-trash3-fill fs-4"></i></button></td>
                    </tr>`;

                const $newRow = $(newRow).hide();
                tbody.append($newRow);
                $newRow.fadeIn(300);
                validateRow($newRow);
            });

            $(document).on("click", ".remove-area", function () {
                const row = $(this).closest("tr");
                row.fadeOut(300, function () {
                    row.remove();
                    checkFormValidity();
                });
            });
        });
    </script>
}