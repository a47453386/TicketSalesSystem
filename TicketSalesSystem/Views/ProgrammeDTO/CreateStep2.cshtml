@model TicketSalesSystem.ViewModel.CreateProgramme.CreateProgrammeStep.VMProgrammeStep2

@await Component.InvokeAsync("VCSteps", new { currentStep = 2 })

<div class="container mt-4">
    <form asp-action="CreateStep2" method="post" id="sessionForm">
       
        @* 🚩 務必加入這個隱藏欄位 *@
        <input type="hidden" asp-for="PlaceID"  />
       
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">場次設定</h5>
                <button type="button" class="btn btn-light btn-sm" id="btnAddSession">
                    <i class="bi bi-plus-circle"></i> 新增一場
                </button>
            </div>
            <div class="card-body">
                <div id="sessionContainer">
                    @* 這裡預留給 JS 動態產生，或是顯示已有的資料 *@
                    @for (int i = 0; i < Model.Sessions.Count; i++)
                    {
                        <div class="session-item border p-3 mb-3 position-relative">
                            <h6>場次 #<span class="row-number">@(i + 1)</span></h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label">活動開始時間</label>
                                    <input asp-for="Sessions[i].StartTime" class="form-control" type="datetime-local" />
                                    <span asp-validation-for="Sessions[i].StartTime" class="text-danger"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">啟售時間</label>
                                    <input asp-for="Sessions[i].SaleStartTime" class="form-control" type="datetime-local" />
                                    <span asp-validation-for="Sessions[i].SaleStartTime" class="text-danger"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">截止銷售時間</label>
                                    <input asp-for="Sessions[i].SaleEndTime" class="form-control" type="datetime-local" />
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        
        <div class="d-flex justify-content-between mt-4">
            <a asp-action="CreateStep1" class="btn btn-secondary px-4">上一步</a>
            <button type="submit" class="btn btn-primary px-5">下一步：票區設定</button>
        </div>
    </form>
    <div asp-validation-summary="All" class="text-danger"></div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }


    <script>
        let sessionIndex = @Model.Sessions.Count; // 從現有的筆數開始算

        document.getElementById('btnAddSession').addEventListener('click', function () {
            const container = document.getElementById('sessionContainer');

            // 建立新的場次 HTML 字串
            const html = `
                <div class="session-item border p-3 mb-3 position-relative shadow-sm bg-light">
                    <button type="button" class="btn-close position-absolute top-0 end-0 m-2 remove-session"></button>
                    <h6>場次 #<span class="row-number">${sessionIndex + 1}</span></h6>
                    <div class="row g-3">
                               <div class="col-md-4">
                                <label class="form-label">活動開始時間</label>
                                <input name="Sessions[${sessionIndex}].StartTime" class="form-control" type="datetime-local" required />
                                @* JS 動態產生的部分，雖然 asp-validation-for 不能直接用，但可以手動留一個 span *@
                                <span class="field-validation-valid text-danger" data-valmsg-for="Sessions[${sessionIndex}].StartTime" data-valmsg-replace="true"></span>
                            </div>
        <div class="col-md-4">
                <label class="form-label">啟售時間</label>
                <input name="Sessions[${sessionIndex}].SaleStartTime" class="form-control" type="datetime-local" required />
                <span class="field-validation-valid text-danger" data-valmsg-for="Sessions[${sessionIndex}].SaleStartTime" data-valmsg-replace="true"></span> </div>
                        <div class="col-md-4">
                            <label class="form-label">截止銷售時間</label>
                            <input name="Sessions[${sessionIndex}].SaleEndTime" class="form-control" type="datetime-local" required />
                        </div>
                    </div>
                </div>
            `;

            container.insertAdjacentHTML('beforeend', html);
            sessionIndex++;
                    const form = document.getElementById('sessionForm');
        $(form).removeData("validator").removeData("unobtrusiveValidation");
        $.validator.unobtrusive.parse(form);
        });

        // 處理刪除功能
        document.addEventListener('click', function (e) {
            if (e.target.classList.contains('remove-session')) {
                e.target.closest('.session-item').remove();
                reIndexSessions();
            }
        });

        // 重新排序索引 (防止中間刪掉一筆導致斷號)
        function reIndexSessions() {
            const items = document.querySelectorAll('.session-item');
            sessionIndex = 0;
            items.forEach((item, index) => {
                item.querySelector('.row-number').innerText = index + 1;
                item.querySelectorAll('input').forEach(input => {
                    const name = input.getAttribute('name');
                    if (name) {
                        // 取代中間的數字，例如 Sessions[2].StartTime -> Sessions[0].StartTime
                        input.setAttribute('name', name.replace(/\[\d+\]/, `[${index}]`));
                    }
                });
                sessionIndex++;
            });
        }
    </script>
}







