@model IEnumerable<TicketSalesSystem.Models.Question>

@{
    ViewData["Title"] = "客服管理中心";
}
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Index.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Question/QuestionIndex.css" asp-append-version="true" />
<div class="admin-body p-4">

    @* --- [1. 頂部標頭：HUD 儀表板風格] --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-info border-opacity-25 pb-3">
        <div>
            <h1 class="neon-header m-0">
                <i class="bi bi-patch-question me-3"></i>@ViewData["Title"]
            </h1>
        </div>
        <div>
            <button type="button" class="btn-cyber" data-bs-toggle="modal" data-bs-target="#typeManagerModal">
                <i class="bi bi-tags me-2"></i>種類名稱管理
            </button>
        </div>
    </div>

    @* --- [2. 數據網格卡片：Cyber-Card] --- *@
    <div class="cyber-card p-4">
        <div class="table-responsive custom-scroll">
            <table class="table cyber-table align-middle">
                <thead>
                    <tr class="text-center">
                        @* 1. 時間 (12%) *@
                        <th style="width: 12%;" class="pt-4 ps-4">
                            <div class="tech-key1">時間</div>
                        </th>
                        @* 2. 會員 (15%) *@
                        <th style="width: 15%;" class="pt-4">
                            <div class="tech-key1">會員</div>
                        </th>
                        @* 3. 分類 (10%) *@
                        <th style="width: 10%;" class="pt-4">
                            <div class="tech-key1">分類</div>
                        </th>
                        @* 4. 標題 (28%) - 這裡需要較寬空間 *@
                        <th style="width: 25%;" class="pt-4">
                            <div class="tech-key1">標題</div>
                        </th>
                        @* 5. 附件 (5%) *@
                        <th style="width: 10%;" class="pt-4">
                            <div class="tech-key1">附件</div>
                        </th>
                        @* 6. 狀態 (15%) *@
                        <th style="width: 15%;" class="pt-4">
                            <div class="tech-key1">狀態</div>
                        </th>
                        @* 7. 操作 (15%) *@
                        <th style="width: 15%;" class="pe-4 pt-4">
                            <div class="tech-key1">操作</div>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="text-center">
                            @* 提問時間 *@
                            <td class="font-monospace text-info">
                                @item.CreatedTime.ToString("yyyy.MM.dd")<br />
                                <small class="opacity-100">@item.CreatedTime.ToString("HH:mm")</small>
                            </td>

                            @* 會員 *@
                            <td>
                                <div class="fw-bold">@item.Member?.Name</div>
                                <div class="small font-monospace text-info opacity-100">#@item.MemberID</div>
                            </td>

                            @* 分類 *@
                            <td>
                                <span class="badge border border-info text-info bg-dark bg-opacity-50 px-3">
                                    @item.QuestionType?.QuestionTypeName
                                </span>
                            </td>

                            @* 標題 *@
                            <td>
                                <div class="text-truncate" style="max-width: 250px; color: #fff;">
                                    <strong>@item.QuestionTitle</strong>
                                </div>
                            </td>

                            @* 附件 *@
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.UploadFile))
                                {
                                    <i class="bi bi-file-earmark-pdf-fill text-danger fs-5" title="FILE_DETECTED"></i>
                                }
                                else
                                {
                                    <span class="opacity-25">-</span>
                                }
                            </td>

                            @* 狀態判定邏輯 *@
                            <td>
                                @{
                                    var latestReply = item.Reply?.OrderByDescending(r => r.CreatedTime).FirstOrDefault();
                                    if (latestReply == null)
                                    {
                                        <div class="status-badge status-badge-pending">
                                            <i class="bi bi- exclamation-circle me-2"></i> 待處理
                                        </div>
                                    }
                                    else if (latestReply.ReplyStatusID == "Y")
                                    {
                                        <div class="status-badge">
                                            <i class="bi bi-check-circle me-2"></i> 已結案
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="status-badge status-badge-processing">
                                            <i class="bi bi-hourglass-split me-2"></i> 處理中
                                        </div>
                                    }
                                }
                            </td>

                            @* 操作 *@
                            <td>
                                <a asp-action="Details" asp-route-id="@item.QuestionID" class="btn-cyber py-1">
                                    <i class="bi bi-chat-dots-fill me-2"></i>回覆
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* --- [3. 分類管理 Modal - 賽博化改造] --- *@
<div class="modal fade" id="typeManagerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content cyber-card" style="clip-path: none; background: #000b1a !important;">
            <div class="modal-header border-info border-opacity-25">
                <h5 class="text-info font-monospace m-0">問題名稱管理</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" id="typeManagerContent">
                <div class="text-center py-5">
                    <div class="spinner-border text-info" role="status"></div>
                    <p class="mt-3 font-monospace opacity-50">DECRYPTING_DATA...</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
          $(document).ready(function () {
            console.log("INQUIRY_TERMINAL_ONLINE");

            // Modal 顯示時抓資料
            $('#typeManagerModal').on('show.bs.modal', function () {
                refreshTypeList();
            });
        });

        function refreshTypeList() {
            var targetUrl = "@Url.Action("GetPartialList", "QuestionTypes")";
            $("#typeManagerContent").load(targetUrl, function(response, status, xhr) {
                if (status == "error") {
                    alert("PROTOCOL_ERR: 連線失敗，請檢查伺服器狀態。");
                }
            });
        }

        // 新增分類
        function addNewType() {
            var name = $("#newTypeName").val();
            if (!name) return alert("INPUT_ERR: 請輸入分類名稱");

            $.post("@Url.Action("QuickCreate", "QuestionTypes")", { name: name }, function (data) {
                if (data.success) {
                    $("#newTypeName").val("");
                    refreshTypeList();
                } else {
                    alert("ERROR: " + data.message);
                }
            });
        }

        // 修改分類名稱
        function editType(id, oldName) {
            var newName = prompt("請輸入新的分類名稱：", oldName);
            if (newName && newName !== oldName) {
                $.post("@Url.Action("Edit", "QuestionTypes")", { id: id, name:newName  }, function(data) {
                    if (data.success) refreshTypeList();
                    else alert("修改失敗");
                });
            }
        }

        // 刪除分類 (如果沒設狀態欄位，就直接刪除)
        function deleteType(id) {
            if (confirm("確定要刪除此分類嗎？（若已有諮詢使用此分類將無法刪除）")) {
                // 這裡對應你 Controller 內建的 DeleteConfirmed 或自訂一個 AjaxDelete
                $.post("/QuestionTypes/Delete", { id: id }, function(data) {
                    if (data.success) refreshTypeList();
                    else alert("刪除失敗，可能已有資料關聯。");
                });
            }
        }


    </script>
}
