@model TicketSalesSystem.Models.Question

@{
    ViewData["Title"] = "問題回覆";
}
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Question/QuestionDetail.css" asp-append-version="true" />



<div class="admin-body p-4">

    @* --- [1. 頂部導覽：戰術路徑] --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-info border-opacity-25 pb-3">
        <div>
            @* <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb m-0 p-0 bg-transparent font-monospace">
                    <li class="breadcrumb-item"><a asp-action="MyList" class="text-info text-decoration-none opacity-50">INQUIRY_LIST</a></li>
                    <li class="breadcrumb-item active text-white">STREAM_#@Model.QuestionID</li>
                </ol>
            </nav> *@
            <h1 class="neon-header m-0"><i class="bi bi-send-check-fill"></i>@ViewData["Title"] </h1>
        </div>
        <a asp-controller="Questions" asp-action="Index" class="btn-cyber px-4">
            <i class="bi bi-arrow-left me-2"></i>回清單
        </a>
    </div>

    <div class="row g-4">
        @* --- [2. 左側：提問原始數據紀錄] --- *@
        <div class="col-lg-4">
            <div class="cyber-card p-4 h-100">
                <div class="tech-key mb-4">問題資訊</div>

                <div class="mb-4">
                    <span class="meta-label">問題種類</span>
                    <div class="mt-1">
                        <span class="badge border border-info text-info bg-dark">@Model.QuestionType?.QuestionTypeName</span>
                    </div>
                </div>

                <div class="mb-4">
                    <span class="meta-label">發問時間</span>
                    <div class="mt-1 text-white font-monospace">@Model.CreatedTime.ToString("yyyy-MM-dd HH:mm")</div>
                </div>

                <hr class="border-info opacity-10 my-4" />

                <div class="mb-4">
                    <span class="meta-label">主旨</span>
                    <h4 class="text-white fw-bold mt-2">@Model.QuestionTitle</h4>
                </div>

                <div class="mb-4">
                    <span class="meta-label">詳細內容</span>
                    <p class="text-white-50 mt-2" style="white-space: pre-wrap; line-height: 1.6;">@Model.QuestionDescription</p>
                </div>

                @if (!string.IsNullOrEmpty(Model.UploadFile))
                {
                    <div class="mt-4 p-3 border border-info border-opacity-20 bg-dark bg-opacity-50">
                        <span class="meta-label d-block mb-2"><i class="bi bi-paperclip"></i> 附件</span>
                        <a href="~/Docs/Questions/@Model.UploadFile" target="_blank" class="btn-cyber btn-sm w-100 justify-content-center">
                            查看附件
                        </a>
                    </div>
                }
            </div>
        </div>

        @* --- [3. 右側：回覆對話流與指令發送] --- *@
        <div class="col-lg-8">
            <div class="cyber-card d-flex flex-column h-100">
                <div class="p-4 border-bottom border-info border-opacity-10 d-flex justify-content-between align-items-center">
                    <div class="tech-key m-0" style="font-size: 1rem !important;">回覆紀錄</div>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <span class="status-badge">✓ @TempData["SuccessMessage"]</span>
                    }
                </div>

                @* 對話紀錄區 *@
                <div class="card-body chat-container custom-scroll flex-grow-1" style="max-height: 400px; overflow-y: auto;">
                    @if (Model.Reply != null && Model.Reply.Any())
                    {
                        @foreach (var reply in Model.Reply)
                        {
                            <div class="reply-bubble">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-info fw-bold font-monospace">@@回覆人: @reply.Employee.Name</span>
                                    <small class="text-white-50 font-monospace">@reply.CreatedTime</small>
                                </div>
                                <p class="text-white mb-0 opacity-75">@reply.ReplyDescription</p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5 opacity-25">
                            <i class="bi bi-chat-square-dots fs-1"></i>
                            <p class="mt-2 font-monospace">沒有紀錄</p>
                        </div>
                    }
                </div>

                @* 管理員回覆指令區 *@
                <div class="p-4 border-top border-info border-opacity-10 bg-dark bg-opacity-30">
                    <form asp-controller="Reply" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="questionId" value="@Model.QuestionID" />

                        <div class="row g-3">
                            <div class="col-md-8">
                                <div class="tech-key mb-2" style="font-size: 0.8rem !important;">回覆內容</div>
                                <textarea name="replyDescription" class="form-control order-input custom-scroll" rows="4"
                                          placeholder="請輸入內容..." required></textarea>
                            </div>
                            <div class="col-md-4 d-flex flex-column justify-content-between">
                                <div>
                                    <div class="tech-key mb-2" style="font-size: 0.8rem !important;">處理進度</div>
                                    <select name="replyStatusId" class="form-select order-input mb-3" asp-items="ViewBag.ReplyStatusID" required>
                                        <option value="">-- 請選擇 --</option>
                                    </select>
                                </div>

                                <button type="submit" class="btn-cyber w-100 py-3 justify-content-center">
                                    <i class="bi bi-send-fill me-2"></i>發送
                                </button>
                            </div>
                        </div>

                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="text-danger small mt-2 font-monospace">ALERT: @TempData["ErrorMessage"]</div>
                        }
                    </form>
                </div>

                @* 底部安全性提示 *@
                <div class="p-2 border-top border-warning border-opacity-10 text-center">
                    <span class="meta-label" style="font-size: 0.65rem;">
                        <i class="bi bi-shield-lock"></i> 一旦回覆無法刪除
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>