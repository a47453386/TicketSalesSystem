@model TicketSalesSystem.Models.Question

@{
    ViewData["Title"] = "諮詢詳情";
}

<div class="container py-4">
    @* 頂部導覽 *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="MyList">我的諮詢</a></li>
                <li class="breadcrumb-item active">問題詳情</li>
            </ol>
        </nav>
        <a asp-action="MyList" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> 返回列表
        </a>
    </div>

    <div class="row">
        @* 左側：原始問題內容 *@
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">提問資訊</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-muted d-block">問題類型</small>
                        <span class="badge bg-info text-dark">@Model.QuestionType?.QuestionTypeName</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">提問時間</small>
                        <span class="fw-bold">@Model.CreatedTime.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    <hr />
                    <h5 class="fw-bold text-primary">@Model.QuestionTitle</h5>
                    <p class="text-dark" style="white-space: pre-wrap;">@Model.QuestionDescription</p>

                    @if (!string.IsNullOrEmpty(Model.UploadFile))
                    {
                        <div class="mt-3 p-2 bg-light rounded border">
                            <small class="d-block text-muted mb-1"><i class="bi bi-paperclip"></i> 附件檔案</small>
                            <a href="~/Docs/Questions/@Model.UploadFile" target="_blank" class="text-decoration-none small">查看上傳附件</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* 右側：回覆對話紀錄 *@
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0"><i class="bi bi-chat-left-dots me-2"></i>回覆紀錄</h5>
                    @* 顯示 TempData 訊息 *@
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <span class="badge bg-success">@TempData["SuccessMessage"]</span>
                    }
                </div>

                <div class="card-body bg-light" style="max-height: 500px; overflow-y: auto;">
                    @if (Model.Reply != null && Model.Reply.Any())
                    {
                        @foreach (var reply in Model.Reply)
                        {
                            <div class="mb-3 p-2 bg-white rounded shadow-sm">
                                <strong>客服人員 @reply.Employee.Name</strong>
                                <small class="text-muted">@reply.CreatedTime</small>
                                <p class="mb-0">@reply.ReplyDescription</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">目前尚無回覆紀錄</p>
                    }
                </div>

                @* 🚩 新增：管理員回覆區塊 *@
                <div class="card-footer bg-white border-top-0 py-3">
                    <form asp-controller="Reply" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="questionId" value="@Model.QuestionID" />

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-primary">撰寫管理員回覆</label>
                            <textarea name="replyDescription" class="form-control" rows="4"
                                      placeholder="請輸入回覆內容..." required></textarea>
                            @if (TempData["ErrorMessage"] != null)
                            {
                                <div class="text-danger small mt-1">@TempData["ErrorMessage"]</div>
                            }
                            <div class="mb-3">
                                <label class="form-label small fw-bold">目前處理進度</label>
                                <select name="replyStatusId" class="form-select form-select-sm" asp-items="ViewBag.ReplyStatusID">
                                        <option>請選擇處理進度</option>
                                </select>
                               
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-send-fill me-1"></i> 送出回覆
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-white py-2">
                    <p class="small text-muted mb-0 text-center">
                        <i class="bi bi-shield-check"></i> 此回覆將即時同步給提問會員。
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-light {
        background-color: #f8f9fa !important;
    }

    .transition-hover:hover {
        transform: translateY(-5px);
        transition: 0.3s;
    }
</style>