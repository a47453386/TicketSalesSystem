@model TicketSalesSystem.Models.Question

@{
    ViewData["Title"] = "諮詢詳情";
}

<div class="container py-4">
    @* 頂部導覽 *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="MyList">我的諮詢</a></li>
                <li class="breadcrumb-item active">問題詳情</li>
            </ol>
        </nav>
        <a asp-action="MyList" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> 返回列表
        </a>
    </div>

    <div class="row">
        @* 左側：原始問題內容 *@
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">提問資訊</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-muted d-block">問題類型</small>
                        <span class="badge bg-info text-dark">@Model.QuestionType?.QuestionTypeName</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">提問時間</small>
                        <span class="fw-bold">@Model.CreatedTime.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    <hr />
                    <h5 class="fw-bold text-primary">@Model.QuestionTitle</h5>
                    <p class="text-dark" style="white-space: pre-wrap;">@Model.QuestionDescription</p>

                    @if (!string.IsNullOrEmpty(Model.UploadFile))
                    {
                        <div class="mt-3 p-2 bg-light rounded border">
                            <small class="d-block text-muted mb-1"><i class="bi bi-paperclip"></i> 附件檔案</small>
                            <a href="~/uploads/@Model.UploadFile" target="_blank" class="text-decoration-none small">查看上傳附件</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* 右側：回覆對話紀錄 *@
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0"><i class="bi bi-chat-left-dots me-2"></i>回覆紀錄</h5>
                </div>
                <div class="card-body bg-light" style="max-height: 600px; overflow-y: auto;">
                    @if (Model.Reply == null || !Model.Reply.Any())
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary mb-3" role="status"></div>
                            <p class="text-muted">客服人員正在準備回覆中，請稍候...</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var reply in Model.Reply)
                        {
                            <div class="mb-4 d-flex flex-column align-items-start">
                                <div class="d-flex align-items-center mb-1">
                                    <span class="fw-bold me-2 text-primary">客服人員 @reply.Employee?.EmployeeID</span>
                                    <small class="text-muted">@reply.CreatedTime.ToString("yyyy-MM-dd HH:mm")</small>
                                    <span class="badge bg-success ms-2 small">@reply.ReplyStatus?.ReplyStatusName</span>
                                </div>
                                <div class="bg-white p-3 rounded shadow-sm border-start border-4 border-success" style="max-width: 90%; white-space: pre-wrap;">
                                    @reply.ReplyDescription
                                </div>
                                @if (!string.IsNullOrEmpty(reply.Note))
                                {
                                    <small class="text-muted mt-1 italic">備註：@reply.Note</small>
                                }
                            </div>
                        }
                    }
                </div>
                @* 如果消費者可以追問，可以在這裡加一個簡易表單（非必要） *@
                <div class="card-footer bg-white py-3">
                    <p class="small text-muted mb-0 text-center">
                        <i class="bi bi-info-circle"></i> 若對回覆內容有疑問，請撥打客服專線 0800-xxx-xxx。
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-light {
        background-color: #f8f9fa !important;
    }

    .transition-hover:hover {
        transform: translateY(-5px);
        transition: 0.3s;
    }
</style>