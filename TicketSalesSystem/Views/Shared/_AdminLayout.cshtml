<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketSalesSystem後台管理</title>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TicketSalesSystem.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/admin-cyber.css" asp-append-version="true" />
    
</head>
<body class="admin-body">
    <div class="d-flex">
        <div class="sidebar d-flex flex-column p-3 flex-shrink-0">
            <h4 class="text-center mb-4 fw-bold mt-2">
                <i class="bi bi-cpu-fill me-2"></i>售票系統後台管理
            </h4>

            <ul class="nav nav-pills flex-column mb-auto admin-nav">
                <li class="nav-item nav-item-tech">
                    <a asp-controller="Admin" asp-action="Dashboard"
                       class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-terminal-fill me-2"></i> 控制面板
                    </a>
                </li>

                <li class="nav-item nav-item-tech">
                    <a asp-controller="Places" asp-action="Index" class="nav-link">
                        <i class="bi bi-geo-fill me-2"></i> 場地座標管理
                    </a>
                </li>

                <li class="nav-item nav-item-tech">
                    <a asp-controller="Programmes" asp-action="AdminIndex"
                       class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "AdminIndex" ? "active" : "")">
                        <i class="bi bi-broadcast-pin me-2"></i> 任務/活動排程
                    </a>
                </li>

                <li class="nav-item nav-item-tech">
                    <a asp-controller="Orders" asp-action="Index" class="nav-link">
                        <i class="bi bi-database-fill-check me-2"></i> 交易數據串流
                    </a>
                </li>

                <li class="nav-item nav-item-tech">
                    <a asp-controller="Members" asp-action="Index" class="nav-link">
                        <i class="bi bi-person-bounding-box me-2"></i> 人員名錄管理
                    </a>
                </li>

                <li class="nav-item nav-item-tech">
                    <a asp-controller="Employees" asp-action="Index" class="nav-link">
                        <i class="bi bi-fingerprint me-2"></i> 權限等級授權
                    </a>
                </li>

                <li class="nav-item nav-item-tech">
                    <a asp-controller="PublicNotices" asp-action="Index" class="nav-link">
                        <i class="bi bi-reception-4 me-2"></i> 系統通訊發佈
                    </a>
                </li>

                <li class="nav-item nav-item-tech">
                    <a asp-controller="FAQs" asp-action="Index" class="nav-link">
                        <i class="bi bi-cpu me-2"></i> 邏輯數據查詢
                    </a>
                </li>

                <li class="nav-item nav-item-tech">
                    <a asp-controller="Questions" asp-action="Index" class="nav-link">
                        <i class="bi bi-headset-vr me-2"></i> 客戶支援終端
                    </a>
                </li>
            </ul>

            <hr class="border-cyan">

            <div class="dropdown">
                <a href="#" class="d-flex align-items-center text-cyan text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle fs-4 me-2"></i>
                    <strong class="neon-text">@User.Identity.Name</strong>
                </a>
                <ul class="dropdown-menu dropdown-menu-dark shadow border-info">
                    <li><a class="dropdown-item" href="/"><i class="bi bi-house me-2"></i>回前台</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item text-danger" asp-controller="Login" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-2"></i>安全登出
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="main-wrapper">
            <header class="shadow-sm py-2 px-4 d-flex justify-content-between align-items-center">
                <div class="small text-cyan">
                    <i class="bi bi-terminal me-2"></i>
                    CORE_STATUS: <span class="text-success fw-bold">STABLE</span>
                    <span class="ms-3 text-muted">|</span>
                    <span class="ms-3">UPTIME: 99.9%</span>
                </div>
                <div class="d-flex align-items-center">
                    <a href="/" class="btn btn-sm btn-outline-cyan px-3">
                        <i class="bi bi-display me-1"></i> 前台預覽
                    </a>
                </div>
            </header>

            <main role="main" class="p-4 flex-grow-1">
                @RenderBody()
            </main>

            <footer class="py-2 px-4 d-flex justify-content-between align-items-center">
                <div class="small">
                    &copy; 2026 - <span class="neon-text">TICKET_SALES_KERNEL</span> v2.4.0
                </div>
                <div class="small">
                    <i class="bi bi-shield-check me-1"></i> SSL_ENCRYPTED: AES-256
                    <span class="ms-3 text-cyan">
                        <i class="bi bi-clock me-1"></i> @DateTime.Now.ToString("HH:mm:ss")
                    </span>
                </div>
            </footer>
        </div>
    </div>

    <div id="antiforgery-token-holder" style="display:none;">
        @Html.AntiForgeryToken()
    </div>



    <!-- 漂亮的彈窗 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @* <script src="~/lib/jquery/dist/jquery.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    @* <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/admin-common.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
