<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketSalesSystem後台管理</title>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TicketSalesSystem.styles.css" asp-append-version="true" />

    <style>
        /* 側邊欄樣式優化 */
        .sidebar .nav-link {
            color: #adb5bd !important;
            transition: 0.2s;
        }

            .sidebar .nav-link:hover {
                background-color: rgba(255, 255, 255, 0.1);
                color: white !important;
            }

            .sidebar .nav-link.active {
                background-color: #0d6efd !important;
                color: white !important;
            }

        .flex-grow-1 {
            min-height: 100vh;
        }
        /* 確保全螢幕高度 */
        body, html {
            height: 100%;
            margin: 0;
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <div class="sidebar d-flex flex-column p-3 flex-shrink-0" style="width: 280px; background-color: #2c3e50; min-height: 100vh;">
            <h4 class="text-center mb-4 fw-bold text-white">@ViewData["Title"]</h4>
            <ul class="nav nav-pills flex-column mb-auto admin-nav">
                <li class="nav-item mb-1">
                    <a asp-controller="Admin" asp-action="Dashboard" class="nav-link text-white @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-speedometer2 me-2"></i> 控制面板
                    </a>
                </li>
                <li class="nav-item mb-1">
                    <a asp-controller="Programmes" asp-action="AdminIndex" class="nav-link text-white @(ViewContext.RouteData.Values["Action"]?.ToString() == "AdminIndex" ? "active" : "")">
                        <i class="bi bi-music-note-beamed me-2"></i> 活動管理
                    </a>
                </li>
                <li class="nav-item mb-1">
                    <a asp-controller="Orders" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-receipt me-2"></i> 訂單管理
                    </a>
                </li>
                <li class="nav-item mb-1">
                    <a asp-controller="Members" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-people me-2"></i> 會員管理
                    </a>
                </li>
                <li class="nav-item mb-1">
                    <a asp-controller="Employees" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-person-badge me-2"></i> 員工管理
                    </a>
                </li>
                <li class="nav-item mb-1">
                    <a asp-controller="PublicNotices" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-megaphone me-2"></i> 公告管理
                    </a>
                </li>
                <li class="nav-item mb-1">
                    <a asp-controller="PublicNotices" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-megaphone me-2"></i> 常見問題管理
                    </a>
                </li>
                <li class="nav-item mb-1">
                    <a asp-controller="FAOs" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-question-circle me-2"></i> 諮詢管理
                    </a>
                </li>
            </ul>
            <hr class="text-white-50">
            <div class="dropdown">
                <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
                    <strong>Admin User</strong>
                </a>
            </div>
        </div>

        <div class="flex-grow-1 bg-light">
            <header class="bg-white shadow-sm py-2 px-4 d-flex justify-content-end mb-4">
                <a href="/" class="btn btn-sm btn-outline-secondary">回前台首頁</a>
            </header>

            <main role="main" class="px-4 pb-5">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </main>

            <footer class="mt-auto py-3 border-top bg-white px-4">
                <div class="container-fluid d-flex justify-content-between text-muted small">
                    <span>&copy; 2026 - TicketSalesSystem</span>
                    <nav>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none me-3">隱私權政策</a>
                        <a href="#" class="text-decoration-none">服務條款</a>
                    </nav>
                </div>
            </footer>
        </div>

        
    </div>



    @* <script src="~/lib/jquery/dist/jquery.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    @* <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
