@using System.Security.Claims
@{
    // 優先從 Claim 抓，抓不到再從 ViewBag (當作備援)
    var currentEmpId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketSalesSystem後台管理</title>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TicketSalesSystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-cyber.css" asp-append-version="true" />  
</head>
<body class="admin-body">
    <div class="d-flex min-height: 100vh; overflow-x: hidden;">
        <div class="sidebar d-flex flex-column p-3 flex-shrink-0">
            <h4 class="text-center mb-4 fw-bold mt-2">
                <i class="bi bi-cpu-fill me-2"></i>售票系統後台管理
            </h4>

            <ul class="nav nav-pills flex-column mb-auto admin-nav">
                @* 1. 控制面板 *@
                <li class="nav-item nav-item-tech">
                    <a asp-controller="Admin" asp-action="Dashboard"
                       class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-terminal-fill me-2"></i> 控制面板
                    </a>
                </li>

                @* 2. 場地管理 *@
                <li class="nav-item nav-item-tech">
                    <a asp-controller="Places" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Places" ? "active" : "")">
                        <i class="bi bi-geo-fill me-2"></i> 場地管理
                    </a>
                </li>

                @* 3. 活動管理 *@
                <li class="nav-item nav-item-tech">
                    <a asp-controller="Programmes" asp-action="AdminIndex"
                       class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Programmes" ? "active" : "")">
                        <i class="bi bi-broadcast-pin me-2"></i> 活動管理
                    </a>
                </li>

                @* 4. 訂單管理 *@
                <li class="nav-item nav-item-tech">
                    <a asp-controller="Orders" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Orders" ? "active" : "")">
                        <i class="bi bi-database-fill-check me-2"></i> 訂單管理
                    </a>
                </li>

                @* 5. 會員管理 *@
                <li class="nav-item nav-item-tech">
                    <a asp-controller="Members" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Members" ? "active" : "")">
                        <i class="bi bi-person-bounding-box me-2"></i> 會員管理
                    </a>
                </li>

                @* 6. 員工管理 *@
                <li class="nav-item nav-item-tech">
                    <a asp-controller="Employees" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Employees" ? "active" : "")">
                        <i class="bi bi-fingerprint me-2"></i> 員工管理
                    </a>
                </li>

                @* 7. 公告管理 *@
                <li class="nav-item nav-item-tech">
                    <a asp-controller="PublicNotices" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PublicNotices" ? "active" : "")">
                        <i class="bi bi-reception-4 me-2"></i> 公告管理
                    </a>
                </li>

                @* 8. 常見問題管理 *@
                <li class="nav-item nav-item-tech">
                    <a asp-controller="FAQs" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "FAQs" ? "active" : "")">
                        <i class="bi bi-cpu me-2"></i> 常見問題管理
                    </a>
                </li>

                @* 9. 客服管理 *@
                <li class="nav-item nav-item-tech">
                    <a asp-controller="Questions" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Questions" ? "active" : "")">
                        <i class="bi bi-headset-vr me-2"></i> 客服管理
                    </a>
                </li>
                @* 10.票券管理 *@
                <li class="nav-item nav-item-tech">
                    <a asp-controller="Tickets" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Questions" ? "active" : "")">
                        <i class="bi bi-headset-vr me-2"></i> 票券管理
                    </a>
                </li>
            </ul>

            <hr class="border-cyan">

            <div class="dropdown">
                <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle px-3 py-1" data-bs-toggle="dropdown">

                    @if (User.Identity.IsAuthenticated && !string.IsNullOrEmpty(currentEmpId))
                    {
                        <img src="@Url.Content("~/Photos/employeePhotos/" + currentEmpId + ".jpg")"
                             class="user-avatar-tech me-2"
                             alt="User Avatar"
                             style="width:38px; height:38px; object-fit:cover; border-radius:50%; border:2px solid var(--tech-cyan);"
                             onerror="this.onerror=null; this.src='/Photos/employeePhotos/default-tech-user.png';" />
                    }
                    else
                    {
                        <i class="bi bi-person-circle fs-4 me-2 text-pixel-blue"></i>
                    }

                    <strong class="neon-text-sharp">@User.Identity.Name</strong>

                </a>
                <ul class="dropdown-menu dropdown-menu-dark shadow border-info">
                    <li><a asp-controller="Home" asp-action="Index" class="dropdown-item"><i class="bi bi-house me-2"></i>回前台</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item text-danger" asp-controller="Login" asp-action="EmployeeLogout">
                            <i class="bi bi-box-arrow-right me-2"></i>安全登出
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="main-wrapper d-flex flex-column flex-grow-1" style="min-width: 0;">
            <header class="cyber-header d-flex align-items-center justify-content-between px-4" style="height: 70px; flex-shrink: 0;">

                <div class="tech-hud-bar">

                    <div class="status-item-tech">
                        <div class="dot-blink-tech"></div>
                        <span>系統狀態: <span style="color: #00ff88;">STABLE</span></span>
                    </div>

                    <div class="status-item-tech d-none d-xl-flex">
                        <i class="bi bi-reception-4"></i>
                        <span>在線率: <span id="uptime-val" style="color: var(--tech-cyan);">99.98%</span></span>
                    </div>

                    <div class="status-item-tech" style="border-left-color: var(--tech-blue);">
                        <i class="bi bi-clock-history"></i>
                        <span id="sync-clock" class="text-white">00:00:00</span>
                    </div>

                </div>
            </header>

            <main role="main" class="p-4 flex-grow-1">
                @RenderBody()
            </main>

            <footer class="py-3 px-4 d-flex justify-content-between align-items-center" style="flex-shrink: 0; background: rgba(0,0,0,0.3); border-top: 1px solid var(--tech-border);">
                <div class="small">
                    &copy; 2026 - <span class="neon-text">演唱會售票系統</span>
                </div>
                <div class="small">
                    <i class="bi bi-shield-check me-1"></i> 
                    <span class="ms-3 text-cyan">
                        <i class="bi bi-clock me-1"></i> @DateTime.Now.ToString("HH:mm:ss")
                    </span>
                </div>
            </footer>
        </div>
    </div>

    <div id="antiforgery-token-holder" style="display:none;">
        @Html.AntiForgeryToken()
    </div>



    <!-- 漂亮的彈窗 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @* <script src="~/lib/jquery/dist/jquery.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    @* <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/admin-common.js" asp-append-version="true"></script>
    <script src="~/js/server-monitor.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity.IsAuthenticated)
    {
        <script src="~/js/Login/Logout.js" asp-append-version="true"></script>
    }
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
