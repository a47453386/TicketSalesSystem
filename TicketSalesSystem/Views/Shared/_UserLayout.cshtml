<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketSalesSystem</title>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TicketSalesSystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pixel-theme.css" asp-append-version="true" />
</head>
<body>
    <header>
        @* 🚩 修改 Nav：移除 bg-white, navbar-light，加入 pixel-navbar *@
        <nav class="navbar navbar-expand-lg pixel-navbar">
            <div class="container">
                @* 🚩 修改 Brand：加入 pixel-brand *@
                <a class="navbar-brand pixel-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-joystick me-2"></i> 8-BIT TICKET
                </a>

                @* 修改 Toggler 按鈕顏色以適應深色背景 *@
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" style="background-color: var(--pixel-blue);">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        @* 🚩 修改連結：加入 pixel-nav-link *@
                        <li class="nav-item"><a asp-controller="Programmes" asp-action="Index" class="nav-link pixel-nav-link">節目資訊</a></li>
                        <li class="nav-item"><a asp-controller="PublicNotices" asp-action="UserIndex" class="nav-link pixel-nav-link">最新消息</a></li>
                        <li class="nav-item"><a asp-controller="FAQs" asp-action="UserIndex" class="nav-link pixel-nav-link">常見問題</a></li>
                        <li class="nav-item"><a asp-controller="Orders" asp-action="UserIndex" class="nav-link pixel-nav-link">訂單查詢</a></li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (!User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item ms-lg-3">
                                @* 🚩 修改按鈕：換成 btn-pixel *@
                                <a class="btn btn-pixel" href="javascript:void(0);" onclick="openLoginModal()">
                                    <i class="bi bi-person-fill me-2"></i>會員登入
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                @* 🚩 修改下拉觸發器 *@
                                <a class="nav-link dropdown-toggle pixel-nav-link" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    PLAYER: @User.Identity.Name
                                </a>
                                @* 🚩 修改下拉選單容器：加入 pixel-dropdown-menu *@
                                <ul class="dropdown-menu dropdown-menu-end shadow-none pixel-dropdown-menu">
                                    <li><a class="dropdown-item pixel-dropdown-item" asp-controller="Orders" asp-action="UserIndex">我的訂單</a></li>
                                    <li><a class="dropdown-item pixel-dropdown-item" asp-controller="Members" asp-action="UserEdit">會員中心</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item pixel-dropdown-item text-danger" asp-controller="Login" asp-action="Logout">GAME OVER (登出)</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    @* 管理員選單 (同樣套用像素樣式) *@
                    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                    {
                        <ul class="navbar-nav ms-3">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle pixel-nav-link text-danger" href="#" id="adminNavbarDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-shield-lock-fill"></i> ADMIN ZONE
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-none pixel-dropdown-menu mt-2">
                                    @if (User.IsInRole("S") || User.IsInRole("A") || User.IsInRole("B"))
                                    {
                                        <li><h6 class="dropdown-header">CORE SYSTEMS</h6></li>
                                        <li><a class="dropdown-item pixel-dropdown-item" asp-controller="Programmes" asp-action="AdminIndex">節目管理</a></li>
                                        <li><a class="dropdown-item pixel-dropdown-item" asp-controller="Admin" asp-action="Dashboard">控制面板</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    @* (省略其他管理員選項，請依照上方模式套用 pixel-dropdown-item) *@
                                    <li><a class="dropdown-item pixel-dropdown-item" asp-controller="Admin" asp-action="Dashboard">進入後台</a></li>
                                </ul>
                            </li>
                        </ul>
                    }
                    else if (!User.IsInRole("Admin"))
                    {
                        <ul class="navbar-nav ms-3">
                            <li class="nav-item">
                                <a class="nav-link pixel-nav-link fs-pixel-small" asp-controller="Login" asp-action="EmployeeLogin">
                                    <i class="bi bi-door-open"></i> 後台管理
                                </a>
                            </li>
                        </ul>
                    }

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @* 🚩 核心：將主要內容包裹在像素框中，製造復古電視機/遊戲畫面的感覺 *@
        <div class="pixel-container-box">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    @* 🚩 修改 Modal：加入 pixel-modal-content *@
    <div class="modal fade" id="loginModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content pixel-modal-content border-0">
                <div class="modal-header">
                    <h5 class="modal-title text-pixel-yellow">PLAYER LOGIN</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div id="loginModalBody" class="modal-body p-0 bg-dark">
                    <div class="text-center py-5">
                        @* 修改 Loading Spinner 顏色 *@
                        <div class="spinner-border text-info" role="status" style="color: var(--pixel-blue) !important;"></div>
                        <div class="mt-3 fs-pixel-small">LOADING...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* 🚩 修改 Footer：加入 pixel-footer *@
    <footer class="pixel-footer text-muted">
        <div class="container text-center">
            &copy; 2026 - 8-BIT TICKET SYSTEM - PRESS START TO CONTINUE
        </div>
    </footer>

    @* <script src="~/lib/jquery/dist/jquery.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    @* <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/auth-modal.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
