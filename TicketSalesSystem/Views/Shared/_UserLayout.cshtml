@* 1. 注入你的 UserAccessor 服務 *@
@inject TicketSalesSystem.Service.IUserAccessor.IUserAccessorService UserAccessor


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketSalesSystem</title>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TicketSalesSystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pixel-theme.css" asp-append-version="true" />
</head>
<body>
    <header>
        
        <nav class="navbar navbar-expand-lg pixel-navbar">
            <div class="container">
                @* --- 品牌標誌 --- *@
                <a class="navbar-brand pixel-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-joystick me-2"></i> 演唱會售票系統
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" style="background-color: var(--pixel-blue);">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    @* --- 左側通用選單 (所有人都看的到) --- *@
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a asp-controller="Programmes" asp-action="Index" class="nav-link pixel-nav-link">節目資訊</a></li>
                        <li class="nav-item"><a asp-controller="UserPublicNotices" asp-action="UserIndex" class="nav-link pixel-nav-link">最新消息</a></li>
                        <li class="nav-item"><a asp-controller="UserFAQs" asp-action="UserIndex" class="nav-link pixel-nav-link">常見問題</a></li>
                        <li class="nav-item"><a asp-controller="UserOrders" asp-action="UserIndex" class="nav-link pixel-nav-link">訂單查詢</a></li>
                        <li class="nav-item"><a asp-controller="UserMembers" asp-action="Index" class="nav-link pixel-nav-link">會員中心</a></li>
                    </ul>

                    @* --- 右側功能區 (根據身份切換) --- *@
                    <div class="d-flex align-items-center">
                        @* --- 第一部分：員工/管理員區塊 (EmployeeScheme) --- *@
                        <ul class="navbar-nav">
                            @if (UserAccessor.IsEmployee())
                            {
                                @* 情況 B-1：員工已登入 - 顯示紅色管理專區 *@
                                <li class="nav-item dropdown ms-3">
                                    <a class="nav-link dropdown-toggle pixel-nav-link text-danger" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-shield-lock-fill"></i> BOSS AREA: @UserAccessor.GetUserRole()
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-none pixel-dropdown-menu mt-2">
                                        <li><h6 class="dropdown-header">CORE SYSTEMS</h6></li>
                                        <li><a class="dropdown-item pixel-dropdown-item" asp-controller="Admin" asp-action="Dashboard">系統儀表板</a></li>

                                        @* 根據細分角色顯示 *@
                                        @if (UserAccessor.GetUserRole() == "S" || UserAccessor.GetUserRole() == "A" || UserAccessor.GetUserRole() == "B")
                                        {
                                            <li><a class="dropdown-item pixel-dropdown-item" asp-controller="Programmes" asp-action="AdminIndex">節目管理</a></li>
                                        }

                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item pixel-dropdown-item text-danger" asp-controller="Login" asp-action="EmployeeLogout">下班登出</a></li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                @* 情況 A-1：員工未登入 - 顯示員工入口連結 *@
                                <li class="nav-item">
                                    <a class="nav-link pixel-nav-link fs-pixel-small mt-1" asp-controller="Login" asp-action="EmployeeLogin">
                                        <i class="bi bi-door-open"></i> 員工入口
                                    </a>
                                </li>
                            }
                        </ul>

                        @* --- 第二部分：一般會員區塊 (MemberScheme) --- *@
                        <ul class="navbar-nav">
                            @if (UserAccessor.IsMember())
                            {
                                @* 情況 B-2：會員已登入 - 顯示藍色玩家選單 *@
                                <li class="nav-item dropdown ms-3">
                                    <a class="nav-link dropdown-toggle pixel-nav-link" href="#" id="memberDropdown" role="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-person-circle"></i> @UserAccessor.GetUserName()
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-none pixel-dropdown-menu mt-2">
                                        <li><a class="dropdown-item pixel-dropdown-item" asp-controller="Orders" asp-action="UserIndex">我的訂單</a></li>
                                        <li><a class="dropdown-item pixel-dropdown-item" asp-controller="Members" asp-action="UserEdit">個人中心</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item pixel-dropdown-item text-danger" asp-controller="Login" asp-action="MemberLogout">GAME OVER (登出)</a></li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                @* 情況 A-2：會員未登入 - 顯示顯眼的登入按鈕 *@
                                <li class="nav-item ms-lg-3">
                                    <a class="btn btn-pixel" href="javascript:void(0);" onclick="openLoginModal()">
                                        <i class="bi bi-person-fill me-2"></i>會員登入
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @* 🚩 核心：將主要內容包裹在像素框中，製造復古電視機/遊戲畫面的感覺 *@
        <div class="pixel-container-box">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <div class="modal fade" id="loginModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-md">
            @* 🚩 加入 modal-md 確保寬度足夠 *@
            <div class="modal-content pixel-modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-pixel-yellow" style="font-family: 'Press Start 2P', cursive, monospace;">會員登入</h5>
                    @* 🚩 btn-close-white 確保在深色背景下看得到叉叉 *@
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                @* 🚩 移除 p-0 以免內容貼邊，背景統一為深色 *@
                <div id="loginModalBody" class="modal-body bg-dark" style="min-height: 350px;">
                    <div class="text-center py-5">
                        <div class="spinner-border text-info" role="status" style="color: var(--pixel-blue) !important; width: 3rem; height: 3rem;"></div>
                        <div class="mt-3 text-white fs-pixel-small">LOADING...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* 🚩 修改 Footer：加入 pixel-footer *@
    <footer class="pixel-footer text-muted">
        <div class="server-status-bar font-pixel">
            <div class="container d-flex justify-content-between align-items-center text-end">
                
                <div class="d-flex align-items-center gap-3 ">
                    <div class="status-item">
                        <span id="load-dot" class="dot-blink">●</span>
                        人流狀態: <span id="server-load" class="text-success">穩定</span>
                    </div>
                    <div class="status-item d-none d-sm-block">
                        | 在線率: <span id="uptime-val" class="text-pixel-yellow">99.98</span>%
                    </div>
                    <div class="status-item">
                        | <span id="sync-clock" class="text-white-50">00:00:00</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="container text-center">
            &copy; 2026 - 8-BIT TICKET SYSTEM - PRESS START TO CONTINUE
        </div>
    </footer>

    @* <script src="~/lib/jquery/dist/jquery.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    @* <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/auth-modal.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
