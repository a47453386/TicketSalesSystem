@model TicketSalesSystem.ViewModel.Employee.VMEmployeeEdit

@{
    ViewData["Title"] = "員工資料更新";
}
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Employee/EmployeeEdit.css" asp-append-version="true" />

@* 🚩 確保外層有 scope 鎖定，套用戰術背景與字體 *@
<div class="order-management-scope admin-body p-4">

    @* --- [1. 頂部標頭：HUD 診斷風格] --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-info border-opacity-25 pb-3">
        <div>
          @*   <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb m-0 p-0 bg-transparent">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-info text-decoration-none opacity-50">EMP_LIST</a></li>
                    <li class="breadcrumb-item active text-white">DATA_OVERRIDE</li>
                </ol>
            </nav> *@
            <h1 class="neon-header m-0">
                <i class="bi bi-pencil-square me-3"></i>@ViewData["Title"]
            </h1>
        </div>
        <div class="text-end">
            <div class="tech-key mb-0" style="background: linear-gradient(90deg, var(--tech-cyan), transparent 140%);">
                員工編號: @Model.EmployeeID
            </div>
        </div>
    </div>

    @* --- [2. 主編輯卡片] --- *@
    <div class="cyber-card p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @* 🚩 隱藏欄位 *@
            <input type="hidden" asp-for="EmployeeID" />
            <input type="hidden" asp-for="Photo" />
            <div asp-validation-summary="ModelOnly" class="text-danger small font-monospace mb-4"></div>

            <div class="row g-5">
                @* --- 左側：生物識別與基本資料 --- *@
                <div class="col-lg-7 border-end border-info border-opacity-10">

                    @* 照片上傳區：圓形掃描器樣式 *@
                    <div class="mb-5 text-center">
                        <div class="tech-key mb-4">照片</div>
                        <div class="position-relative d-inline-block">
                            <div class="profile-avatar-edit-wrap">
                                @if (!string.IsNullOrEmpty(Model.Photo))
                                {
                                    <img id="imgPreview" src="~/Photos/employeePhotos/@Model.Photo" />
                                }
                                else
                                {
                                    <img id="imgPreview" src="~/images/default-avatar.png" />
                                }
                                <label for="PhotoFile" class="avatar-edit-label">
                                    <i class="bi bi-camera-fill"></i>
                                </label>
                            </div>
                        </div>
                        <input asp-for="PhotoFile" type="file" class="d-none" accept="image/*" onchange="previewImage(this)" id="PhotoFile" />
                        
                    </div>

                    <div class="tech-key mb-4">基本資料</div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Name" class="text-info small mb-2 d-block">姓名</label>
                            <input asp-for="Name" class="form-control order-input" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NationalID" class="text-info small mb-2 d-block">身分證字號</label>
                            <input asp-for="NationalID" class="form-control order-input" />
                            <span asp-validation-for="NationalID" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Birthday" class="text-info small mb-2 d-block">生日</label>
                            <input asp-for="Birthday" type="date" class="form-control order-input"
                                   value="@Model.Birthday.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="text-info small mb-2 d-block">性別</label>
                            <div class="d-flex gap-4 mt-2">
                                <div class="form-check custom-cyber-radio">
                                    <input class="form-check-input" type="radio" asp-for="Gender" value="true" id="genderM">
                                    <label class="form-check-label text-white" for="genderM">男</label>
                                </div>
                                <div class="form-check custom-cyber-radio">
                                    <input class="form-check-input" type="radio" asp-for="Gender" value="false" id="genderF">
                                    <label class="form-check-label text-white" for="genderF">女</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="text-info small mb-2 d-block">信箱</label>
                        <input asp-for="Email" class="form-control order-input" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-8">
                            <label asp-for="Tel" class="text-info small mb-2 d-block">手機號碼</label>
                            <input asp-for="Tel" class="form-control order-input" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Extension" class="text-info small mb-2 d-block">分機</label>
                            <input asp-for="Extension" class="form-control order-input" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="text-info small mb-2 d-block">通訊地址</label>
                        <textarea asp-for="Address" class="form-control order-input" rows="2"></textarea>
                    </div>
                </div>

                @* --- 右側：帳號權限與安全系統 --- *@
                <div class="col-lg-5">
                    <div class="tech-key mb-4" style="background: linear-gradient(90deg, #ffcc00,transparent 140%);">帳號/密碼</div>

                    <div class="p-4 bg-dark bg-opacity-50 border border-info border-opacity-10 mb-4">
                        <div class="mb-4">
                            <label asp-for="Account" class="text-warning small mb-2 d-block">帳號</label>
                            <input asp-for="Account" class="form-control order-input opacity-50" readonly />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="text-warning small mb-2 d-block">重設密碼</label>
                            <input asp-for="Password" class="form-control order-input" type="password" placeholder="LEAVE_BLANK_TO_KEEP" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <hr class="border-info opacity-25 my-4" />

                        @* 職位變更區 *@
                        @* --- 職位分配模組 --- *@
                        <div class="mb-4">
                            <label class="text-info small mb-2 d-block">ASSIGN_ROLE / 職位分配</label>
                            <div class="input-group">
                                <select asp-for="RoleID" class="form-select order-input" asp-items="ViewBag.RoleID">
                                    <option value="">-- SELECT_ROLE --</option>
                                </select>
                                @* 快速操作按鈕群 *@
                                <button type="button" class="btn-cyber py-0 px-2" onclick="openQuickModal('Role', 'CREATE')"><i class="bi bi-plus-lg"></i></button>
                                <button type="button" class="btn-cyber btn-cyber-warning py-0 px-2" onclick="openQuickModal('Role', 'EDIT')"><i class="bi bi-pencil"></i></button>
                            </div>
                        </div>

                        @* --- 帳號狀態模組 --- *@
                        <div class="mb-4">
                            <label class="text-info small mb-2 d-block">ACCOUNT_STATUS / 帳號狀態</label>
                            <div class="input-group">
                                <select asp-for="AccountStatusID" class="form-select order-input" asp-items="ViewBag.AccountStatusID">
                                    <option value="">-- SELECT_STATUS --</option>
                                </select>
                                <button type="button" class="btn-cyber py-0 px-2" onclick="openQuickModal('Status', 'CREATE')"><i class="bi bi-plus-lg"></i></button>
                                <button type="button" class="btn-cyber btn-cyber-warning py-0 px-2" onclick="openQuickModal('Status', 'EDIT')"><i class="bi bi-pencil"></i></button>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="text-info small mb-2 d-block">帳號狀態</label>
                            <select asp-for="AccountStatusID" class="form-select order-input" asp-items="ViewBag.AccountStatusID"></select>
                        </div>

                        <div class="mb-0">
                            <label asp-for="HireDate" class="text-info small mb-2 d-block">到職日</label>
                            <input asp-for="HireDate" type="date" class="form-control order-input"
                                   value="@Model.HireDate.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>

                    <div class="alert border border-warning border-opacity-10 small text-info font-monospace">
                        <i class="bi bi-shield-lock-fill me-2"></i>警告：任何對權限層級 (Role) 的變更都將被系統日誌紀錄。
                    </div>
                </div>
            </div>

            @* --- 底部操作區 --- *@
            <div class="mt-5 pt-4 border-top border-info border-opacity-10 text-center">
                <a asp-action="Index" class="btn-cyber btn-cyber-warning me-3">
                    <i class="bi bi-arrow-left me-2"></i>回到清單
                </a>
                <button type="submit" class="btn-cyber px-5">
                    <i class="bi bi-save2-fill me-2"></i>更新並儲存
                </button>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
                // 🚩 戰術彈窗邏輯
        function openQuickModal(type, mode) {
            let title = (mode === 'CREATE') ? `NEW_${type}_REGISTRY` : `UPDATE_${type}_NAME`;
            let currentId = (mode === 'EDIT') ? $(`#${type}ID`).val() : '';
            let currentName = (mode === 'EDIT') ? $(`#${type}ID option:selected`).text() : '';

            if (mode === 'EDIT' && !currentId) {
                alert("請先從選單中選擇要修改的項目");
                return;
            }

            // 使用 SweetAlert2 或自定義 Modal
            Swal.fire({
                title: title,
                html: `
                    <input id="qId" class="swal2-input" placeholder="ID (編號)" value="${currentId}" ${mode === 'EDIT' ? 'readonly' : ''}>
                    <input id="qName" class="swal2-input" placeholder="Name (名稱)" value="${currentName}">
                `,
                background: '#000b1a',
                confirmButtonColor: '#00f2ff',
                showCancelButton: true,
                preConfirm: () => {
                    return { id: $('#qId').val(), name: $('#qName').val() };
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    let url = (mode === 'CREATE') ? `/Employees/QuickCreate${type}` : `/Employees/Update${type}`;

                    $.post(url, result.value, function(res) {
                        if (res.success) {
                            if (mode === 'CREATE') {
                                // 新增選項並選中
                                const newOpt = new Option(res.name, res.id, true, true);
                                $(`#${type}ID`).append(newOpt).trigger('change');
                            } else {
                                // 更新現有選項文字
                                $(`#${type}ID option:selected`).text(res.name);
                            }
                            Swal.fire('PROTOCOL_COMPLETED', '數據庫同步成功', 'success');
                        } else {
                            Swal.fire('ERROR', res.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}