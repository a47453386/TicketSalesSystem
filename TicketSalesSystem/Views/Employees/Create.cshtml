@model TicketSalesSystem.ViewModel.Employee.EmployeeCreateVM

@{
    ViewData["Title"] = "新增員工";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-person-plus-fill"></i> 新增員工資料</h4>
            <span class="badge bg-light text-primary">系統自動編號預覽：F26XXX</span>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-4 text-center">
                    <div class="position-relative d-inline-block">
                        <img id="imgPreview" src="~/images/default-avatar.png"
                             class="rounded-circle border shadow-sm"
                             style="width: 140px; height: 140px; object-fit: cover;" />
                        <label for="PhotoFile" class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle p-2 shadow" style="cursor: pointer;">
                            <i class="bi bi-camera-fill"></i>
                        </label>
                    </div>
                    <div class="mt-2">
                        <input asp-for="PhotoFile" type="file" class="d-none" accept="image/*" onchange="previewImage(this)" id="PhotoFile" />
                        <small class="text-muted">點擊相機圖示上傳照片</small>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-7 border-end">
                        <h5 class="text-primary mb-3 border-bottom pb-2">基本資訊</h5>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-bold"></label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NationalID" class="form-label fw-bold"></label>
                                <input asp-for="NationalID" class="form-control" placeholder="A123456789" />
                                <span asp-validation-for="NationalID" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Birthday" class="form-label fw-bold"></label>
                                <input asp-for="Birthday" type="date" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Gender" class="form-label fw-bold"></label>
                                <div class="mt-2">
                                    <input type="radio" asp-for="Gender" value="true" checked /> 男
                                    <input type="radio" asp-for="Gender" value="false" class="ms-3" /> 女
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-8">
                                <label asp-for="Tel" class="form-label fw-bold"></label>
                                <input asp-for="Tel" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Extension" class="form-label fw-bold"></label>
                                <input asp-for="Extension" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-bold"></label>
                            <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="col-md-5 bg-light p-3 rounded">
                        <h5 class="text-success mb-3 border-bottom pb-2">權限與帳號設定</h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">職位分配</label>
                            <div id="roleSelectArea">
                                <div class="input-group">
                                    <select asp-for="RoleID" class="form-select" asp-items="ViewBag.RoleID">
                                        <option value="">-- 請選擇職位 --</option>
                                    </select>
                                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="toggleInput('Role')">新增</button>
                                </div>
                            </div>
                            <div id="roleInputArea" style="display:none;" class="p-2 border rounded bg-white mt-1">
                                <div class="d-flex justify-content-between mb-1"><small class="fw-bold text-primary">手動新增角色</small><button type="button" class="btn-close btn-sm" onclick="toggleInput('Role', false)"></button></div>
                                <div class="row g-1">
                                    <div class="col-4"><input asp-for="NewRoleID" class="form-control form-control-sm" placeholder="編號" /></div>
                                    <div class="col-8"><input asp-for="NewRoleName" class="form-control form-control-sm" placeholder="名稱" /></div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">帳號狀態</label>
                            <div id="statusSelectArea">
                                <div class="input-group">
                                    <select asp-for="AccountStatusID" class="form-select" asp-items="ViewBag.AccountStatusID">
                                        <option value="">-- 請選擇狀態 --</option>
                                    </select>
                                    <button type="button" class="btn btn-outline-success btn-sm" onclick="toggleInput('Status')">新增</button>
                                </div>
                            </div>
                            <div id="statusInputArea" style="display:none;" class="p-2 border rounded bg-white mt-1">
                                <div class="d-flex justify-content-between mb-1"><small class="fw-bold text-success">手動新增狀態</small><button type="button" class="btn-close btn-sm" onclick="toggleInput('Status', false)"></button></div>
                                <div class="row g-1">
                                    <div class="col-4"><input asp-for="NewAccountStatusID" class="form-control form-control-sm" placeholder="編號" /></div>
                                    <div class="col-8"><input asp-for="NewAccountStatusName" class="form-control form-control-sm" placeholder="名稱" /></div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Account" class="form-label fw-bold"></label>
                            <input asp-for="Account" class="form-control" />
                            <span asp-validation-for="Account" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-bold"></label>
                            <input asp-for="Password" class="form-control" type="password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="HireDate" class="form-label fw-bold"></label>
                            <input asp-for="HireDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4 border-top pt-3">
                    <a asp-action="Index" class="btn btn-secondary me-2">取消</a>
                    <button type="submit" class="btn btn-primary px-5">建立員工帳號</button>
                </div>
            </form>
        </div>
    </div>
</div>
<div asp-validation-summary="All" class="text-danger"></div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // 1. 照片預覽
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = e => document.getElementById('imgPreview').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
            }
        }

        // 2. 切換行內新增區塊
        function toggleInput(type, show = true) {
            const selectArea = document.getElementById(`${type.toLowerCase()}SelectArea`);
            const inputArea = document.getElementById(`${type.toLowerCase()}InputArea`);
            selectArea.style.display = show ? 'none' : 'block';
            inputArea.style.display = show ? 'block' : 'none';

            if (!show) { // 如果取消，清空手動輸入內容
                document.getElementById(`New${type}ID`).value = '';
                document.getElementById(`New${type}Name`).value = '';
            }
        }
    </script>
}