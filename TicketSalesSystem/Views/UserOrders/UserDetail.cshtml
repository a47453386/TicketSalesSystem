@using TicketSalesSystem.ViewModel.Order
@model VMUserOrderDetail

@{
    ViewData["Title"] = "我的電子票夾";
    Layout = "_UserLayout";
}
<style>
    /* 🚩 像素票券專屬樣式 */
    .pixel-ticket {
        background-color: var(--pixel-bg-light);
        border: 4px solid #000;
        box-shadow: 4px 4px 0px var(--pixel-blue);
        position: relative;
        transition: transform 0.1s;
    }

        .pixel-ticket:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--pixel-pink);
        }

    .bg-pixel-blue {
        background-color: var(--pixel-blue) !important;
    }

    /* 票券鋸齒邊緣感 (模擬打孔) */
    .ticket-pixel-body {
        position: relative;
        border-top: 4px dashed #331144;
        border-bottom: 4px dashed #331144;
    }

    /* 🚩 QR Code 霓虹框 */
    .pixel-qrcode-frame {
        width: 180px;
        height: 180px;
        padding: 10px;
        background: #fff; /* QR Code 必須在白底上 */
        border: 4px solid var(--pixel-blue);
        box-shadow: 0 0 10px var(--pixel-blue);
    }

    .border-pixel-dashed {
        border-top: 2px dashed var(--pixel-blue);
    }

    .locked-pixel-box {
        background-color: rgba(0,0,0,0.5);
        border: 2px solid #331144;
    }

    .ticket-pixel-footer {
        background-color: #000;
        color: var(--pixel-text-muted);
    }

    .border-start-pixel {
        border-left: 4px solid var(--pixel-pink);
        padding-left: 20px;
    }

    .fs-pixel-small{
        font-size: 1.2rem !important;
    }

    /* 列印優化：隱藏背景與不必要的像素框 */
    @@media print {
        body {
            background: white;
            color: black;
        }

        .btn-pixel-text, .pixel-navbar, .pixel-footer {
            display: none;
        }

        .pixel-ticket {
            border: 2px solid black;
            box-shadow: none;
            page-break-inside: avoid;
        }
    }
</style>
<div class="container py-5">
    <div class="mt-2 py-2  border-secondary text-warning overflow-hidden" style="white-space: nowrap;">
        <marquee scrollamount="5">>>> 請將驗證妥善保存.....請勿截圖上傳至公開區域 <<<</marquee>
    </div>
    @* 🚩 頂部導覽區：像素化麵包屑與列印按鈕 *@
    <div class="d-flex justify-content-between align-items-center mb-4">        
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="UserIndex" asp-controller="UserOrders" class="btn-pixel-text">[ 訂單總攬 ]</a></li>
                <li class="breadcrumb-item active text-white" aria-current="page">票券詳情</li>
            </ol>
        </nav>
        <button class="btn-pixel-text" onclick="window.print()">
            <i class="bi bi-printer me-2"></i>[ 列印憑證 ]
        </button>
    </div>

    @* 🚩 活動主資訊：終端機封包格式 *@
    <div class="pixel-container-box mb-5">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 class="text-pixel-yellow fw-bold mb-3">活動名稱:@Model.ProgrammeName</h2>
                <div class="d-flex flex-wrap gap-4 fs-6">
                    <span class="text-pixel-blue"><i class="bi bi-calendar3 me-2"></i>演出日期: @Model.StartTime</span>
                    <span class="text-pixel-pink"><i class="bi bi-geo-alt-fill me-2"></i>演出地點: @Model.PlaceName</span>
                </div>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0 border-start-pixel">
                <div class="text-pixel-muted fs-6">總額</div>
                <div class="h2 fw-bold text-pixel-yellow">$@Model.FinalAmount.ToString("N0")</div>
            </div>
        </div>
    </div>

    <h4 class="text-pixel-pink mb-4 font-pixel-small">>>> 掃描持票憑證 </h4>

    <div class="row g-4">
        @foreach (var ticket in Model.Tickets)
        {
            <div class="col-md-6 col-lg-4">
                @* 🚩 像素票券核心 *@
                <div class="pixel-ticket">
                    @* 票區標題 *@
                    <div class="ticket-pixel-header bg-pixel-blue text-dark text-center py-2 fw-bold fs-pixel-small">
                       票區: @ticket.TicketsAreaName
                    </div>

                    <div class="ticket-pixel-body p-4 text-center">
                        <div class="text-pixel-muted fs-pixel-small mb-1">座位</div>
                        <h3 class="text-white fw-bold mb-4">@ticket.Seat</h3>

                        <div class="qr-section">
                            @if (!string.IsNullOrEmpty(ticket.CheckInCode))
                            {
                                @* 🚩 QR Code 霓虹外框 *@
                                <div class="pixel-qrcode-frame mx-auto mb-3">
                                    <div class="qrcode-container d-flex justify-content-center" data-code="@ticket.CheckInCode"></div>
                                </div>
                                <div class="bg-black bg-opacity-50 py-2 border-pixel-dashed">
                                    <small class="text-pixel-blue d-block fs-pixel-small">檢查碼</small>
                                    <code class="text-pixel-yellow fw-bold" style="font-size: 1.1rem;">@ticket.CheckInCode</code>
                                </div>
                            }
                            else
                            {
                                @* 🚩 鎖定狀態：模擬加密失敗 *@
                                <div class="locked-pixel-box py-5">
                                    <i class="bi bi-shield-lock-fill text-pixel-muted display-4 dot-blink"></i>
                                    <p class="mt-3 mb-1 fw-bold text-pixel-pink fs-pixel-small">尚未開放</p>
                                    <small class="text-white-50 fs-pixel-small">開放時間：演出前 3 天</small>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="ticket-pixel-footer d-flex justify-content-between px-3 py-2 fs-pixel-small">
                        <span class="text-pixel-muted">ID: @ticket.TicketsID.Substring(0, 8)</span>
                        <span class="text-pixel-pink">通行證</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>



@section Scripts {
    @* 請確保頁面有引用 qrcode.js *@
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const qrContainers = document.querySelectorAll('.qrcode-container');
            qrContainers.forEach(container => {
                const code = container.getAttribute('data-code');
                if (code) {
                    new QRCode(container, {
                        text: code,
                        width: 160,
                        height: 160,
                        colorDark: "#000000",
                        colorLight: "#ffffff",
                        correctLevel: QRCode.CorrectLevel.H
                    });
                }
            });
        });
    </script>
}