@using TicketSalesSystem.ViewModel.Order
@model VMUserOrderDetail

@{
    ViewData["Title"] = "我的電子票夾";
    Layout = "_UserLayout";
}
<link rel="stylesheet" href="~/css/User/Order/UserOrderDetail.css" asp-append-version="true" />

<div class="container py-5">
    <div class="mt-2 py-2  border-secondary text-warning overflow-hidden" style="white-space: nowrap;">
        <marquee scrollamount="5">>>> 請將驗證妥善保存.....請勿截圖上傳至公開區域 <<<</marquee>
    </div>
    @* 🚩 頂部導覽區：像素化麵包屑與列印按鈕 *@
    <div class="d-flex justify-content-between align-items-center mb-4">        
       
        @if (Model.IsPrintable)
        {
            @* 🚩 可點擊：像素藍色風格 *@
            <a asp-controller="UserTickets" asp-action="PrintTickets" asp-route-orderId="@Model.OrderID"
               target="_blank" class="pixel-btn btn-print">
                <i class="bi bi-printer-fill me-2"></i>[ 列印實體票券 ]
            </a>
        }
        else
        {
            @* 🚩 鎖定：像素灰色風格 *@
            <button class="pixel-btn btn-locked"
                    style="background-color: rgba(0,0,0,0.5) !important;
                   border: 4px solid rgba(255, 255, 255, 0.1) !important;
                   color: rgba(255, 255, 255, 0.4) !important;
                   box-shadow: none !important;
                   display: flex; align-items: center;"
                    onclick="alert('>>> 系統提示: 票券演出前15天開放 <<<')">
                <i class="bi bi-lock-fill me-2" style="color: var(--pixel-blue) !important;"></i>
                <span>[ 尚未開放列印 ]</span>
            </button>
        }
    </div>

    @* 🚩 活動主資訊：終端機封包格式 *@
    <div class="pixel-container-box mb-5">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 class="text-pixel-yellow fw-bold mb-3">活動名稱:@Model.ProgrammeName</h2>
                <div class="d-flex flex-wrap gap-4 fs-6">
                    <span class="text-pixel-blue"><i class="bi bi-calendar3 me-2"></i>演出日期: @Model.StartTime</span>
                    <span class="text-pixel-pink"><i class="bi bi-geo-alt-fill me-2"></i>演出地點: @Model.PlaceName</span>
                </div>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0 border-start-pixel">
                <div class="text-pixel-muted fs-6">總額</div>
                <div class="h2 fw-bold text-pixel-yellow">$@Model.FinalAmount.ToString("N0")</div>
            </div>
        </div>
    </div>

    <h4 class="text-pixel-pink mb-4 font-pixel-small">>>> 掃描持票憑證 </h4>

    <div class="row g-4">
        @foreach (var ticket in Model.Tickets)
        {
            <div class="col-md-6 col-lg-4">
                @* 🚩 像素票券核心 *@
                <div class="pixel-ticket">
                    @* 票區標題 *@
                    <div class="ticket-pixel-header bg-pixel-blue text-dark text-center fw-bold fs-pixel-small">
                        票區: @ticket.TicketsAreaName
                    </div>

                    <div class="ticket-pixel-body p-4 text-center">
                        <div class="text-pixel-muted fs-pixel-small">座位</div>
                        <h3 class="text-white fw-bold mb-4">@ticket.Seat</h3>

                        <div class="qr-section">
                            @* 🚩 改用 TicketsStatusID 判斷是否顯示 QR Code *@
                            @if (ticket.TicketsStatusID == "A")
                            {
                                @* 🚩 狀態為 A：顯示 QR Code *@
                                <div class="pixel-qrcode-frame mx-auto mb-3">
                                    <div class="qrcode-container d-flex justify-content-center" data-code="@ticket.CheckInCode"></div>
                                </div>
                                <div class="bg-black bg-opacity py-2 border-pixel-dashed">
                                    <small class="text-pixel-blue d-block fs-pixel-small">檢查碼</small>
                                    <code class="text-pixel-yellow fw-bold" style="font-size: 1.1rem;">@ticket.CheckInCode</code>
                                </div>
                            }
                            else if (ticket.TicketsStatusID == "S")
                            {
                                @* 🚩 狀態為 S：顯示鎖定畫面 *@
                                <div class="locked-pixel-box py-5">
                                    <i class="bi bi-shield-lock-fill text-pixel-muted display-4 dot-blink"></i>
                                    <p class="mt-3 mb-1 fw-bold text-pixel-pink fs-pixel-small">票券鎖定中</p>
                                    @* 這裡的日期可以根據你的 15 天邏輯動態計算，或是寫死提醒 *@
                                    <small class="text-white-50 fs-pixel-small">開放時間：演出前 15 天</small>
                                </div>
                            }
                            else
                            {
                                @* 其他狀態處理 (如：已使用、已取消) *@
                                <div class="locked-pixel-box py-5 opacity-50">
                                    <i class="bi bi-slash-circle text-pixel-muted display-4"></i>
                                    <p class="mt-3 mb-1 fw-bold text-white fs-pixel-small">
                                        @(ticket.TicketsStatusID == "Y" ? "票券已使用" : "票券無效")
                                    </p>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="ticket-pixel-footer d-flex justify-content-between px-3 py-2 fs-pixel-small">
                        <span class="text-pixel-muted">ID: @ticket.TicketsID.Substring(0, 8)</span>
                        <span class="text-pixel-pink">通行證</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>



@section Scripts {
    <script src="~/js/User/Ticket/ticket-qr-init.js"></script>
}