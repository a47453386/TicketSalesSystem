@using TicketSalesSystem.ViewModel.Booking
@model IEnumerable<VMBookingDetailsResponse>

@{
    ViewData["Title"] = "訂單明細查詢";
    Layout = "_UserLayout";
}

<style>

    /* 🚩 1. 解決字體太小：將基礎大小從 0.7 提高到 0.9rem 或 1rem */
    .pixel-table {
        font-size: 0.9rem !important;
        background-color: transparent !important;
        color: #ffffff !important;
        border: 4px solid var(--pixel-blue) !important;
    }

        /* 🚩 2. 解決黑底黑字：強制表頭文字為黃色 */
        .pixel-table thead th {
            background-color: #000000 !important; /* 黑底 */
            color: var(--pixel-yellow) !important; /* 🚩 強制黃字，確保看得到 */
            border-bottom: 4px solid var(--pixel-pink) !important;
            padding: 15px !important;
            text-align: center;
        }

        /* 🚩 解決列表背景是白色的問題：強制所有 tr/td 為深色 */
        .pixel-table tbody tr {
            background-color: rgba(17, 0, 34, 0.8) !important; /* 深紫色背景 */
            color: #ffffff !important;
        }

        .pixel-table td {
            border-bottom: 2px solid #331144 !important;
            padding: 15px !important;
            background-color: transparent !important; /* 防止 Bootstrap 蓋色 */
            color: #ffffff !important; /* 確保內容字是白的 */
        }

    /* 🚩 3. 金額單一顏色：取消原本的紅色，統一使用像素黃 */
    .text-amount-pixel {
        color: var(--pixel-yellow) !important;
        font-weight: bold;
        text-shadow: 2px 2px 0px #000;
    }
    /* 🚩 成功狀態：亮綠色 (已付款/已完成) */
    .status-paid {
        color: #00ff66 !important;
        text-shadow: 0 0 8px rgba(0, 255, 102, 0.6);
    }

    /* 🚩 警告狀態：像素黃 (待付款/處理中) */
    .status-pending {
        color: #ffcc00 !important;
        text-shadow: 0 0 8px rgba(255, 204, 0, 0.6);
    }

    /* 🚩 終止狀態：霓虹粉 (已取消/失敗) */
    .status-cancelled {
        color: #ff00cc !important;
        text-shadow: 0 0 8px rgba(255, 0, 204, 0.6);
    }

    /* 讓狀態點點閃爍，增加動態感 */
    .status-dot {
        margin-right: 5px;
        animation: pixel-blink 1.5s infinite;
    }

  
</style>
<div class="container py-5">
    <div class="mt-2 py-2  border-secondary text-warning overflow-hidden" style="white-space: nowrap;">
        <marquee scrollamount="5">>>> 如要退票請向客服提出申請... <<<</marquee>
    </div>
    @* 🚩 頁面標題區塊 *@
    <div class="pixel-container-box mb-5">
        <div class="status-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="text-pixel-yellow mb-0">[ 訂單查詢系統 ]</h2>                
            </div>
            <i class="bi bi-terminal display-5 text-pixel-blue"></i>
        </div>
    </div>

    @* 🚩 核心訂單表格 *@
    <div class="pixel-container-box p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table pixel-table mb-0">
                <thead>
                    <tr>
                        <th class="py-3 text-pixel-blue">訂單編號</th>
                        <th class="py-3 text-pixel-blue">訂購時間 </th>
                        <th class="py-3 text-pixel-blue text-start">節目名稱</th>
                        <th class="py-3 text-pixel-blue">訂單狀態</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var order in Model)
                        {
                            <tr class="align-middle  text-center">
                                <td class="fw-bold text-white fs-6">@order.OrderID</td>
                                <td class="text-pixel-muted fs-6">@order.CreateTime</td>
                                <td class="text-start">
                                    <div class="text-pixel-pink fw-bold">@order.ProgrammeName</div>
                                    <div class="mt-1 d-flex align-items-center fs-6">
                                        <span class="text-pixel-blue fs-6">[ 共 @(order.TicketDetails?.Count ?? 0) 張 ]</span>
                                        <span class="ms-3 text-white fs-6">總額：<span class="text-pixel-yellow fs-6">$@order.FinalAmount.ToString("N0")</span></span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex flex-column align-items-center gap-2">
                                        @* 🚩 動態顏色狀態標籤 *@
                                        @{
                                            string statusClass = order.OrderStatusID switch
                                            {
                                                "Y" => "status-paid",      // 已付款
                                                "P" => "status-pending",   // 待付款
                                                "C" => "status-cancelled", // 已取消
                                                _ => "text-white-50"       // 其他 (灰)
                                            };
                                        }
                                        <span class="@statusClass fw-bold fs-6 shadow-sm">
                                            <span class="status-dot">●</span>@order.OrderStatusName
                                        </span>

                                        @* 🚩 指令按鈕 *@
                                        <div class="mt-2 fs-6 ">
                                            @if (order.OrderStatusID == "P")
                                            {
                                                <a asp-controller="Seats" asp-action="Payment" asp-route-id="@order.OrderID" class="btn btn-pixel-bright-flat btn-pixel-sm mb-1 bg-warning text-dark">
                                                    前往付款
                                                </a>
                                            }
                                            else if (order.OrderStatusID == "Y")
                                            {
                                                <a asp-action="UserDetail" asp-route-id="@order.OrderID" class="btn btn-pixel-bright-flat btn-pixel-sm mb-1 bg-opacity-100 text-success ">
                                                    入場證明
                                                </a>
                                            }

                                            <button class="btn btn-pixel-text  btn-detail-toggle d-block mx-auto"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#detail_@order.OrderID">
                                                [ <span class="btn-text">檢視明細</span> ]
                                            </button>
                                        </div>
                                    </div>
                                </td>
                            </tr>

                            @* 🚩 摺疊明細內容 (終端機數據風) *@
                            <tr class="collapse" id="detail_@order.OrderID">
                                <td colspan="4" class="p-0">
                                    <div class="bg-black bg-opacity-50 p-4 border-top border-pixel-blue">
                                        <h6 class="text-pixel-blue mb-3 font-pixel-small text-start">>>> 票券明細:</h6>
                                        <table class="table table-dark table-bordered border-secondary mb-0 text-white fs-6 text-center">
                                            <thead >
                                                <tr>
                                                    <th>序號</th>
                                                    <th>場次與地點</th>
                                                    <th>票區 / 座位</th>
                                                    <th>單價</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (order.TicketDetails != null)
                                                {
                                                    int seatIdx = 1;
                                                    foreach (var seat in order.TicketDetails)
                                                    {
                                                        <tr>
                                                            <td>@(seatIdx++)</td>
                                                            <td >
                                                                <div>@order.ProgrammeName－@(DateTime.TryParse(order.StartTime, out var dt) ? dt.ToString("yyyy/MM/dd HH:mm") : order.StartTime)</div>
                                                                
                                                                <div class="text-pixel-blue small">📍 @order.PlaceName</div>
                                                            </td>
                                                            <td>@seat.SeatInfo</td>
                                                            <td>$@seat.Price.ToString("N0")</td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="text-pixel-muted">
                                    <i class="bi bi-exclamation-triangle display-4 d-block mb-3"></i>
                                    [ 目前尚未有訂單 ]
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const collapseElements = document.querySelectorAll('.collapse');
            collapseElements.forEach(el => {
                el.addEventListener('show.bs.collapse', function () {
                    const btn = document.querySelector(`[data-bs-target="#${this.id}"]`);
                    if (btn) btn.querySelector('.btn-text').innerText = '收合';
                });
                el.addEventListener('hide.bs.collapse', function () {
                    const btn = document.querySelector(`[data-bs-target="#${this.id}"]`);
                    if (btn) btn.querySelector('.btn-text').innerText = '檢視明細';
                });
            });

            @if (TempData["Success"] != null)
            {
                    <text>
                    Swal.fire({
                        background: '#110022',
                        color: '#00ff66',
                        title: '[ 執行成功 ]',
                        text: '@Html.Raw(TempData["Success"])',
                        confirmButtonColor: '#ff00cc',
                        confirmButtonText: '了解',
                        customClass: { popup: 'pixel-modal-content' }
                    });
                    </text>
            }
        });
    </script>
}