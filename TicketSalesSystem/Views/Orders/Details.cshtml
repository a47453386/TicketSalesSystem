@model TicketSalesSystem.Models.Order

@{
    ViewData["Title"] = "訂單詳情 - " + Model.OrderID;
}
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Order/OrderDetail.css" asp-append-version="true" />


<div class="admin-body p-4">

    @* --- [1. 頁面標頭：診斷報告風格] --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-info border-opacity-25 pb-3">
        <div>
            <h1 class="neon-header m-0">
                <i class="bi bi-file-earmark-text me-3"></i>訂單詳情：@Model.OrderID
            </h1>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.OrderID" class="btn-cyber btn-cyber-warning">
                <i class="bi bi-shield-check me-2"></i>[ 訂單編輯]
            </a>
            <a asp-action="Index" class="btn-cyber">
                <i class="bi bi-arrow-left-circle me-2"></i>[ 回到清單 ]
            </a>
        </div>
    </div>

    <div class="row g-4">
        @* --- [2. 左側：基本資訊與客戶數據] --- *@
        <div class="col-lg-4">
            <div class="cyber-card p-4 mb-4">
                <div class="tech-key mb-4">訂單概覽</div>
                
                <div class="tech-data-row">
                    <div class="data-label">訂單狀態:</div>
                    <div class="data-value">
                        @{
                            var badgeClass = Model.OrderStatusID == "Y" ? "bg-success" : 
                                            (Model.OrderStatusID == "N" ? "bg-warning" : "bg-danger");
                        }
                        <span class="status-badge-tech @badgeClass">@Model.OrderStatus?.OrderStatusName</span>
                    </div>
                </div>

                <div class="tech-data-row">
                    <div class="data-label">建立時間:</div>
                    <div class="data-value font-monospace">@Model.OrderCreatedTime.ToString("yyyy/MM/dd HH:mm:ss")</div>
                </div>

                <div class="tech-data-row">
                    <div class="data-label">付款方式:</div>
                    <div class="data-value">@(Model.PaymentMethod?.PaymentMethodName ?? "UNSPECIFIED")</div>
                </div>

                <div class="tech-data-row border-0">
                    <div class="data-label">訂單總金額:</div>
                    <div class="data-value fs-4 fw-bold text-pixel-yellow">
                        TWD $@Model.Tickets.Sum(t => t.TicketsArea.Price).ToString("N0")
                    </div>
                </div>
            </div>

            <div class="cyber-card p-4">
                <div class="tech-key mb-4">會員</div>
                <div class="tech-data-row">
                    <div class="data-label">ID:</div>
                    <div class="data-value font-monospace text-info">#@Model.MemberID</div>
                </div>
                <div class="tech-data-row">
                    <div class="data-label">Identity:</div>
                    <div class="data-value fw-bold">@Model.Member?.Name</div>
                </div>
            </div>
        </div>

        @* --- [3. 右側：票券明細與紀錄] --- *@
        <div class="col-lg-8">
            <div class="cyber-card p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="tech-key mb-0">票券明細</div>
                    <span class="badge bg-info bg-opacity-10 text-info border border-info px-3">
                        票券數: @Model.Tickets.Count 張
                    </span>
                </div>

                <div class="table-responsive custom-scroll">
                    <table class="cyber-table align-middle">
                        <thead>
                            <tr>
                                <th style="width: 40%"><div class="tech-key">活動名稱 / 場次</div></th>
                                <th><div class="tech-key">票區</div></th>
                                <th><div class="tech-key">座次</div></th>
                                <th class="text-end"><div class="tech-key">單價</div></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ticket in Model.Tickets)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-white">@ticket.Session?.Programme?.ProgrammeName</div>
                                        <div class="small font-monospace text-info opacity-75">
                                            @ticket.Session?.StartTime.ToString("yyyy/MM/dd HH:mm")
                                        </div>
                                    </td>
                                    <td class="text-center">@ticket.TicketsArea?.TicketsAreaName</td>
                                    <td class="text-center font-monospace">@ticket.RowIndex <span class="opacity-50">R</span> @ticket.SeatIndex <span class="opacity-50">S</span></td>
                                    <td class="text-end fw-bold text-pixel-yellow">
                                        $@ticket.TicketsArea?.Price.ToString("N0")
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background: rgba(0, 242, 255, 0.05);">
                                <td colspan="3" class="text-end py-3 text-info font-monospace">總額:</td>
                                <td class="text-end py-3 px-3">
                                    <div class="fs-4 fw-bold text-pixel-yellow">
                                        $@Model.Tickets.Sum(t => t.TicketsArea.Price).ToString("N0")
                                    </div>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

           
            @if (Model.Question != null && Model.Question.Any())
            {
                <div class="cyber-card p-4 mt-4" style="border-color: var(--tech-danger) !important;">
                    <div class="tech-key mb-4" style="background: linear-gradient(90deg, var(--tech-danger), transparent) !important;">
                        <i class="bi bi-broadcast me-2"></i> 客服紀錄
                    </div>
                    @foreach (var q in Model.Question)
                    {
                        <div class="border-start border-danger border-2 ps-3 mb-4">
                            <div class="small text-danger opacity-75 font-monospace">
                                TIMESTAMP: @q.CreatedTime.ToString("yyyy.MM.dd HH:mm")
                            </div>
                            <div class="text-white mt-1">@q.QuestionDescription</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>