@model TicketSalesSystem.Models.Order

@{
    ViewData["Title"] = "訂單詳情 - " + Model.OrderID;
    Layout = "_AdminLayout"; // 確保套用後台版面
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center my-4">
        <h2><i class="bi bi-file-earmark-text"></i> 訂單詳情：@Model.OrderID</h2>
        <div>
            <a asp-action="Index" class="btn btn-secondary">返回列表</a>
            <a asp-action="Edit" asp-route-id="@Model.OrderID" class="btn btn-warning text-white">去管理/退票</a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">基本資訊</div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <th class="ps-0" style="width: 100px;">訂單狀態</th>
                            <td>
                                <span class="badge @(Model.OrderStatusID == "S" ? "bg-success" : (Model.OrderStatusID == "P" ? "bg-warning text-dark" : "bg-danger"))">
                                    @Model.OrderStatus?.OrderStatusName
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th class="ps-0">成立時間</th>
                            <td>@Model.OrderCreatedTime.ToString("yyyy/MM/dd HH:mm:ss")</td>
                        </tr>
                        <tr>
                            <th class="ps-0">付款方式</th>
                            <td>@(Model.PaymentMethod?.PaymentMethodName ?? "未指定")</td>
                        </tr>
                        <tr>
                            <th class="ps-0">總金額</th>
                            <td class="fs-5 fw-bold text-danger">TWD $@Model.Tickets.Sum(t => t.TicketsArea.Price).ToString("N0")</td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">會員資訊</div>
                <div class="card-body">
                    <p class="mb-1"><strong>會員 ID：</strong><br />@Model.MemberID</p>
                    <p class="mb-1"><strong>會員帳號：</strong><br />@Model.Member?.Name</p>
                    <hr />
                    <small class="text-muted">若需聯絡會員，請至會員管理系統查詢詳細 Email 與電話。</small>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-bold text-primary">票券明細 (@Model.Tickets.Count 張)</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>活動名稱 / 場次</th>
                                    <th>票區</th>
                                    <th>座位</th>
                                    <th class="text-end">價格</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ticket in Model.Tickets)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-bold">@ticket.Session?.Programme?.ProgrammeName</div>
                                            <small class="text-muted">@ticket.Session?.StartTime.ToString("yyyy/MM/dd HH:mm")</small>
                                        </td>
                                        <td>@ticket.TicketsArea?.TicketsAreaName</td>
                                        <td>@ticket.RowIndex 排 @ticket.SeatIndex 號</td>
                                        <td class="text-end fw-bold">$@ticket.TicketsArea?.Price.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">合計：</td>
                                    <td class="text-end fw-bold text-danger fs-5">$@Model.Tickets.Sum(t => t.TicketsArea.Price).ToString("N0")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            @if (Model.Question != null && Model.Question.Any())
            {
                <div class="card shadow-sm mt-4">
                    <div class="card-header bg-info text-white text-white fw-bold">相關客服紀錄</div>
                    <div class="card-body">
                        @foreach (var q in Model.Question)
                        {
                            <div class="border-start border-info border-4 ps-3 mb-3">
                                <div class="small text-muted">@q.CreatedTime.ToString("yyyy/MM/dd") - 提問</div>
                                <div>@q.QuestionDescription</div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>