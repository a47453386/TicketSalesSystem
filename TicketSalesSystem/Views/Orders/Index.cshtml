@model IEnumerable<TicketSalesSystem.Models.Order>

@{
    ViewData["Title"] = "訂單管理總覽";
}
<link rel="stylesheet" href="~/css/Admin/Order/OrderIndex.css" asp-append-version="true" />

<div class="order-management-scope">
    @* --- [Header] --- *@
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="neon-header"><i class="bi bi-cart-check-fill"></i>@ViewData["Title"]</h2>
        </div>
    </div>

    @* --- [Filter Section] --- *@
    <div class="cyber-card">
        <div class="tech-key small">搜尋</div>
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="opacity-50 small mb-2"><i class="bi bi-search me-1"></i>尋找</label>
                <input type="text" name="searchString" class="form-control order-input" placeholder="請輸入關鍵字..." value="@Context.Request.Query["searchString"]" />
            </div>
            <div class="col-md-3">
                <label class="opacity-50 small mb-2"><i class="bi bi-filter-left me-1"></i>狀態篩選</label>
                <select name="statusFilter" class="form-select order-input" asp-items="ViewBag.StatusList">
                    <option value="" class="text-white-50">-- 請選擇 --</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-order-action w-100 py-2">
                    <i class="bi bi- lightning-charge-fill me-2"></i>查詢
                </button>
            </div>
            <div class="col-md-1">
                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2" style="font-size: 1rem;">
                    <i class="bi bi-arrow-counterclockwise"></i>取消
                </a>
            </div>
        </form>
    </div>

    

    @* --- [Data Matrix] --- *@
    <div class="table-container">
        <table class="table order-table">
            <thead>
                <tr class="text-center">
                    <th>訂單編號</th>
                    <th>會員姓名</th>
                    <th>建立時間</th>
                    <th>付款狀態</th>
                    <th>訂單狀態</th>
                    <th>問題</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="font-monospace text-info">@item.OrderID</td>
                        <td class="opacity-75">@item.Member?.Name</td>
                        <td class="font-monospace opacity-50">@item.OrderCreatedTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (item.PaymentStatus)
                            {
                                <span class="status-badge tag-paid-outline">已付款</span>
                            }
                            else
                            {
                                <span class="status-badge tag-secondary">未付款</span>
                            }
                        </td>
                        <td>
                            @{
                                var (tagClass, statusName) = item.OrderStatusID switch
                                {
                                    "Y" => ("tag-active", item.OrderStatus?.OrderStatusName),
                                    "C" => ("tag-danger", item.OrderStatus?.OrderStatusName),
                                    "N" => ("tag-warning", item.OrderStatus?.OrderStatusName),
                                    _ => ("tag-secondary", item.OrderStatus?.OrderStatusName)
                                };
                            }
                            <span class="status-badge @tagClass">@statusName</span>
                        </td>
                        <td class="text-center">
                            @if (item.Question != null && item.Question.Any())
                            {
                                <span class="status-badge tag-danger">
                                    <i class="bi bi-broadcast"></i> @item.Question.Count 個
                                </span>
                            }
                            else
                            {
                                <span class="opacity-25">-</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group">
                                @* 詳情按鈕：鎖定為青色 (Cyan) *@
                                <a asp-action="Details" asp-route-id="@item.OrderID" class="btn btn-sm btn-order-action btn-info-static px-3">
                                    <i class="bi bi-eye-fill me-2"></i>詳細
                                </a>

                                @* 審核按鈕：鎖定為警告黃 (Warning Yellow) *@
                                <a asp-action="Edit" asp-route-id="@item.OrderID" class="btn btn-sm btn-order-action btn-audit-static px-3">
                                    <i class="bi bi-shield-check me-2"></i>審核
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
</div>