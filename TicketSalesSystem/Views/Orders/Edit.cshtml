@model TicketSalesSystem.Models.Order

@{
    ViewData["Title"] = "訂單修改";
    // 判斷是否鎖定
    bool isLocked = ViewBag.IsLocked ?? false;
}

@* 🚩 載入戰術規格 CSS *@
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Order/OrderEdit.css" asp-append-version="true" />

@* 🚩 1. 頂部警示區：只有鎖定時顯示 *@
@if (isLocked)
{
    <div class="alert alert-warning border-3 border-warning d-flex align-items-center mb-4 shadow-sm animate__animated animate__fadeIn" role="alert">
        <i class="bi bi-shield-lock-fill fs-3 me-3"></i>
        <div>
            <h5 class="alert-heading fw-bold mb-1">訂單已鎖定</h5>
            <p class="mb-0 small">此訂單已有票券完成核銷進場作業，系統已停用編輯權限以保護帳務原始數據。</p>
        </div>
    </div>
}

<div class="order-management-scope admin-body">
    @* --- [2. 標頭] --- *@
    <div class="d-flex justify-content-between align-items-center mb-5 tech-label border-bottom border-info border-opacity-25 pb-3">
        <h1 class="neon-header m-0">
            <i class="bi bi-terminal-fill me-3"></i>訂單編號: @Model.OrderID
            @if (isLocked)
            {
                <span class="badge bg-danger ms-2" style="font-size: 0.5em; vertical-align: middle;">唯讀</span>
            }
        </h1>
        <a asp-action="Index" class="btn-order-action btn-info-static px-4 py-2">
            <i class="bi bi-arrow-left me-2"></i>[ 回到清單 ]
        </a>
    </div>

    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="OrderID" />
        <input type="hidden" asp-for="MemberID" />
        <input type="hidden" asp-for="SessionID" />
        <input type="hidden" asp-for="OrderCreatedTime" />
        <input type="hidden" asp-for="PaymentMethodID" />

        @* 🚩 關鍵：使用 fieldset disabled 來一次鎖定所有內容 *@
        <fieldset @(isLocked ? "disabled" : "")>
            <div class="row g-4 align-items-stretch">

                @* --- [左側：決策核心區] --- *@
                <div class="col-lg-7">
                    <div class="cyber-card h-100 p-4">
                        <div class="audit-card-header mb-4">
                            <i class="bi bi-cpu me-2 ms-5"></i> 基本資料
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="opacity-100 small mb-2 text-info">會員帳號</label>
                                <input class="form-control audit-input" value="@Model.Member?.MemberLogin?.Account" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="opacity-100 small mb-2 text-info">會員姓名</label>
                                <input class="form-control audit-input" value="@Model.Member?.Name" readonly />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="OrderStatusID" class="text-warning small mb-2">狀態變更 STATUS</label>
                                <select asp-for="OrderStatusID" class="form-select order-input border-warning" asp-items="ViewBag.OrderStatusID"></select>
                            </div>
                            <div class="col-md-6">
                                <label class="opacity-100 small mb-2">支付狀態 PAYMENT</label>
                                <select class="form-select order-input opacity-50" asp-items="ViewBag.PaymentMethodID" disabled></select>
                            </div>
                        </div>

                        @* 付款核可區塊 *@
                        <div class="mt-5 p-4 border border-info border-opacity-20" style="background: rgba(0, 242, 255, 0.02); position: relative;">
                            <div class="form-check form-switch mb-4">
                                <input class="form-check-input" type="checkbox" asp-for="PaymentStatus" id="paySwitch" style="cursor:pointer;">
                                <label class="form-check-label fw-bold text-info" for="paySwitch">
                                    <i class="bi bi-cash-stack me-2"></i>付款核可：確認款項已入帳
                                </label>
                            </div>
                            <div>
                                <label asp-for="PaymentDescription" class="opacity-100 small mb-2">管理員備註 REMARKS</label>
                                <textarea asp-for="PaymentDescription" class="form-control audit-input" rows="3"
                                          placeholder="請輸入審核理由、手動退款或其他管理備註..."></textarea>
                            </div>
                        </div>

                        @* 執行按鈕 *@
                        <div class="mt-4">
                            @if (isLocked)
                            {
                                <button type="button" class="btn btn-secondary w-100 py-3 fw-bold opacity-50" disabled>
                                    <i class="bi bi-lock-fill me-2"></i> 訂單已鎖定，無法修改
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-order-action btn-audit-static w-100 py-3 fw-bold">
                                    <i class="bi bi-shield-check me-2"></i> 儲存並執行變更
                                </button>
                            }
                        </div>
                    </div>

                    @* --- 票券明細面板 --- *@
                    <div class="audit-card p-4 mt-4">
                        <div class="cyber-card h-100 p-4">
                            <div class="audit-card-header mb-4">
                                <i class="bi bi-ticket-perforated me-2 ms-5"></i> 票券明細
                            </div>
                            <div class="table-responsive custom-scroll">
                                <table class="table table-dark table-borderless align-middle mb-0">
                                    <thead class="border-bottom border-white border-opacity-10">
                                        <tr class="text-info small opacity-75">
                                            <th>活動名稱/場次</th>
                                            <th>票區</th>
                                            <th>座位</th>
                                            <th class="text-center">狀態</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var ticket in Model.Tickets)
                                        {
                                            <tr class="border-bottom border-white border-opacity-5">
                                                <td class="py-3">
                                                    <div class="text-white fw-bold">@ticket.Session?.Programme?.ProgrammeName</div>
                                                    <div class="font-monospace small text-info opacity-50">@ticket.Session?.StartTime.ToString("yyyy-MM-dd HH:mm")</div>
                                                </td>
                                                <td><span class="opacity-75">@ticket.TicketsArea?.TicketsAreaName</span></td>
                                                <td class="font-monospace text-warning">@ticket.RowIndex <span class="small">R</span> @ticket.SeatIndex <span class="small">S</span></td>
                                                <td class="text-center">
                                                    @{
                                                        string sId = ticket.TicketsStatusID?.Trim().ToUpper() ?? "";
                                                        var (bColor, bIcon, bLabel) = sId switch
                                                        {
                                                            "Y" => ("var(--tech-cyan)", "bi-check2-circle", "已進場"),
                                                            "A" => ("#28a745", "bi-broadcast", "待核銷"),
                                                            "C" => ("var(--tech-danger)", "bi-x-octagon", "已退票"),
                                                            _ => ("#888", "bi-slash-circle", "未知")
                                                        };
                                                    }
                                                    <div class="status-badge" style="color: @bColor; border-color: @bColor; font-size: 0.7rem; padding: 2px 8px; display: inline-flex; align-items: center;">
                                                        <i class="bi @bIcon me-1"></i> @bLabel
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                @* --- [右側：通訊與訊號日誌] --- *@
                <div class="col-lg-5">
                    <div class="cyber-card h-100 p-0 overflow-hidden" style="border-color: rgba(255, 204, 0, 0.3) !important;">
                        @* 1. 標頭：維持黃色警告風格 *@
                        <div class="audit-card-header text-dark fw-bold p-2 px-3" style="background: linear-gradient(90deg, #ffcc00, #aa8800) !important;">
                            <i class="bi bi-broadcast me-2 ms-5"></i> 客訴處理 
                        </div>

                        <div class="p-3">
                            <div class="custom-scroll pe-2" style="max-height: 850px; overflow-y: auto;">
                                @if (Model.Question != null && Model.Question.Any())
                                {
                                    @foreach (var q in Model.Question.OrderByDescending(x => x.CreatedTime))
                                    {
                                        @* --- 客訴主體區塊 --- *@
                                        <div class="mb-4 p-3 border-start border-warning border-3" style="background: rgba(255, 204, 0, 0.05);">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <span class="text-warning small font-monospace" style="font-size: 0.7rem;">
                                                    提問日期: @q.CreatedTime.ToString("yyyy.MM.dd HH:mm")
                                                </span>
                                                <a asp-controller="Questions" asp-action="Details" asp-route-id="@q.QuestionID" class="btn-cyber py-0 px-2" style="font-size: 0.95rem; color: #ffcc00; border: 1px solid #ffcc00; text-decoration: none;">
                                                    [ 前往處理 ]
                                                </a>
                                            </div>

                                            <div class="text-white mb-3" style="font-size: 0.9rem;">@q.QuestionDescription</div>

                                            @* --- 管理員回覆區塊 (你剛才寫的部分) --- *@
                                            @if (q.Reply != null && q.Reply.Any())
                                            {
                                                <div class="ms-3 border-start border-info border-opacity-50 ps-3 mt-2" style="background: rgba(0, 255, 255, 0.02);">
                                                    @foreach (var r in q.Reply.OrderBy(x => x.CreatedTime))
                                                    {
                                                        <div class="mb-3">
                                                            <div class="d-flex align-items-center mb-1">
                                                                <span class="badge bg-info text-dark me-2" style="font-size: 0.5rem; padding: 2px 4px;">回覆</span>
                                                                <div class="small text-info opacity-50 font-monospace" style="font-size: 0.6rem;">
                                                                    回覆日期: @r.CreatedTime.ToString("HH:mm") 負責人:@r.Employee?.Name
                                                                </div>
                                                            </div>
                                                            <div class="text-info opacity-75 small" style="line-height: 1.4;">@r.ReplyDescription</div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center py-5 opacity-25 font-monospace">目前此訂單無客訴</div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </fieldset>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // 戰術警示邏輯
        const statusSelect = document.querySelector('#OrderStatusID');
        const initialVal = statusSelect.value;
        statusSelect.addEventListener('change', function() {
            if (['C', 'N'].includes(this.value)) {
                if (!confirm("🚨 [注意!!]\n\n此操作將會註銷所有關聯票券並釋放座位庫存。\n該程序為不可逆轉之決策。確定要執行嗎？")) {
                    this.value = initialVal;
                }
            }
        });
    </script>
}