@using TicketSalesSystem.ViewModel.Order
@model VMUserOrderDetail

@{
    ViewData["Title"] = "訂單詳情";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-receipt"></i> 訂單詳情</h2>
        <a href="@Url.Action("Index", "Orders")" class="btn btn-outline-secondary">返回訂單列表</a>
    </div>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body bg-light rounded">
            <div class="row">
                <div class="col-md-6">
                    <h4 class="text-primary">@Model.ProgrammeName</h4>
                    <p class="mb-1"><strong>訂單編號：</strong>@Model.OrderID</p>
                    <p class="mb-1"><strong>演出時間：</strong>@Model.StartTime</p>
                    <p class="mb-1"><strong>演出地點：</strong>@Model.PlaceName</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-1"><strong>訂單狀態：</strong><span class="badge bg-success">@Model.OrderStatusName</span></p>
                    <h3 class="mt-2 text-danger">NT$ @Model.FinalAmount.ToString("N0")</h3>
                </div>
            </div>
        </div>
    </div>

    <h4 class="mb-3">您的票券</h4>

    <div class="row">
        @foreach (var ticket in Model.Tickets)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 ticket-card shadow-sm border-2">
                    <div class="card-header bg-dark text-white text-center py-2">
                        @ticket.TicketsAreaName
                    </div>
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h4 class="card-title fw-bold">@ticket.Seat</h4>
                        <div class="qr-section py-3">
                            @* 🚩 修改：移除 Model.IsPrintable，只檢查是否有核銷碼 *@
                            @if (!string.IsNullOrEmpty(ticket.CheckInCode))
                            {
                                <div class="qrcode-container d-flex justify-content-center" data-code="@ticket.CheckInCode"></div>
                                <p class="mt-3 mb-0 text-muted">核銷碼：<strong class="text-dark">@ticket.CheckInCode</strong></p>
                            }
                            else
                            {
                                @* 這是預防萬一該票券真的還沒產生 Code 的顯示 *@
                                <div class="text-center py-4 bg-light rounded">
                                    <i class="bi bi-hourglass-split text-secondary" style="font-size: 3rem;"></i>
                                    <p class="mt-2 mb-0 text-secondary">票券核銷碼產生中</p>
                                </div>
                            }
                        </div>
                        @* <div class="qr-section py-3">
                            (Model.IsPrintable && !string.IsNullOrEmpty(ticket.CheckInCode)
                            @if(!string.IsNullOrEmpty(ticket.CheckInCode))
                            {
                                <div class="qrcode-container d-flex justify-content-center" data-code="@ticket.CheckInCode"></div>
                                <p class="mt-3 mb-0 text-muted">核銷碼：<strong class="text-dark">@ticket.CheckInCode</strong></p>
                            }
                            else
                            {
                                <div class="text-center py-4 bg-light rounded">
                                    <i class="bi bi-lock-fill text-secondary" style="font-size: 3rem;"></i>
                                    <p class="mt-2 mb-0 text-secondary">票券尚未開放領取</p>
                                    <small class="text-muted">將於 @DateTime.Parse(Model.StartTime).AddDays(0).ToString("yyyy/MM/dd") 開放</small>
                                </div>
                            }
                        </div> *@
                    </div>
                    <div class="card-footer bg-transparent border-0 text-center pb-3">
                        <small class="text-muted">Ticket ID: @ticket.TicketsID</small>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 抓取所有帶有 data-code 的容器
            const qrContainers = document.querySelectorAll('.qrcode-container');

            qrContainers.forEach(container => {
                const code = container.getAttribute('data-code');
                if (code) {
                    new QRCode(container, {
                        text: code,
                        width: 160,
                        height: 160,
                        colorDark: "#000000",
                        colorLight: "#ffffff",
                        correctLevel: QRCode.CorrectLevel.H
                    });
                }
            });
        });
    </script>
}

<style>
    .ticket-card {
        border-style: dashed; /* 讓它看起來像票根 */
        transition: transform 0.2s;
    }

        .ticket-card:hover {
            transform: translateY(-5px);
        }

    .qrcode-container img {
        margin: 0 auto;
        padding: 10px;
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        border: 1px solid #eee;
    }
</style>