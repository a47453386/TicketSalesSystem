

@using TicketSalesSystem.ViewModel.Order
@model VMUserOrderDetail

@{
    ViewData["Title"] = "我的電子票夾";
    Layout = "_UserLayout";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("UserIndex", "Orders")" class="text-decoration-none">訂單查詢</a></li>
                <li class="breadcrumb-item active">票券詳情</li>
            </ol>
        </nav>
        <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
            <i class="bi bi-printer"></i> 列印本頁
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-5 bg-dark text-white overflow-hidden" style="border-radius: 15px;">
        <div class="card-body p-4 p-md-5">
            <div class="row">
                <div class="col-md-8">
                    <h2 class="fw-bold mb-3">@Model.ProgrammeName</h2>
                    <div class="d-flex flex-wrap gap-3 opacity-75">
                        <span><i class="bi bi-calendar3 me-2"></i>@Model.StartTime</span>
                        <span><i class="bi bi-geo-alt-fill me-2"></i>@Model.PlaceName</span>
                    </div>
                </div>
                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                    <div class="small text-white-50">訂單總額</div>
                    <div class="h2 fw-bold text-warning">NT$ @Model.FinalAmount.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="fw-bold mb-4 border-start border-primary border-4 ps-3">持票憑證</h4>
    
    <div class="row g-4">
        @foreach (var ticket in Model.Tickets)
        {
            <div class="col-md-6 col-lg-4">
                <div class="ticket-stub shadow-sm bg-white">
                    @* 票區標題 *@
                    <div class="ticket-header bg-primary text-white text-center py-2 fw-bold">
                        @ticket.TicketsAreaName
                    </div>

                    <div class="ticket-body text-center p-4">
                        <div class="mb-2 text-muted small">座位資訊 SEAT</div>
                        <h3 class="fw-bold mb-4">@ticket.Seat</h3>

                        <div class="qr-section">
                            @* 🚩 判斷邏輯：如果有 Code 則顯示 QR，否則顯示鎖定 *@
                            @if (!string.IsNullOrEmpty(ticket.CheckInCode))
                            {
                                <div class="qrcode-container d-flex justify-content-center mb-3" data-code="@ticket.CheckInCode"></div>
                                <div class="bg-light py-2 rounded">
                                    <small class="text-muted d-block">入場核銷碼</small>
                                    <code class="fs-5 fw-bold text-dark">@ticket.CheckInCode</code>
                                </div>
                            }
                            else
                            {
                                <div class="locked-section py-5 bg-light rounded-3 border border-dashed">
                                    <i class="bi bi-lock-fill text-secondary display-4"></i>
                                    <p class="mt-3 mb-1 fw-bold text-secondary">票券尚未開放領取</p>
                                    @* 假設活動當天前 3 天開放，這裡可以放你的邏輯時間 *@
                                    <small class="text-muted">開放時間：演出前 3 天</small>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="ticket-footer d-flex justify-content-between px-3 py-2 bg-light border-top small text-muted">
                        <span>ID: @ticket.TicketsID.Substring(0,8)...</span>
                        <span class="text-uppercase">E-Ticket</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* 票券外觀設計 */
    .ticket-stub {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #eee;
        transition: 0.3s;
    }
    .ticket-stub:hover {
        transform: translateY(-8px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

    /* 模擬實體票券的圓孔感 (選加) */
    .ticket-body {
        position: relative;
    }
    .ticket-body::before, .ticket-body::after {
        content: "";
        position: absolute;
        bottom: -10px;
        width: 20px;
        height: 20px;
        background-color: #f8f9fa; /* 與背景色一致 */
        border-radius: 50%;
        z-index: 10;
    }
    .ticket-body::before { left: -10px; }
    .ticket-body::after { right: -10px; }

    .qrcode-container canvas, .qrcode-container img {
        padding: 8px;
        background: white;
        border: 1px solid #eee;
        border-radius: 4px;
    }
</style>




@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 抓取所有帶有 data-code 的容器
            const qrContainers = document.querySelectorAll('.qrcode-container');

            qrContainers.forEach(container => {
                const code = container.getAttribute('data-code');
                if (code) {
                    new QRCode(container, {
                        text: code,
                        width: 160,
                        height: 160,
                        colorDark: "#000000",
                        colorLight: "#ffffff",
                        correctLevel: QRCode.CorrectLevel.H
                    });
                }
            });
        });
    </script>
}
