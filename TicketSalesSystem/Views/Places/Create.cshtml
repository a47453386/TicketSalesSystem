@model TicketSalesSystem.ViewModel.Place.VMPlaceCreate

@{
    ViewData["Title"] = "新增演出地點及配置";
}
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Place/PlaceCreate.css" asp-append-version="true" />
<div class="admin-body p-4">
    <form asp-action="Create" method="post" enctype="multipart/form-data" id="createForm">
        @Html.AntiForgeryToken()

        @* --- [1. 頁面標題] --- *@
        <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-info border-opacity-25 pb-3">
            <div>
                <h1 class="neon-header m-0">
                    <i class="bi bi-map me-3"></i>新增演出地點及配置
                </h1>
            </div>
        </div>

        @* --- [2. 第一步：基本資訊] --- *@
        <div class="cyber-card p-4 mb-4">
            <div class="tech-key mb-4">
                <i class="bi bi-geo-alt me-2"></i>步驟一: 演出地點基本資訊
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <label asp-for="PlaceName" class="tech-label">演出地點 </label>
                    <input asp-for="PlaceName" class="form-control tech-input" placeholder="請輸入場館名稱..." />
                    <span asp-validation-for="PlaceName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PlaceAddress" class="tech-label">演出地點地址</label>
                    <input asp-for="PlaceAddress" class="form-control tech-input" placeholder="請輸入場地地址..." />
                    <span asp-validation-for="PlaceAddress" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label class="tech-label">演出地點平面圖</label>
                    <input type="file" name="file" class="form-control tech-input" id="imageInput" accept="image/*" />

                    <div class="mt-3 preview-scanner d-inline-block p-2">
                        <img id="imagePreview" src="#" class="d-none" style="max-height: 250px; border: 1px solid rgba(0,242,255,0.3);" />
                        <div id="no-image-text" class="p-5 text-center text-white-50 small">
                            <i class="bi bi-camera fs-1 d-block mb-2"></i>
                            等待影像訊號輸入...
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* --- [3. 第二步：配置區域] --- *@
        <div class="cyber-card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="tech-key mb-0">
                    <i class="bi bi-layers me-2"></i>步驟二:區域配置
                </div>
                <button type="button" class="btn-cyber" id="btnAddVenue">
                    <i class="bi bi-plus-circle me-2"></i>新增區域
                </button>
            </div>

            <div class="table-responsive">
                <table class="cyber-table align-middle">
                    <thead>
                        <tr>
                            <th><div class="tech-key">區域名稱</div></th>
                            <th><div class="tech-key">樓層</div></th>
                            <th><div class="tech-key">顏色</div></th>
                            <th><div class="tech-key">排數 x 座位</div></th>
                            <th><div class="tech-key">系統狀態</div></th>
                            <th><div class="tech-key">刪除</div></th>
                        </tr>
                    </thead>
                    <tbody id="venueBody">
                        <tr class="venue-row">
                            <td class="p-2"><input name="VenueItem[0].VenueName" class="form-control tech-input py-1" required /></td>
                            <td class="p-2"><input name="VenueItem[0].FloorName" class="form-control tech-input py-1" required /></td>
                            <td class="p-2"><input name="VenueItem[0].AreaColor" type="color" class="form-control tech-input p-1" style="height: 38px;" value="#00f2ff" /></td>
                            <td class="p-2">
                                <div class="input-group">
                                    <input name="VenueItem[0].RowCount" type="number" class="form-control tech-input py-1" placeholder="ROW" min="1" />
                                    <span class="input-group-text bg-transparent text-info border-info border-opacity-25">X</span>
                                    <input name="VenueItem[0].SeatCount" type="number" class="form-control tech-input py-1" placeholder="SEAT" min="1" />
                                </div>
                            </td>
                            <td class="p-2">
                                <div class="input-group">
                                    <select name="VenueItem[0].VenueStatusID" class="form-select tech-input py-1" asp-items="ViewBag.VenueStatus">
                                        <option value="">請選擇</option>
                                    </select>
                                    <button class="btn btn-outline-info btn-status-modal py-0 px-2" type="button" data-mode="add"><i class="bi bi-plus"></i></button>
                                    <button class="btn btn-outline-warning btn-status-modal py-0 px-2" type="button" data-mode="edit"><i class="bi bi-pencil"></i></button>
                                </div>
                            </td>
                            <td class="text-center">
                                <button type="button" class="text-danger bg-transparent border-0 remove-venue" disabled>
                                    <i class="bi bi-trash3 fs-5"></i>
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        @* --- [4. 底部操作] --- *@
        <div class="d-flex justify-content-end gap-3 mt-5">
            <a asp-action="Index" class="btn-cyber" style="border-color: #666; color: #999;">
                <i class="bi bi-arrow-left-circle me-2"></i>回清單
            </a>
            <button type="submit" class="btn-cyber btn-cyber-success">
                <i class="bi bi-cloud-arrow-up me-2"></i>新增地點
            </button>
        </div>
    </form>
</div>

<partial name="_VenueStatusModal" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        window.venueConfig = {
            statusOptionsHtml: `@if (ViewBag.VenueStatus != null) {
                foreach (var item in (SelectList)ViewBag.VenueStatus)
                {
                        <option value="@item.Value">@item.Text</option>
                }
        }
`,
        updateStatusUrl: '@Url.Action("UpdateVenueStatus", "Places")',
        createStatusUrl: '@Url.Action("QuickCreateStatus", "Places")'
    };

    // 圖片預覽邏輯增強
    document.getElementById('imageInput').onchange = function (evt) {
        const [file] = this.files;
        if (file) {
            const preview = document.getElementById('imagePreview');
            preview.src = URL.createObjectURL(file);
            preview.classList.remove('d-none');
        }
    };
</script>
<script src="~/js/venue-logic.js?v=@DateTime.Now.Ticks"></script>
}