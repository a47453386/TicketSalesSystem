@model IEnumerable<TicketSalesSystem.Models.Place>

@{
    ViewData["Title"] = "場館系統總覽 / VENUE_MANAGEMENT";
}
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Place/PlaceIndex.css" asp-append-version="true" />

<div class="admin-body p-4">
    @* --- 頂部標題與操作 --- *@
    <div class="d-flex justify-content-between align-items-center mb-5 tech-label border-bottom border-info border-opacity-25 pb-3">
        <h1 class="neon-header m-0">
            <i class="bi bi-building-fill me-3"></i>場館系統總覽
        </h1>
        <a asp-action="Create" class="btn-cyber-primary">
            <i class="bi bi-plus-lg me-2"></i>[ 新增場館 ]
        </a>
    </div>

    @* --- 數據面板 --- *@
    <div class="cyber-card p-1">
        <div class="table-responsive">
            <table class="cyber-table align-middle">
                <thead>
                    <tr>
                        <th class="tech-key">平面圖</th>
                        <th class="tech-key">場館名稱</th>
                        <th class="tech-key">地址</th>
                        <th class="tech-key">區域數量</th>
                        <th class="tech-key">總座位數</th>
                        <th class="tech-key">系統操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="/Photos/VenueImage/@item.VenueImage"
                                     class="venue-img-tech"
                                     onerror="this.onerror=null; this.src='/images/default-place.jpg'" />
                            </td>
                            <td>
                                <div class="neon-text-sharp">@item.PlaceName</div>
                                <div class="text-info small opacity-75">ID: @item.PlaceID</div>
                            </td>
                            <td class="text-white">@item.PlaceAddress</td>
                            <td class="text-center">
                                <span class="badge-tech">@item.Venue.Count 區域</span>
                            </td>
                            <td class="text-center fw-bold">
                                <span class="text-pixel-yellow">
                                    @item.Venue.Sum(v => v.RowCount * v.SeatCount).ToString("N0")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@item.PlaceID" class="tech-link-icon px-2" title="查看數據">
                                        <i class="bi bi-eye fs-4"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.PlaceID" class="tech-link-icon px-2" title="修正參數">
                                        <i class="bi bi-pencil-square fs-4"></i>
                                    </a>
                                    <button type="button"
                                            class="tech-link-icon px-2 bg-transparent border-0 text-danger"
                                            style="text-shadow: 0 0 8px rgba(220, 53, 69, 0.5);"
                                            onclick="globalDelete('@item.PlaceID', '@item.PlaceName', 'Places')">
                                        <i class="bi bi-trash3-fill fs-4"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
