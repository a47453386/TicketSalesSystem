@model IEnumerable<TicketSalesSystem.Models.Place>

@{
    ViewData["Title"] = "場館管理";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-building-fill me-2"></i>場館管理</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>新增場館
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4" style="width: 100px;">縮圖</th>
                    <th>場館名稱 / ID</th>
                    <th>地址</th>
                    <th class="text-center">區域數量</th>
                    <th class="text-center">總載客量</th>
                    <th class="text-center" style="width: 200px;">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <img src="/Photos/VenueImage/@item.VenueImage"
                                 class="rounded shadow-sm"
                                 style="width: 60px; height: 45px; object-fit: cover;"
                                 onerror="this.src='/images/default-place.jpg'" />
                        </td>
                        <td>
                            <div class="fw-bold text-primary">@item.PlaceName</div>
                            <small class="text-muted">ID: @item.PlaceID</small>
                        </td>
                        <td>@item.PlaceAddress</td>
                        <td class="text-center">
                            <span class="badge bg-info text-dark">@item.Venue.Count 區</span>
                        </td>
                        <td class="text-center fw-bold">
                            @* 🚩 計算總座位：加總每一區的 (Row * Seat) *@
                            @item.Venue.Sum(v => v.RowCount * v.SeatCount).ToString("N0") 位
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Details" asp-route-id="@item.PlaceID" class="btn btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.PlaceID" class="btn btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-delete-id="@item.PlaceID"
                                        onclick="globalDelete('@item.PlaceID', '@item.PlaceName', 'Places')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>