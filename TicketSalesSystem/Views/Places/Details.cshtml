@model TicketSalesSystem.Models.Place

@{
    ViewData["Title"] = "場館詳情";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-info-circle-fill me-2 text-primary"></i>場館詳情</h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.PlaceID" class="btn btn-warning">
                <i class="bi bi-pencil me-1"></i>編輯此場館
            </a>
            <a asp-action="Index" class="btn btn-secondary">返回列表</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white fw-bold">基本資訊</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="text-muted small d-block">場館 ID</label>
                        <span class="fw-bold">@Model.PlaceID</span>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small d-block">場館名稱</label>
                        <span class="h5">@Model.PlaceName</span>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small d-block">場館地址</label>
                        <span>@Model.PlaceAddress</span>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white fw-bold">場地平面圖</div>
                <div class="card-body text-center">
                    <img src="/Photos/VenueImage/@Model.VenueImage" class="img-fluid rounded border"
                         onerror="this.src='/images/default-place.jpg'" />
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span class="fw-bold">區域配置列表</span>
                    <span class="badge bg-primary">共 @Model.Venue.Count 個區域</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>區域</th>
                                <th>樓層</th>
                                <th class="text-center">顏色</th>
                                <th class="text-center">配置</th>
                                <th class="text-center">小計座位</th>
                                <th class="text-center">目前狀態</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in Model.Venue.OrderBy(x => x.VenueID))
                            {
                                <tr>
                                    <td><strong>@v.VenueName</strong><br /><small class="text-muted">@v.VenueID</small></td>
                                    <td>@v.FloorName</td>
                                    <td class="text-center">
                                        <div class="rounded-circle mx-auto" style="width: 20px; height: 20px; background-color: @v.AreaColor; border: 1px solid #ddd;"></div>
                                    </td>
                                    <td class="text-center text-muted">@v.RowCount 排 x @v.SeatCount 座</td>
                                    <td class="text-center fw-bold">@(v.RowCount* v.SeatCount)</td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill @(v.VenueStatusID == "A" ? "bg-success" : "bg-secondary")">
                                            @v.VenueStatus?.VenueStatusName
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td colspan="4" class="text-end text-uppercase">總載客量合計：</td>
                                <td class="text-center text-danger">@Model.Venue.Sum(v => v.RowCount * v.SeatCount)</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>