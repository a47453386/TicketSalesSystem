@model TicketSalesSystem.ViewModel.Question.VMQuestionDetail

@{
    ViewData["Title"] = "我的問題";
    Layout = "_UserLayout";
}

<style>
    /* ============================================================
           [ 1. 核心規格 ] - 最小字體 1.2rem
           ============================================================ */
    .pixel-details-container {
        font-size: 1.2rem !important;
        color: #fff;
    }

    /* 數據分類標籤 (如：>>> 主旨) */
    .data-section-label {
        font-family: 'Press Start 2P', cursive;
        font-size: 1.5rem; /* 像素字體寬，縮小一點以求精緻 */
        color: var(--pixel-yellow) !important;
        display: block;
        margin-bottom: 10px;
        text-shadow: 0 0 5px var(--pixel-yellow);
    }

    /* ============================================================
           [ 2. 玩家提問框 ] - 已移除上方的 PLAYER_LOG 標籤
           ============================================================ */
    .pixel-chat-player {
        background-color: rgba(0, 0, 0, 0.85);
        border: 4px solid #fff;
        padding: 30px;
        margin-bottom: 40px;
        position: relative;
        box-shadow: 8px 8px 0px rgba(255, 255, 255, 0.1);
    }

    /* 內容文字樣式 */
    .pixel-content-text {
        line-height: 1.8;
        letter-spacing: 1px;
        margin-bottom: 20px;
        color: #fff;
    }

    /*  [ 3. 微型附件與時間戳記 ] */
    .attachment-tag-micro {
        font-size: 0.85rem !important; /*  附件縮小 */
        color: var(--pixel-blue) !important;
        border: 1px solid var(--pixel-blue);
        padding: 4px 12px;
        display: inline-flex;
        align-items: center;
        text-decoration: none;
        transition: 0.2s;
    }

        .attachment-tag-micro:hover {
            border-color: var(--pixel-yellow);
            color: var(--pixel-yellow) !important;
            background: rgba(255, 204, 0, 0.05);
        }

    .timestamp-log {
        font-family: monospace;
        font-size: 1.1rem !important;
        color: var(--pixel-text-muted);
        text-align: right;
        display: block;
        margin-top: 20px;
    }

    /* 狀態顯示 */
    .status-badge-pixel {
        font-family: 'Press Start 2P', cursive;
        border: 2px solid var(--pixel-blue);
        color: var(--pixel-blue);
        padding: 8px 15px;
        font-size: 0.8rem !important;
    }

    /* 管理員回覆框 */
    .pixel-chat-admin {
        background-color: rgba(0, 204, 255, 0.05);
        border: 4px solid var(--pixel-blue);
        padding: 25px;
        margin-left: 40px;
        margin-bottom: 30px;
    }
</style>

<div class="container py-5 pixel-details-container">

    @* ---頂部導覽 --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-secondary pb-4">
        <div>
            <h2 class="text-pixel-yellow fw-bold mb-1">[ 我的問題 ]</h2>
            <div class="text-pixel-muted fs-pixel-base">
                訂單編號: <span class="text-white">@(string.IsNullOrEmpty(Model.OrderID) ? "" : Model.OrderID)</span>|
                問題種類: <span class="text-white">@Model.QuestionTypeName</span>
            </div>
        </div>
        <a asp-controller="UserQuestions" asp-action="MyList" class="btn-pixel-text">[ 問題清單 ]</a>
    </div>

    @* --- 核心內容區塊 --- *@
    <div class="pixel-container-box">

        @* 標題與狀態 *@
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div class="text-white fw-bold m-0 fs-3">
                主旨: <span class="text-white fs-4 fw-bold">@Model.QuestionTitle</span>
            </div>

            @{
                var latestReply = Model.Reply?.OrderByDescending(r => r.CreatedTime).FirstOrDefault();
                string statusText = latestReply?.ReplyStatusID == "Y" ? "結案" : (latestReply != null ? "已回覆" : "待處理");
            }
            <div class="status-badge-pixel">
                狀態: @statusText
            </div>
        </div>

        @* ---提問對話框 (無頂部標籤) --- *@
        <div class="pixel-chat-player">
            @* B. 內容 (已移除重複項) *@
            <div class="mb-4">
                <span class="data-section-label"> 內容:</span>
                <div class="pixel-content-text">@Model.QuestionDescription</div>
            </div>

            @* C. 微型附件 *@
            @if (!string.IsNullOrEmpty(Model.UploadFile))
            {
                <div class="pt-3 border-top border-secondary">
                    <span class="data-section-label mb-2">附件:</span>
                    <a href="~/Photos/Question/@Model.UploadFile" target="_blank" class="attachment-tag-micro">
                        <i class="bi bi-paperclip me-1"></i> 檢視附件憑證
                    </a>
                </div>
            }

            @* D. 時間戳記 *@
            <span class="timestamp-log">上傳時間: @Model.CreatedTime.ToString("yyyy-MM-dd HH:mm:ss")</span>
        </div>

        @* --- 🚩 管理員回覆區域 --- *@
        <div class="mt-5">
            <h5 class="text-pixel-blue mb-4 fs-pixel-base">
                <i class="bi bi-cpu me-2"></i>回覆...
            </h5>

            @if (Model.Reply == null || !Model.Reply.Any())
            {
                <div class="text-center py-5 border border-secondary border-dashed opacity-50">
                    <p class="text-white mb-0">[ 尚無回傳]</p>
                </div>
            }
            else
            {
                @foreach (var reply in Model.Reply.OrderBy(r => r.CreatedTime))
                {
                    <div class="pixel-chat-admin">
                        <div class="text-white mb-4 lh-lg">@reply.ReplyDescription</div>                        
                    </div>
                }
            }
        </div>

    </div>
</div>