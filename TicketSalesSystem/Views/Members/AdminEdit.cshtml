@model TicketSalesSystem.ViewModel.Member.VMMemberAdminEdit

@{
    ViewData["Title"] = "後台會員管理 - 更新";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">會員列表</a></li>
            <li class="breadcrumb-item active">管理員編輯</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white p-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-shield-lock-fill me-2"></i> 會員權限管理</h5>
            <span class="badge bg-secondary">會員編號: @Model.MemberID</span>
        </div>

        <div class="card-body p-4">
            <form asp-action="AdminEdit" method="post">
                @* 🚩 必要隱藏欄位 *@
                <input type="hidden" asp-for="MemberID" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-8 border-end pe-md-4">
                        <h6 class="text-primary fw-bold mb-3 border-bottom pb-2">
                            <i class="bi bi-person-lines-fill me-1"></i> 基本聯絡資料
                        </h6>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Account" class="form-label text-muted small">登入帳號</label>
                                <input asp-for="Account" class="form-control-plaintext fw-bold ps-2 bg-light rounded" readonly />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-bold">姓名</label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Tel" class="form-label fw-bold text-danger">手機號碼 (唯讀)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-phone-mute"></i></span>
                                    @* 🚩 設定為 readonly 並加上 bg-light 灰色外觀 *@
                                    <input asp-for="Tel" class="form-control bg-light" readonly />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Birthday" class="form-label fw-bold">生日</label>
                                <input asp-for="Birthday" type="date" class="form-control" />
                                <span asp-validation-for="Birthday" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NationalID" class="form-label fw-bold">身分證字號</label>
                                <input asp-for="NationalID" type="text" class="form-control" />
                                <span asp-validation-for="NationalID" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">電子郵件</label>
                            <input asp-for="Email" class="form-control" readonly />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-bold">聯絡地址</label>
                            <textarea asp-for="Address" class="form-control" rows="2" readonly></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-4 ps-md-4">
                        <h6 class="text-danger fw-bold mb-3 border-bottom pb-2">
                            <i class="bi bi-gear-wide-connected me-1"></i> 帳號狀態控制
                        </h6>

                        <div class="p-3 bg-light rounded border mb-4">
                            <div class="mb-3">
                                <label asp-for="AccountStatusID" class="form-label fw-bold">帳號目前狀態</label>
                                <select asp-for="AccountStatusID" class="form-select border-primary" asp-items="ViewBag.AccountStatusID"></select>
                                <span asp-validation-for="AccountStatusID" class="text-danger"></span>
                            </div>

                            <hr />

                            <div class="form-check form-switch mt-3">
                                <input class="form-check-input" type="checkbox" asp-for="IsPhoneVerified" id="verifySwitch">
                                <label class="form-check-label fw-bold" for="verifySwitch">
                                    手機驗證狀態
                                </label>
                                <div class="form-text small">
                                    開啟後，該會員將被視為已完成簡訊驗證。
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info py-2 small shadow-sm">
                            <i class="bi bi-info-circle-fill me-1"></i>
                            若將狀態設為「停用 (D)」，該會員將無法進行登入操作。
                        </div>
                    </div>
                </div>

                <div class="mt-5 border-top pt-4 text-center">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 me-2">
                        <i class="bi bi-arrow-left"></i> 放棄並返回
                    </a>
                    <button type="submit" class="btn btn-danger px-5 fw-bold shadow">
                        <i class="bi bi-check-lg me-1"></i> 儲存管理員變更
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<div asp-validation-summary="All" class="text-danger"></div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}