@model TicketSalesSystem.ViewModel.Member.VMMemberAdminEdit

@{
    ViewData["Title"] = "會員權限核心 / IDENTITY_CONTROL";
}

@* 🚩 載入戰術規格 CSS *@
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Member/MemberEdit.css" asp-append-version="true" />


<div class="order-management-scope admin-body p-4">

    @* --- [1. 頂部標頭：HUD 診斷風格] --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-info border-opacity-25 pb-3">
        <div>
            @* <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb mb-0" style="background: transparent; padding: 0;">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-info opacity-75 text-decoration-none">會員清單</a></li>
                    <li class="breadcrumb-item active text-white" aria-current="page">會員資料更新</li>
                </ol>
            </nav> *@
            <h1 class="neon-header m-0">
                <i class="bi bi-shield-lock-fill me-3"></i>會員資料更新
            </h1>
        </div>
        <div class="text-end">
            <div class="tech-key mb-0" style="background: linear-gradient(90deg, var(--tech-danger), transparent 150%);">
                ID: @Model.MemberID
            </div>
        </div>
    </div>

    @* --- [2. 主編輯區域：Cyber-Card] --- *@
    <div class="cyber-card p-5">
        <form asp-action="AdminEdit" method="post">
            <input type="hidden" asp-for="MemberID" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4 font-monospace small"></div>

            <div class="row g-5">
                @* --- 左側：基本聯絡數據 --- *@
                <div class="col-lg-8 border-end border-info border-opacity-10">
                    <div class="tech-key mb-4">基本資料</div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Account" class="text-info small mb-2 d-block">帳號</label>
                            @* 唯讀欄位處理：看起來像終端輸出 *@
                            <div class="order-input opacity-50 bg-dark" style="cursor: not-allowed;">
                                @Model.Account
                                <input type="hidden" asp-for="Account" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Name" class="text-info small mb-2 d-block">姓名</label>
                            <input asp-for="Name" class="form-control order-input" placeholder="輸入姓名..." />
                            <span asp-validation-for="Name" class="text-danger small font-monospace"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label asp-for="Tel" class="text-danger small mb-2 d-block">手機 (唯讀)</label>
                            <input asp-for="Tel" class="form-control order-input opacity-100" readonly />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Birthday" class="text-info small mb-2 d-block">生日</label>
                            <input asp-for="Birthday" type="date" class="form-control order-input" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NationalID" class="text-info small mb-2 d-block">身分證號</label>
                            <input asp-for="NationalID" class="form-control order-input" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="text-info small mb-2 d-block">電子郵件</label>
                        <input asp-for="Email" class="form-control order-input opacity-100" readonly />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="text-info small mb-2 d-block">聯絡地址</label>
                        <textarea asp-for="Address" class="form-control order-input opacity-100" rows="2" readonly></textarea>
                    </div>
                </div>

                @* --- 右側：系統狀態控制 --- *@
                <div class="col-lg-4">
                    <div class="tech-key mb-4" style="background: linear-gradient(90deg, #ffcc00, transparent 120%);">系統鎖定</div>

                    <div class="p-4 mb-4" style="background: rgba(0,0,0,0.3); border: 1px solid var(--tech-border);">
                        <div class="mb-4">
                            <label asp-for="AccountStatusID" class="text-warning small mb-2 d-block">帳號狀態</label>
                            <select asp-for="AccountStatusID" class="form-select order-input border-warning" asp-items="ViewBag.AccountStatusID"></select>
                        </div>

                        <hr class="border-info opacity-25" />

                        <div class="form-check form-switch mt-4">
                            <input class="form-check-input" type="checkbox" asp-for="IsPhoneVerified" id="verifySwitch" style="cursor:pointer">
                            <label class="form-check-label text-white ms-2" for="verifySwitch">
                                驗證通過
                            </label>
                        </div>
                        <div class="small text-warning opacity-10 mt-2 font-monospace">
                            [ WARNING: 手動強制通過簡訊驗證程序 ]
                        </div>
                    </div>

                    <div class="alert  border border-info border-opacity-0 small text-info p-3">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        注意：若設為「停用」，該使用者將被禁止存取所有前端交易服務與票券資源。
                    </div>
                </div>
            </div>

            @* --- 底部按鈕區 --- *@
            <div class="mt-5 pt-4 border-top border-info border-opacity-10 text-center">
                <a asp-action="Index" class="btn btn-outline-info px-4 me-3" style="border-radius: 0; clip-path: polygon(10% 0, 100% 0, 90% 100%, 0 100%);">
                    <i class="bi bi-arrow-left"></i> 回到清單
                </a>
                <button type="submit" class="btn btn-danger px-5 fw-bold" style="border-radius: 0; clip-path: polygon(0 0, 90% 0, 100% 100%, 10% 100%); box-shadow: 0 0 15px rgba(255,51,51,0.4);">
                    <i class="bi bi-shield-check me-2"></i> 更新並儲存
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}