@model TicketSalesSystem.Models.Member

@{
    ViewData["Title"] = "會員詳細資料";
}
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Member/MemberDetail.css" asp-append-version="true" />

<div class="order-management-scope admin-body p-4">

    @* --- [1. 頂部導航與標頭] --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-info border-opacity-25 pb-3">
        <div>
@*             <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb m-0 p-0 bg-transparent">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-info text-decoration-none opacity-50">MEMBER_LIST</a></li>
                    <li class="breadcrumb-item active text-white opacity-100">DIAGNOSTICS</li>
                </ol>
            </nav> *@
            <h1 class="neon-header m-0">
                <i class="bi bi-person-badge-fill me-3"></i>會員詳細資訊
            </h1>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="AdminEdit" asp-route-id="@Model.MemberID" class="btn-cyber btn-cyber-warning">
                <i class="bi bi-shield-check me-2"></i>[ 會員資料更新 ]
            </a>
            <a asp-action="Index" class="btn-cyber">
                <i class="bi bi-arrow-left-circle me-2"></i>[ 回到清單 ]
            </a>
        
        </div>
    </div>

    <div class="row g-4 align-items-stretch">
        @* --- [2. 左側：識別與驗證終端] --- *@
        <div class="col-lg-4">
            <div class="cyber-card p-4 h-100 d-flex flex-column">
                <div class="tech-key mb-4">狀態</div>

                <div class="text-center py-4 mb-4" style="background: rgba(0,0,0,0.2); border: 1px solid rgba(0, 242, 255, 0.1);">
                    <div class="profile-scanner d-inline-flex align-items-center justify-content-center mb-3">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <h3 class="text-white fw-bold mb-1">@Model.Name</h3>
                    <div class="font-monospace text-info small opacity-100">@@@ViewData["Account"]</div>
                </div>

                @* 手機驗證終端 *@
                <div class="input-group">
                    @* 手機號碼欄位 *@
                    <input asp-for="Tel" class="form-control order-input opacity-100" readonly />

                    @if (Model.IsPhoneVerified)
                    {
                        @* 🚩 TRUE: 已驗證狀態 (靜態綠色) *@
                        <span class="btn btn-order-action btn-success-static disabled px-3">
                            <i class="bi bi-patch-check-fill me-1"></i> [ 已驗證 ]
                        </span>
                    }
                    else
                    {
                        @* 🚩 FALSE: 未驗證狀態 (標籤 + 發送按鈕) *@
                        <span class="btn btn-order-action btn-danger-static disabled px-2" style="border-right: none;">
                            <i class="bi bi-exclamation-octagon-fill me-1"></i> [ 未驗證 ]
                        </span>

                        <button type="button" class="btn btn-order-action btn-audit-static px-3" id="btnSendSMS">
                            <i class="bi bi-broadcast me-1"></i> [ DISPATCH_SIGNAL ]
                        </button>
                    }
                </div>

                <div class="mt-4 p-3 border border-info border-opacity-10 font-monospace">
                    <div class="text-info small opacity-50 mb-1">會員編號:</div>
                    <div class="small text-break opacity-75">@Model.MemberID</div>
                </div>
            </div>
        </div>

        @* --- [3. 右側：數據矩陣詳情] --- *@
        <div class="col-lg-8">
            <div class="cyber-card p-4 h-100">
                <div class="tech-key mb-4">基本資料</div>

                <div class="tech-data-row">
                    <div class="data-label">身份證字號</div>
                    <div class="data-value font-monospace">@Model.NationalID</div>
                </div>

                <div class="tech-data-row">
                    <div class="data-label">性別</div>
                    <div class="data-value">@(Model.Gender == true ? "男" : "女")</div>
                </div>

                <div class="tech-data-row">
                    <div class="data-label">生日</div>
                    <div class="data-value font-monospace">@Model.Birthday.ToString("yyyy-MM-dd")</div>
                </div>

                <div class="tech-data-row">
                    <div class="data-label">電話</div>
                    <div class="data-value text-info fw-bold font-monospace">@Model.Tel</div>
                </div>

                <div class="tech-data-row">
                    <div class="data-label">信箱</div>
                    <div class="data-value">@Model.Email</div>
                </div>

                <div class="tech-data-row">
                    <div class="data-label">地址</div>
                    <div class="data-value">@Model.Address</div>
                </div>

                <div class="tech-data-row border-0">
                    <div class="data-label">建立時間</div>
                    <div class="data-value font-monospace opacity-100">
                        @Model.CreatedDate.ToString("yyyy-MM-dd HH:mm:ss")
                    </div>
                </div>

                @* 底部修飾裝飾線 *@
                <div class="mt-5 pt-4 border-top border-info border-opacity-10 d-flex justify-content-between align-items-center">
                    <div class="small font-monospace text-info opacity-100">會員狀態</div>
                    <div class="text-end">
                        @* 🚩 顏色維持 ID 判斷，文字改為讀取 AccountStatusName *@
                        <span class="status-badge  @(Model.AccountStatusID == "A" ? "bg-success" : "bg-danger")">
                            <i class="bi bi-shield-shaded me-1"></i>
                            @(Model.AccountStatus?.AccountStatusName ?? "STATUS_UNKNOWN")
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            $(document).on("click", "#btnSendSMS", function() {
                var $btn = $(this);
                $btn.prop('disabled', true).text("SYNCING...");

                $.post("/Members/SendSmsCode", { id: "@Model.MemberID" }, function(res) {
                    if (res.success) {
                        $("#inputVerifyCode").val("");
                        $("#verifyBox").slideDown();
                        startTimer(60, $btn);
                    } else {
                        alert(res.message);
                        $btn.prop('disabled', false).text("RETRY_SIGNAL");
                    }
                }).fail(function() {
                    alert("SYSTEM_CRITICAL_ERROR");
                    $btn.prop('disabled', false).text("RETRY_SIGNAL");
                });
            });

            function startTimer(duration, $button) {
                var timer = duration;
                var interval = setInterval(function () {
                    var seconds = parseInt(timer % 60, 10);
                    $button.text(seconds + "s RE-ARM");
                    if (--timer < 0) {
                        clearInterval(interval);
                        $button.prop('disabled', false).text("RE-SEND SIGNAL");
                    }
                }, 1000);
            }

            $(document).on("click", "#btnSubmitSMS", function() {
                var code = $("#inputVerifyCode").val();
                if (code.length < 6) {
                    alert("INVALID_SIGNAL_LENGTH");
                    return;
                }
                $.post("/Members/SubmitVerifyCode", { id: "@Model.MemberID", inputCode: code }, function(res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("❌ VERIFICATION_FAILED: " + res.message);
                        $("#inputVerifyCode").val("");
                    }
                });
            });
        });
    </script>
}