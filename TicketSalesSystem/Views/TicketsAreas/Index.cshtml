@model IEnumerable<TicketSalesSystem.Models.TicketsArea>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TicketsAreaName)
            </th>
            
            <th>
                @Html.DisplayNameFor(model => model.TicketsAreaStatus)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Venue)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Programme)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TicketsAreaName)
            </td>
           
            <td>
                @Html.DisplayFor(modelItem => item.TicketsAreaStatus.TicketsAreaStatusID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Venue.VenueID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Programme.ProgrammeID)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.TicketsAreaID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.TicketsAreaID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.TicketsAreaID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
