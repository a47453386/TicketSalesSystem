@model IEnumerable<TicketSalesSystem.Models.Programme>
@{
    ViewData["Title"] = "Home Page";
    Layout = "_UserLayout";
}

<style>
    /* ============================================================
       [ 1. 核心規格 ] - 最小字體 1.2rem
       ============================================================ */
    body {
        font-size: 1.2rem !important;
    }

    /* 🚩 輪播圖設定：固定高度且「更扁」，移除外框 */
    .carousel-item img {
        height: 280px; /* 👈 縮減高度，呈現橫向長條感 */
        object-fit: cover;
        object-position: center;
        filter: brightness(0.85);
    }

    /* 🚩 下方區塊專用：霓虹外框樣式 [同步原外框風格] */
    .pixel-neon-section {
        background: rgba(0, 0, 0, 0.8);
        border: 4px solid var(--pixel-blue);
        box-shadow: 6px 6px 0px var(--pixel-pink); /* 增加厚度使視覺更統一 */
        padding: 20px;
        margin-bottom: 3rem;
        position: relative;
    }

    /* 🚩 HUD 狀態列：扁平化 */
    .public-status-hud {
        background: #000;
        border-bottom: 2px solid #222;
        color: #fff;
        padding: 8px 20px;
        font-family: 'Press Start 2P', cursive;
        font-size: 1.2rem !important;
    }

    /* 輪播指示器 */
    .carousel-indicators [data-bs-target] {
        width: 10px;
        height: 10px;
        background-color: var(--pixel-blue);
    }

    .carousel-item img {
        height: 280px;
        object-fit: cover;
        object-position: center;
        filter: brightness(0.8); /* 稍微調暗圖片，讓按鈕更突出 */
    }

    /* 🚩 強化：左右按鈕樣式 */
    .carousel-control-prev,
    .carousel-control-next {
        width: 5%; /* 縮小感應區，避免誤觸 */
        z-index: 10; /* 確保在最上層 */
        opacity: 0.8;
    }

    /* 自定義按鈕圖示：變成霓虹藍色 */
    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        background-color: rgba(0, 0, 0, 0.7); /* 黑底 */
        border: 2px solid var(--pixel-blue); /* 藍邊 */
        padding: 20px;
        background-size: 60%;
        box-shadow: 0 0 10px var(--pixel-blue); /* 發光 */
    }

    .carousel-control-prev:hover .carousel-control-prev-icon,
    .carousel-control-next:hover .carousel-control-next-icon {
        border-color: var(--pixel-pink);
        box-shadow: 0 0 15px var(--pixel-pink);
    }

    /* 保持下方霓虹區塊樣式 */
    .pixel-neon-section {
        background: rgba(0, 0, 0, 0.8);
        border: 4px solid var(--pixel-blue);
        box-shadow: 6px 6px 0px var(--pixel-pink);
        padding: 20px;
        margin-bottom: 3rem;
    }
</style>

@* --- 🚩 頂部輪播：純淨無框版 --- *@
<div id="carouselBanner" class="carousel slide mb-0" data-bs-ride="carousel">
    <div class="carousel-indicators">
        @for (int i = 0; i < Model.Count(); i++)
        {
            var activeClass = i == 0 ? "active" : "";
            <button type="button" data-bs-target="#carouselBanner" data-bs-slide-to="@i" class="@activeClass"></button>
        }
    </div>
    <div class="carousel-inner">
        @foreach (var item in Model)
        {
            var a = item == Model.First() ? "active" : "";
            <div class="carousel-item @a">
                <a asp-controller="Programmes" asp-action="Details" asp-route-id="@item.ProgrammeID">
                    <img src="~/Photos/CoverImage/@item.CoverImage" class="d-block w-100" alt="@item.ProgrammeName">
                    
                </a>
            </div>
        }
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselBanner" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselBanner" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>



@* --- 🚩 內容區塊：霓虹外框套用在此 --- *@
<div class="container pb-5 mt-5">
    
    @* 最新消息區塊 *@
    <div class="pixel-neon-section">
      
        @await Component.InvokeAsync("VCLatestNews")
    </div>

    @* 精選活動區塊 *@
    <div class="pixel-neon-section">
       
        @await Component.InvokeAsync("VCProgrammeThree")
    </div>

</div>