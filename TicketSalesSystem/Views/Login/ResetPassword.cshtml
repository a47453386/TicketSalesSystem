@model TicketSalesSystem.ViewModel.Login.VMResetPassword

@{
    Layout = "_UserLayout";
}
<div class="pixel-container mt-5">
    <div class="status-header">
        <h2 class="text-pixel-yellow">[ 重設密碼 ]</h2>
        <p class="text-white-50 small">身分已驗證，請重新設定密碼</p>
    </div>

    <form asp-action="ResetPassword" method="post" class="mt-4">
        @* 🚩 絕對不能忘記這個隱藏欄位 *@
        <input type="hidden" asp-for="Token" />

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="mb-3">
            <label class="text-info small mb-2">新密碼</label>
            <input type="password" asp-for="NewPassword" class="form-control pixel-input" placeholder="至少 6 位字元" />
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label class="text-info small mb-2">密碼再次確認</label>
            <input type="password" asp-for="ConfirmPassword" class="form-control pixel-input" placeholder="再次確認密碼" />
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>
        <div class="text-center ">
            <button type="submit" class="btn btn-outline-success fs-4">
                重設
            </button>
        </div>
        
    </form>
</div>

<style>
    /* 像素風輸入框樣式範例 */
    .pixel-input {
        background-color: #1a1a1a;
        border: 2px solid #333;
        color: #00ffcc;
        border-radius: 0;
        font-family: 'Courier New', Courier, monospace;
    }

        .pixel-input:focus {
            background-color: #000;
            border-color: #00ffcc;
            box-shadow: 0 0 10px rgba(0, 255, 204, 0.3);
            color: #00ffcc;
        }

    
</style>