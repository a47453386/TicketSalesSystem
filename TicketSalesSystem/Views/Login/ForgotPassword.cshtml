@model string 
@{
    Layout = "_UserLayout";
}

<style>
    /* 🚩 高亮度、無光條的平整像素按鈕 */
    .btn-pixel-bright-flat {
        font-family: 'Press Start 2P', cursive;
        /* 🚩 1. 稍微調小字體，像素感會更精緻 */
        font-size: 0.8rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        /* 🚩 2. 移除太強烈的文字發光，改用細微的硬陰影 */
        text-shadow: 2px 2px 0px rgba(0, 0, 0, 0.3);
        background-color: #220033 !important;
        color: #e0d1ff !important;
        border: none;
        /* 🚩 3. 調整內距：上下 8px，左右 20px */
        padding: 1px 15px ;
        position: relative;
        border-radius: 0 !important;
        /* 🚩 4. 把陰影顏色改回黑色 (#000)，厚度縮小到 2px 或 3px */
        box-shadow: 3px 3px 0px 0px #000;
        transition: none !important;
        display: inline-block; /* 確保它不會強制換行 */
    }

        /* 🚩 強制取消所有 Hover 效果 */
        .btn-pixel-bright-flat:hover,
        .btn-pixel-bright-flat:focus,
        .btn-pixel-bright-flat:active {
            background-color: #ffcc00 !important; /* 維持原色 */
            color: #000 !important; /* 維持原色 */
            transform: none !important; /* 不位移 */
            box-shadow: 4px 4px 0px 0px #000 !important; /* 陰影不動 */
            outline: none;
        }

</style>

<div class="pixel-container-box mt-5">
    <div class="text-start mb-4">
        <h2 class="text-pixel-yellow">[ 忘記密碼了? ]</h2>
        <hr class="border-secondary" />
    </div>

    @if (ViewBag.IsSuccess == true)
    {
        <div class="text-start py-5">
            <div class="mb-4">
                <i class="bi bi-check2-circle text-success" style="font-size: 3rem;"></i>
            </div>
            <p class="text-white">@ViewBag.Message</p>
            <p class="text-pixel-muted fs-5">請於 30 分鐘內點選重設連結，否則指令將自動失效。</p>
            <a asp-action="MemberLogin" class="btn btn-pixel-bright-flat mt-4">回到登入畫面</a>
        </div>
    }
    else
    {
        <p class="text-white fs-5 mb-4">請輸入註冊信箱...</p>

        <form asp-action="ForgotPassword" method="post">
            <div class="mb-4">
                <label class="text-info fs-5 mb-2">信箱</label>
                <input type="email" name="email" class="form-control pixel-input" 
                       placeholder="example@system.com" required />
                
                <span class="text-warning fs-5">
                    @Html.ValidationMessage("email")
                </span>
            </div>
            <div class="text-center">
                <button type="submit" class="btn btn-pixel-bright-flat w-10  py-3">
                    發送
                </button>
            </div>
            
        </form>

        <div class="mt-4 text-center">
            <a asp-action="MemberLogin" class="text-pixel-muted small text-decoration-none">
                ← 返回登入畫面
            </a>
        </div>
    }
</div>