<div class="admin-body p-3">
    <div class="text-center mb-4">
        <div class="d-inline-block p-2 cyber-card px-5">
            <h2 class="fw-bold mb-0 neon-text" style="letter-spacing: 5px;">
                <i class="bi bi-shield-shaded me-3"></i>售票資料管理系統
            </h2>
            <div class="text-end x-small opacity-75 mt-1">
                KERNEL_STATUS: <span class="text-success">ACTIVE</span> | 
                REFRESH: <span class="fw-bold">@DateTime.Now.ToString("HH:mm:ss")</span>
            </div>
        </div>
    </div>

    <div class="row text-center g-3 mb-4">
        <div class="col-md-3">
            <div class="cyber-card p-3 h-100">
                <div class="cyber-icon-circle"><i class="bi bi-currency-dollar fs-3"></i></div>
                <div class="text-muted small mb-1">總累計營收</div>
                <h3 class="fw-bold neon-text">NT$ @ViewBag.TotalSales.ToString("N0")</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="cyber-card p-3 h-100">
                <div class="cyber-icon-circle"><i class="bi bi-ticket-perforated fs-3"></i></div>
                <div class="text-muted small mb-1">已售票數 / 銷售率</div>
                <h3 class="fw-bold">@ViewBag.TotalTicketsSold <span class="fs-6 opacity-50">張</span> / <span class="text-info">@ViewBag.SalesRate%</span></h3>
                <div class="progress bg-dark mt-2" style="height: 4px; border: 1px solid var(--tech-cyan);">
                    <div class="progress-bar bg-info shadow-glow" style="width: @ViewBag.SalesRate%"></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="cyber-card p-3 h-100">
                <div class="cyber-icon-circle"><i class="bi bi-people-fill fs-3"></i></div>
                <div class="text-muted small mb-1">註冊會員總數</div>
                <h4 class="fw-bold neon-text">@ViewBag.MemberCount <span class="fs-6 opacity-50">USERS</span></h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="cyber-card p-3 h-100">
                <div class="cyber-icon-circle border-danger text-danger" style="box-shadow: 0 0 15px rgba(220, 53, 69, 0.4);"><i class="bi bi-exclamation-triangle fs-3"></i></div>
                <div class="text-muted small mb-1">待處理客服件</div>
                <h3 class="fw-bold text-danger">@ViewBag.PendingRefunds <span class="fs-6 opacity-50">PENDING</span></h3>
            </div>
        </div>
    </div>

    <div class="row g-2 mb-4 align-items-stretch">
        <div class="col-lg-5">
            <div class="cyber-card p-3 h-100">
                <div class="mb-3 border-bottom border-info border-opacity-25 pb-2">
                    <span class="fw-bold x-small text-info neon-text">
                        <i class="bi bi-bar-chart-fill me-1"></i>活動銷售地理區域分析
                    </span>
                </div>
                <div style="height: 180px; position: relative;">
                    <canvas id="salesAreaChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="cyber-card p-3 h-100">
                <div class="mb-3 border-bottom border-info border-opacity-25 pb-2">
                    <span class="fw-bold x-small text-info neon-text">
                        <i class="bi bi-activity me-1"></i>24 小時銷售趨勢監測
                    </span>
                </div>
                <div style="height: 180px; position: relative;">
                    <canvas id="salesVelocityChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-2">
            <div class="cyber-card h-100 d-flex flex-column justify-content-center align-items-center text-center p-2"
                 style="background: rgba(0, 242, 255, 0.05); border-left: 3px solid #198754;">

                <div class="spinner-grow text-success mb-3" role="status"
                     style="width: 30px; height: 30px; filter: drop-shadow(0 0 8px #198754);">
                </div>

                <div class="neon-text fw-bold mb-1" style="font-size: 0.8rem; letter-spacing: 2px;">清理服務</div>
                <div class="badge bg-success bg-opacity-25 text-success border border-success mb-3" style="font-size: 0.6rem;">
                    SERVICE_ACTIVE
                </div>

                <hr class="w-75 border-info opacity-25 my-2">

                <div class="x-small text-muted mb-1" style="font-size: 0.65rem;">每 10 分鐘自動執行</div>
                <div class="x-small text-info mb-3" style="font-size: 0.65rem;">掃描失效訂單中...</div>

                <div class="progress w-75" style="height: 2px; background: rgba(0,242,255,0.1);">
                    <div class="progress-bar bg-success progress-bar-striped progress-bar-animated" style="width: 100%"></div>
                </div>

                <div class="mt-3 x-small opacity-25 fw-bold" style="font-size: 0.5rem; font-family: 'Orbitron';">
                    PROC_ID: #8829-X
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-4">
            <div class="cyber-card p-3 h-100">
                <div class="mb-3 border-bottom border-danger pb-2 x-small fw-bold text-danger">
                    <i class="bi bi-bell-fill me-2"></i>系統即時預警 (LIVE)
                </div>
                <div class="overflow-auto" style="max-height: 250px;">
                    <div id="alertsContainer" class="list-group list-group-flush bg-transparent">
                        </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="cyber-card p-3 h-100">
                <div class="mb-3 border-bottom border-info pb-2 x-small fw-bold text-info">
                    <i class="bi bi-list-ul me-2"></i>最近交易數據串流
                </div>
                <div class="table-responsive">
                    <table class="w-100 cyber-table small text-center">
                        <thead>
                            <tr class="text-muted">
                                <th>時間</th>
                                <th>帳號</th>
                                <th>金額</th>
                                <th>狀態</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="small opacity-75">@item.OrderCreatedTime.ToString("HH:mm:ss")</td>
                                    <td>@item.Member?.Name</td>
                                    <td class="text-info fw-bold">@item.Tickets.Sum(t => t.TicketsArea.Price).ToString("C0")</td>
                                    <td>
                                        <span class="x-small @(item.OrderStatusID == "Y" ? "text-success" : "text-warning")">
                                            ● @item.OrderStatus?.OrderStatusName
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-3">
            <div class="cyber-card p-3 h-100">
                <div class="mb-3 border-bottom border-info pb-2 x-small fw-bold text-info">
                    <i class="bi bi-list-check me-2"></i>待辦執行清單
                </div>
                <div class="list-group list-group-flush small">
                    <a asp-controller="Questions" asp-action="Index" class="list-group-item bg-transparent text-cyan border-info border-opacity-25 d-flex justify-content-between align-items-center px-0">
                        <span>客服提問回覆</span><span class="badge rounded-pill bg-danger shadow-glow">@ViewBag.PendingRefunds</span>
                    </a>
                    <a asp-controller="Programmes" asp-action="AdminIndex" class="list-group-item bg-transparent text-cyan border-info border-opacity-25 d-flex justify-content-between align-items-center px-0">
                        <span>活動草稿審核</span><span class="badge rounded-pill bg-warning text-dark">@ViewBag.PendingProgramme</span>
                    </a>
                    <a asp-controller="FAQs" asp-action="Index" class="list-group-item bg-transparent text-cyan border-info border-opacity-25 d-flex justify-content-between align-items-center px-0">
                        <span>未發佈 FAQ</span><span class="badge rounded-pill bg-info">@ViewBag.PendingFAQ</span>
                    </a>
                    <a asp-controller="PublicNotices" asp-action="Index" class="list-group-item bg-transparent text-cyan border-0 d-flex justify-content-between align-items-center px-0">
                        <span>未發佈公告</span><span class="badge rounded-pill bg-secondary">@ViewBag.PendingPublicNotice</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
