@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // --- 0. 統一配置 ---
            const commonOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { boxWidth: 10, font: { size: 10 } }
                    }
                }
            };

            // --- 1. 活動銷售分析 (Bar Chart) ---
            fetch('/Admin/GetAreaSalesData')
                .then(res => res.json())
                .then(data => {
                    const el = document.getElementById('salesAreaChart');
                    if (!el) return; // 沒找到標籤就不跑，防止報錯

                    // 隱藏 Loading
                    const loader = document.getElementById('chartLoading');
                    if (loader) loader.style.display = 'none';

                    new Chart(el.getContext('2d'), {
                        type: 'bar',
                        data: {
                            labels: data.map(d => d.label),
                            datasets: [
                                { label: '已售', data: data.map(d => d.sold), backgroundColor: '#0d6efd', borderRadius: 4 },
                                { label: '剩餘', data: data.map(d => d.remaining), backgroundColor: '#f8f9fa', borderColor: '#dee2e6', borderWidth: 1, borderRadius: 4 }
                            ]
                        },
                        options: {
                            ...commonOptions,
                            indexAxis: 'y',
                            scales: { x: { stacked: true }, y: { stacked: true } }
                        }
                    });
                }).catch(err => console.error("活動圖表失敗:", err));

            // --- 2. 24小時銷售趨勢 (Line Chart) ---
            fetch('/Admin/GetSalesVelocity')
                .then(res => res.json())
                .then(data => {
                    const el = document.getElementById('salesVelocityChart');
                    if (!el) return;

                    new Chart(el.getContext('2d'), {
                        type: 'line',
                        data: {
                            labels: data.map(d => d.hour),
                            datasets: [{
                                label: '單量',
                                data: data.map(d => d.count),
                                borderColor: '#0d6efd',
                                tension: 0.4,
                                fill: true,
                                backgroundColor: 'rgba(13, 110, 253, 0.05)',
                                pointRadius: 2
                            }]
                        },
                        options: {
                            ...commonOptions,
                            plugins: { legend: { display: false } } // 趨勢圖不需要圖例
                        }
                    });
                }).catch(err => console.error("趨勢圖失敗:", err));

            // --- 3. 訂單狀態分佈 (Doughnut Chart) ---
           fetch('/Admin/GetOrderStatusDistribution')
            .then(res => res.json())
            .then(data => {
                const el = document.getElementById('orderStatusChart');
                if (!el) return;

                new Chart(el.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: data.map(d => d.status),
                        datasets: [{
                            data: data.map(d => d.count),
                            // 🚩 修改 1：換成 Cyberpunk 霓虹色系
                            backgroundColor: [
                                '#00f2ff', // 亮青色 (你的主色)
                                '#7000ff', // 電子紫
                                '#ff0055', // 霓虹紅
                                '#39ff14'  // 螢光綠
                            ],
                            borderColor: '#000b1a', // 🚩 修改 2：邊框換成背景深藍色，營造分離感
                            borderWidth: 2,
                            hoverOffset: 15,
                            hoverBorderColor: '#00f2ff', // 懸停時邊框發光
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '80%', // 🚩 讓圓環更細，看起來更精緻
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: {
                                    boxWidth: 10,
                                    padding: 15,
                                    // 🚩 修改 3：重要！將圖例文字改為亮青色，否則深色背景看不見
                                    color: '#00f2ff',
                                    font: {
                                        size: 11,
                                        family: "'Share Tech Mono', monospace" // 使用科技感字體
                                    }
                                }
                            },
                            tooltip: {
                                // 🚩 修改 4：提示框也要科技感
                                backgroundColor: 'rgba(0, 20, 40, 0.9)',
                                titleColor: '#00f2ff',
                                bodyColor: '#fff',
                                borderColor: '#00f2ff',
                                borderWidth: 1
                            }
                        }
                    }
                });
            }).catch(err => console.error("圓餅圖失敗:", err));

            // --- 4. 即時警示與通知邏輯 ---
            function loadLiveAlerts() {
                fetch('/Admin/GetLiveAlerts')
                    .then(res => res.json())
                    .then(data => {
                        const loading = document.getElementById('alertsLoading');
                        const container = document.getElementById('alertsContainer');
                        const noAlerts = document.getElementById('noAlertsMsg');

                        if (loading) loading.classList.add('d-none');
                        if (!container) return;

                        container.innerHTML = "";

                        if (!data || data.length === 0) {
                            if (noAlerts) noAlerts.classList.remove('d-none');
                            return;
                        }

                        if (noAlerts) noAlerts.classList.add('d-none');
                        data.forEach(alert => {
                            const icon = alert.level === 'danger' ? 'bi-exclamation-octagon-fill' : 'bi-exclamation-triangle-fill';
                            container.innerHTML += `
                                <div class="list-group-item border-start border-${alert.level} border-4 py-2 bg-light bg-opacity-10 mb-1">
                                    <h6 class="mb-0 fw-bold text-${alert.level}" style="font-size:0.75rem;"><i class="bi ${icon} me-1"></i>${alert.title}</h6>
                                    <p class="mb-0 x-small text-dark">${alert.message}</p>
                                </div>`;
                        });
                    });
            }

            loadLiveAlerts();
            setInterval(loadLiveAlerts, 60000); // 每一分鐘自動更新一次
        });
    </script>
}