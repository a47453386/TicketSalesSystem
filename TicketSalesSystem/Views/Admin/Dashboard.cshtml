@model IEnumerable<TicketSalesSystem.Models.Order>

@{
    ViewData["Title"] = "營運戰情室";
}

<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/Dashboard/Dashboard.css" asp-append-version="true" />
<div class="admin-body p-3">

    @* --- 1. 頂部標題 --- *@

    <div class="text-center mb-4">

        <div class="d-inline-block p-3 cyber-card px-5">

            <h1 class="neon-header mb-0">

                <i class="bi bi-shield-shaded me-3"></i>售票後台即時監控中心

            </h1>

        </div>

    </div>



    @* --- 第一列：核心 KPI 數據 (不變) --- *@

    <div class="row text-center g-3 mb-3">
        <div class="col-md-3">
            <div class="cyber-card p-3 h-100">
                <div class="tech-key">總累計營收</div>
                <h3 class="fw-bold mb-0 text-white">NT$ @ViewBag.TotalSales.ToString("N0")</h3>
            </div>
        </div>
        <div class="col-md-2">
            <div class="cyber-card p-3 h-100">
                <div class="tech-key">銷售率</div>
                <h3 class="fw-bold mb-0">@ViewBag.SalesRate%</h3>
                <div class="progress mt-2" style="height: 6px;">
                    <div class="progress-bar bg-info shadow-glow" style="width: @ViewBag.SalesRate%"></div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="cyber-card p-3 h-100 border-start border-success border-4">
                <div class="tech-key" style="background: linear-gradient(90deg, #39ff14, transparent 140%); color: #000;">當前進場數</div>
                <h3 class="fw-bold mb-0 text-white">@ViewBag.TotalAttendance <span class="small opacity-50">/ @ViewBag.TotalTicketsSold</span></h3>
                <div class="small text-success">進場率: @ViewBag.AttendanceRate%</div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="cyber-card p-3 h-100">
                <div class="tech-key">累計會員數</div>
                <h3 class="fw-bold mb-0">@ViewBag.MemberCount <span class="small opacity-50">位</span></h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="cyber-card p-3 h-100">
                <div class="tech-key" style="background: linear-gradient(90deg, var(--tech-danger), transparent 140%);">待處理客服</div>
                <h3 class="fw-bold text-danger mb-0">@ViewBag.PendingRefunds <span class="small opacity-50 text-white">Pending</span></h3>
            </div>
        </div>
    </div>



    @* --- 第二列：時間監控 (24H趨勢 + 背景日誌 + 狀態) --- *@

    <div class="row g-3 mb-3">

        @* 24H 銷售趨勢 (寬度佔 6) *@

        <div class="col-lg-6">

            <div class="cyber-card p-3 h-100">

                <div class="tech-key"><i class="bi bi-activity me-2"></i>24H 銷售趨勢</div>

                <div style="height: 200px;"><canvas id="salesVelocityChart"></canvas></div>

            </div>

        </div>



        @* 清理日誌 / 背景任務回報 (寬度佔 4) *@

        <div class="col-lg-4">

            <div class="cyber-card p-3 h-100">

                <div class="tech-key mb-2">背景任務日誌 (Live)</div>

                <div id="log-container" class="font-monospace p-2 custom-scroll" style="height: 180px; overflow-y: auto; background: #000; color: #0f0; font-size: 0.75rem; border: 1px solid var(--tech-cyan);">

                    >> 初始化監控系統...   

                </div>

            </div>

        </div>



        @* 數據回收狀態 (寬度佔 2) *@

        <div class="col-lg-2">
            <div class="cyber-card h-100 d-flex flex-column justify-content-center align-items-center p-2 text-center">
                @* Spinner 顏色由 JS 動態控制，初始不設顏色類別 *@
                <div id="status-spinner" class="spinner-grow mb-2 shadow-glow"
                     style="width: 3rem; height: 3rem; transition: all 0.5s ease;" role="status">
                </div>

                @* 標籤改為中文 *@
                <div class="tech-key mb-1" style="font-size: 2rem !important; padding: 2px 8px; letter-spacing: 1px;">
                    系統監測
                </div>

                @* 初始狀態文字改為中文 *@
                <div id="current-status-text" class="small text-white-50"
                     style="font-size: 1.2rem; transition: color 0.5s ease;">
                    系統待機中
                </div>
            </div>
        </div>

    </div>



    @* --- 第三列：深度分析與警告 (活動、狀態、預警、待處理) --- *@

    <div class="row g-3">

        @* 活動銷售分析 *@

        <div class="col-lg-3">
            <div class="cyber-card p-3 h-100 d-flex flex-column">
                <div class="tech-key d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-bar-chart-fill me-2"></i>活動銷售分析</span>
                    <span class="badge rounded-pill bg-success pulse-dot" style="font-size: 0.6rem;">LIVE</span>
                </div>

                <div class="flex-grow-1" style="height: 180px;">
                    <canvas id="salesAreaChart"></canvas>
                </div>

                <div class="mt-3">
                    <a asp-controller="Admin" asp-action="ActiveMonitorList"
                       class="btn-cyber-action w-100 text-center py-2">
                        <i class="bi bi-grid-3x3-gap-fill me-2"></i>即時票區監控
                    </a>
                    <small class="text-muted d-block mt-2 text-center" style="font-size: 0.7rem;">
                        * 僅顯示狀態為「開賣中」之活動
                    </small>
                </div>
            </div>
        </div>



        @* 訂單狀態分佈 *@

        <div class="col-lg-3">

            <div class="cyber-card p-3 h-100">

                <div class="tech-key"><i class="bi bi-pie-chart-fill me-2"></i>訂單狀態分佈</div>

                <div style="height: 200px;"><canvas id="orderStatusChart"></canvas></div>

            </div>

        </div>



        @* 場館、票區預警 *@

        <div class="col-lg-3">

            <div class="cyber-card p-3 h-100">

                <div class="tech-key" style="background: linear-gradient(90deg, var(--tech-danger),transparent 140%);">

                    <i class="bi bi-bell-fill me-2"></i>場館預警

                </div>

                <div class="overflow-auto custom-scroll mt-2" style="max-height: 180px;" id="alertsContainer">

                    @* AJAX 載入預警內容 *@

                </div>

            </div>

        </div>



        @* 待處理區域 *@

        <div class="col-lg-3">

            <div class="cyber-card p-3 h-100">

                <div class="tech-key"><i class="bi bi-list-check me-2"></i>系統待處理</div>

                <div class="list-group list-group-flush mt-2">

                    <a asp-controller="Questions" asp-action="Index" class="list-group-item bg-transparent text-white border-info border-opacity-10 d-flex justify-content-between px-0 py-1 small">

                        <span>客服提問</span><span class="badge rounded-pill bg-danger">@ViewBag.PendingRefunds</span>

                    </a>

                    <a asp-controller="Programmes" asp-action="AdminIndex" class="list-group-item bg-transparent text-white border-info border-opacity-10 d-flex justify-content-between px-0 py-1 small">

                        <span>活動審核</span><span class="badge rounded-pill bg-warning text-dark">@ViewBag.PendingProgramme</span>

                    </a>

                    <a asp-controller="PublicNotices" asp-action="Index" class="list-group-item bg-transparent text-white border-info border-opacity-10 d-flex justify-content-between px-0 py-1 small">

                        <span>未發公告</span><span class="badge rounded-pill bg-info">@ViewBag.PendingPublicNotice</span>

                    </a>

                    <a asp-controller="FAQs" asp-action="Index" class="list-group-item bg-transparent text-white border-0 d-flex justify-content-between px-0 py-1 small">

                        <span>未發 FAQ</span><span class="badge rounded-pill bg-success">@ViewBag.PendingFAQ</span>

                    </a>

                </div>

            </div>

        </div>

    </div>
    @* --- 5. 第四列：進場實況監控中心 (New) --- *@
    <div class="row g-3">
        @* 各場次進場率堆疊圖 *@
        <div class="col-lg-8">
            <div class="cyber-card p-3 h-100">
                <div class="tech-key" style="background: linear-gradient(90deg, #39ff14, transparent 140%); color: #000;">
                    <i class="bi bi-ticket-detailed-fill me-2"></i>活動現場進場率 (已核銷 vs 未核銷)
                </div>
                <div style="height: 250px;">
                    <canvas id="attendanceChart"></canvas>
                </div>
            </div>
        </div>

        @* 掃描槍流水日誌 *@
        <div class="col-lg-4">
            <div class="cyber-card p-3 h-100" style="border-color: #39ff14 !important;">
                <div class="tech-key mb-2" style="background: #39ff14; color: #000;">
                    <i class="bi bi-qr-code-scan me-2"></i>入口核銷流水 (Live Feed)
                </div>
                <div id="scanFeedContainer" class="font-monospace p-2 custom-scroll"
                     style="height: 210px; overflow-y: auto; background: rgba(0,0,0,0.9); border: 1px solid #39ff14;">
                    <div class="text-white-50 small">>> 等待入口掃描器訊號...</div>
                </div>
            </div>
        </div>
    </div>

</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/Admin/Dashboard/Dashboard.js" asp-append-version="true"></script>
}