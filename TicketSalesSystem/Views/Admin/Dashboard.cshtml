@model IEnumerable<TicketSalesSystem.Models.Order>

@{
    ViewData["Title"] = "營運戰情室";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center my-4">
        <h3 class="fw-bold text-dark mb-0"><i class="bi bi-speedometer2 me-2"></i>營運戰情室</h3>
        <div class="badge bg-dark px-3 py-2 shadow-sm">
            <i class="bi bi-clock-history me-1"></i> 最後更新: @DateTime.Now.ToString("yyy年MM月dd日 HH:mm:ss")
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-primary border-4">
                <div class="card-body">
                    <h6 class="text-muted small fw-bold text-uppercase">總銷售額</h6>
                    <div class="d-flex align-items-center">
                        <h3 class="fw-bold mb-0 text-primary">NT$ @ViewBag.TotalSales.ToString("N0")</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-success border-4">
                <div class="card-body">
                    <h6 class="text-muted small fw-bold text-uppercase">已售票數</h6>
                    <h3 class="fw-bold mb-0 text-success">@ViewBag.TotalTicketsSold 張</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-info border-4">
                <div class="card-body">
                    <h6 class="text-muted small fw-bold text-uppercase">總銷售率</h6>
                    <div class="d-flex align-items-center justify-content-between">
                        <h3 class="fw-bold mb-0 text-info">@ViewBag.SalesRate %</h3>
                        <div class="progress w-50" style="height: 10px;">
                            <div class="progress-bar bg-info" style="width: @ViewBag.SalesRate%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-warning border-4">
                <div class="card-body">
                    <h6 class="text-muted small fw-bold text-uppercase">註冊會員</h6>
                    <h3 class="fw-bold mb-0 text-warning">@ViewBag.MemberCount 位</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0 text-primary"><i class="bi bi-bar-chart-fill me-2"></i>票區銷售分析 (即時)</h6>
                    <span class="badge bg-light text-dark border">已售 vs 庫存</span>
                </div>
                <div class="card-body position-relative">
                    <div id="chartLoading" class="position-absolute top-50 start-50 translate-middle text-center">
                        <div class="spinner-border text-primary-subtle" role="status"></div>
                        <div class="small text-muted mt-2">數據載入中...</div>
                    </div>
                    <div style="min-height: 350px;">
                        <canvas id="salesAreaChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="fw-bold mb-0 text-danger"><i class="bi bi-list-task me-2"></i>管理待辦項目</h6>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        <a asp-controller="Question" asp-action="Index" asp-route-statusFilter="P" class="list-group-item list-group-item-action py-3 d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-chat-dots me-2 text-danger"></i>待處理客服提問</span>
                            <span class="badge @(ViewBag.PendingRefunds > 0 ? "bg-danger" : "bg-light text-muted") rounded-pill">@ViewBag.PendingRefunds</span>
                        </a>
                        <a asp-controller="Programmes" asp-action="AdminIndex" class="list-group-item list-group-item-action py-3 d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-pencil-square me-2 text-warning"></i>草稿狀態活動</span>
                            <span class="badge bg-warning text-dark rounded-pill">@ViewBag.PendingProgramme</span>
                        </a>
                        <a asp-controller="FAQs" asp-action="Index" class="list-group-item list-group-item-action py-3 d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-question-circle me-2 text-info"></i>未發佈 FAQ</span>
                            <span class="badge bg-info rounded-pill">@ViewBag.PendingFAQ</span>
                        </a>
                        <a asp-controller="PublicNotices" asp-action="Index" class="list-group-item list-group-item-action py-3 d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-megaphone me-2 text-secondary"></i>未發佈公告</span>
                            <span class="badge bg-secondary rounded-pill">@ViewBag.PendingPublicNotice</span>
                        </a>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm bg-dark text-white">
                <div class="card-body text-center py-4">
                    <i class="bi bi-shield-check display-6 text-success mb-2"></i>
                    <h6 class="fw-bold">系統異步清理服務</h6>
                    <p class="text-light opacity-50 small mb-0">運行狀態：正常</p>
                    <hr class="my-2 opacity-25">
                    <small class="text-light opacity-50">最後掃描: @DateTime.Now.ToString("HH:mm")</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0">最近 5 筆成交訂單</h5>
            <a asp-action="Index" asp-controller="Orders" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                所有訂單紀錄 <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">訂單編號</th>
                            <th>訂購人</th>
                            <th>票券明細</th>
                            <th>總額</th>
                            <th>下單時間</th>
                            <th>付款狀態</th>
                            <th class="text-end pe-4">功能</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-primary">@order.OrderID</td>
                                <td>
                                    <div class="fw-bold">@order.Member?.Name</div>
                                    <small class="text-muted">@order.MemberID</small>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">@order.Tickets.Count 張</span>
                                    <small class="text-muted ms-1">@order.Tickets.FirstOrDefault()?.TicketsArea?.TicketsAreaName</small>
                                </td>
                                <td class="fw-bold text-danger">$@order.Tickets.Sum(t => t.TicketsArea.Price).ToString("N0")</td>
                                <td class="small">@order.OrderCreatedTime.ToString("MM/dd HH:mm")</td>
                                <td>
                                    @if (order.PaymentStatus || order.OrderStatusID == "Y")
                                    {
                                        <span class="badge bg-success-subtle text-success">已付款</span>
                                    }
                                    else if (order.OrderStatusID == "N")
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">已失效</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning">待支付</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.OrderID" class="btn btn-sm btn-light border">
                                        <i class="bi bi-search text-primary"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // 🚩 AJAX 非同步抓取圖表數據
            fetch('/Admin/GetAreaSalesData')
                .then(response => {
                    if (!response.ok) throw new Error("API 請求失敗");
                    return response.json();
                })
                .then(data => {
                    // 數據回來後隱藏 Loading
                    document.getElementById('chartLoading').style.display = 'none';

                    const labels = data.map(item => item.label);
                    const soldData = data.map(item => item.sold);
                    const remainingData = data.map(item => item.remaining);

                    const ctx = document.getElementById('salesAreaChart').getContext('2d');
                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: labels,
                            datasets: [
                                {
                                    label: '已售出 (Sold)',
                                    data: soldData,
                                    backgroundColor: '#0d6efd',
                                    borderRadius: 4
                                },
                                {
                                    label: '剩餘庫存 (Remaining)',
                                    data: remainingData,
                                    backgroundColor: '#f8f9fa',
                                    borderColor: '#dee2e6',
                                    borderWidth: 1,
                                    borderRadius: 4
                                }
                            ]
                        },
                        options: {
                            indexAxis: 'y', // 🚩 橫向長條圖，適合顯示較長的票區名稱
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { position: 'bottom' }
                            },
                            scales: {
                                x: { stacked: true, grid: { display: false } },
                                y: { stacked: true, grid: { display: false } }
                            }
                        }
                    });
                })
                .catch(error => {
                    console.error("圖表載入錯誤:", error);
                    document.getElementById('chartLoading').innerHTML =
                        '<span class="text-danger small"><i class="bi bi-exclamation-circle"></i> 圖表載入失敗</span>';
                });
        });
    </script>
}