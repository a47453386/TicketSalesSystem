@model IEnumerable<TicketSalesSystem.Models.Order>

@{
    ViewData["Title"] = "營運戰情室";
}
<style>
    :root {
        --tech-cyan: #00f2ff;
        --tech-bg: #000b1a;
        --tech-border: rgba(0, 242, 255, 0.3);
        --panel-bg: rgba(0, 20, 40, 0.7);
    }

    /* 🚩 1. 背景升級：加入網格紋理 */
    body.admin-body {
        background-color: var(--tech-bg);
        /* 放射漸層 + 數位網格 */
        background-image: radial-gradient(circle at 50% 50%, #001a33 0%, #000b1a 100%), linear-gradient(var(--tech-border) 1px, transparent 1px), linear-gradient(90deg, var(--tech-border) 1px, transparent 1px);
        background-size: 100% 100%, 40px 40px, 40px 40px;
        color: var(--tech-cyan);
        font-family: 'Share Tech Mono', 'Segoe UI', monospace;
    }

    /* 🚩 2. 外框升級：改為裝甲斜切角 */
    .cyber-card {
        background: var(--panel-bg);
        border: 1px solid var(--tech-cyan);
        box-shadow: 0 0 15px rgba(0, 242, 255, 0.2);
        /* 核心變動：銳利的科技切角 */
        clip-path: polygon(0 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%);
        position: relative;
        transition: all 0.3s ease;
    }

        .cyber-card:hover {
            box-shadow: 0 0 25px rgba(0, 242, 255, 0.5);
            transform: translateY(-2px);
            background: rgba(0, 30, 60, 0.8);
        }

        /* 🚩 3. 裝飾性裝甲點：讓邊角看起來更厚實 */
        .cyber-card::after {
            content: "";
            position: absolute;
            bottom: 5px;
            right: 5px;
            width: 20px;
            height: 2px;
            background: var(--tech-cyan);
            transform: rotate(-45deg);
        }

    /* 🚩 4. 表格升級：數據串流感 */
    .cyber-table {
        border-collapse: separate;
        border-spacing: 0 5px;
    }

        .cyber-table thead tr {
            background: linear-gradient(90deg, rgba(0, 242, 255, 0.2), transparent) !important;
            border: none;
        }

        .cyber-table td {
            background: rgba(0, 242, 255, 0.03);
            border-top: 1px solid rgba(0, 242, 255, 0.1);
            border-bottom: 1px solid rgba(0, 242, 255, 0.1);
        }

    /* 🚩 5. 霓虹文字：層次感提升 */
    .neon-text {
        text-shadow: 0 0 5px var(--tech-cyan), 0 0 15px var(--tech-cyan);
        letter-spacing: 1px;
    }
</style>
