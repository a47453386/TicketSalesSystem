@model IEnumerable<TicketSalesSystem.Models.Order>

@{
    ViewData["Title"] = "營運戰情室";
}

<style>
    :root {
        --monitor-height: 210px; /* 🚩 統一底部三欄的高度，可視情況改為 180px 或 200px */
        --chart-height: 220px; /* 🚩 統一圖表層的高度 */
    }

    /* 1. 強制底部三欄等高 */
    .monitor-row .card {
        height: var(--monitor-height) !important;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    /* 2. 內部內容高度計算 (扣除卡片 Header 的 35px) */
    .monitor-body {
        height: calc(var(--monitor-height) - 35px);
        overflow-y: auto;
        overflow-x: hidden;
    }

    /* 3. 圓餅圖專用容器：完全置中 */
    .chart-wrapper {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 5px;
    }

    /* 4. 圖表列的高度控制 */
    .chart-row-height {
        height: var(--chart-height);
    }

    .x-small {
        font-size: 0.72rem !important;
    }

    .list-group-item {
        padding: 0.4rem 0.75rem !important;
        font-size: 0.75rem !important;
    }

    /* 捲軸美化 */
    .monitor-body::-webkit-scrollbar {
        width: 3px;
    }

    .monitor-body::-webkit-scrollbar-thumb {
        background: #cbd5e0;
        border-radius: 10px;
    }

    .x-small {
        /* 原本可能是 0.7rem 或 0.75rem */
        font-size: 0.95rem !important; /* 🚩 數字越大文字越大 */
    }
</style>

<div class="container-fluid px-3">
    <div class="d-flex justify-content-between align-items-center my-2">
        <div>
            <h5 class="fw-bold text-dark mb-0"><i class="bi bi-speedometer2 me-2"></i>營運監測中心</h5>
        </div>
        <div class="x-small">
            最後更新：<span class="fw-bold">@DateTime.Now.ToString("HH:mm:ss")</span>
        </div>
    </div>

    <div class="row g-2 mb-2">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-primary border-4 compact-card">
                <div class="card-body">
                    <div class="kpi-title">總累計營收</div>
                    <h4 class="text-primary fw-bold">NT$ @ViewBag.TotalSales.ToString("N0")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-success border-4 compact-card">
                <div class="card-body">
                    <div class="kpi-title">總已售票數</div>
                    <h4 class="text-success fw-bold">@ViewBag.TotalTicketsSold 張</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-info border-4 compact-card">
                <div class="card-body">
                    <div class="kpi-title">總銷售率</div>
                    <div class="d-flex align-items-center justify-content-between">
                        <h4 class="text-info fw-bold">@ViewBag.SalesRate%</h4>
                        <div class="progress w-50 ms-2">
                            <div class="progress-bar bg-info" style="width: @ViewBag.SalesRate%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-warning border-4 compact-card">
                <div class="card-body">
                    <div class="kpi-title">註冊會員數</div>
                    <h4 class="text-warning fw-bold">@ViewBag.MemberCount 位</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-2 mb-2">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm compact-card" style="height: var(--chart-height);">
                <div class="card-header border-0 d-flex justify-content-between align-items-center">
                    <span class="fw-bold x-small text-primary"><i class="bi bi-bar-chart-fill me-1"></i>活動銷售分析</span>
                </div>
                <div class="card-body position-relative">
                    <div id="chartLoading" class="position-absolute top-50 start-50 translate-middle"><div class="spinner-border spinner-border-sm text-primary"></div></div>
                    <div style="height: 160px;"><canvas id="salesAreaChart"></canvas></div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm compact-card" style="height: var(--chart-height);">
                <div class="card-header border-0"><span class="fw-bold x-small text-primary"><i class="bi bi-activity me-1"></i>24 小時銷售趨勢</span></div>
                <div class="card-body">
                    <div style="height: 160px;"><canvas id="salesVelocityChart"></canvas></div>
                </div>
            </div>
        </div>

        <div class="col-lg-2">
            <div class="card border-0 shadow-sm bg-dark text-white compact-card h-100 d-flex flex-column justify-content-center align-items-center text-center p-2">
                <div class="spinner-grow text-success mb-2" style="width: 20px; height: 20px;"></div>
                <div style="font-size: 0.7rem; font-weight: bold;">清理服務</div>
                <div class="text-success fw-bold" style="font-size: 0.75rem;">運行中</div>
                <hr class="w-75 my-2 opacity-25">
                <div class="x-small opacity-50">每 10 分鐘</div>
                <div class="x-small opacity-50">掃描失效訂單</div>
            </div>
        </div>
    </div>

    <div class="row g-2 monitor-row">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm compact-card">
                <div class="card-header border-0"><span class="fw-bold x-small text-danger"><i class="bi bi-bell-fill me-1"></i>系統即時預警</span></div>
                <div class="card-body p-0 monitor-body">
                    <div id="alertsLoading" class="text-center py-4"><div class="spinner-border spinner-border-sm text-muted"></div></div>
                    <div id="noAlertsMsg" class="text-center py-4 d-none">
                        <i class="bi bi-shield-check text-success fs-2 mb-1 d-block"></i>
                        <span class="text-muted x-small">系統狀態平安</span>
                    </div>
                    <div id="alertsContainer" class="list-group list-group-flush"></div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm compact-card">
                <div class="card-header border-0"><span class="fw-bold x-small text-dark"><i class="bi bi-pie-chart-fill me-1"></i>訂單狀態分佈</span></div>
                <div class="card-body p-1 monitor-body">
                    <div class="chart-wrapper">
                        <canvas id="orderStatusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm compact-card">
                <div class="card-header border-0"><span class="fw-bold x-small text-dark "><i class="bi bi-list-check me-1"></i>管理執行清單</span></div>
                <div class="card-body p-0 monitor-body">
                    <div class="list-group list-group-flush">
                        <a asp-controller="Question" asp-action="Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span>客服提問</span><span class="badge bg-danger rounded-pill">@ViewBag.PendingRefunds</span>
                        </a>
                        <a asp-controller="ProgrammeDTO" asp-action="AdminIndex" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span>草稿活動</span><span class="badge bg-warning text-dark rounded-pill">@ViewBag.PendingProgramme</span>
                        </a>
                        <a asp-controller="FAQs" asp-action="Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span>未發佈 FAQ</span><span class="badge bg-info rounded-pill">@ViewBag.PendingFAQ</span>
                        </a>
                        <a asp-controller="PublicNotices" asp-action="Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0">
                            <span>未發佈公告</span><span class="badge bg-secondary rounded-pill">@ViewBag.PendingPublicNotice</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // --- 0. 統一配置 ---
            const commonOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { boxWidth: 10, font: { size: 10 } }
                    }
                }
            };

            // --- 1. 活動銷售分析 (Bar Chart) ---
            fetch('/Admin/GetAreaSalesData')
                .then(res => res.json())
                .then(data => {
                    const el = document.getElementById('salesAreaChart');
                    if (!el) return; // 沒找到標籤就不跑，防止報錯

                    // 隱藏 Loading
                    const loader = document.getElementById('chartLoading');
                    if (loader) loader.style.display = 'none';

                    new Chart(el.getContext('2d'), {
                        type: 'bar',
                        data: {
                            labels: data.map(d => d.label),
                            datasets: [
                                { label: '已售', data: data.map(d => d.sold), backgroundColor: '#0d6efd', borderRadius: 4 },
                                { label: '剩餘', data: data.map(d => d.remaining), backgroundColor: '#f8f9fa', borderColor: '#dee2e6', borderWidth: 1, borderRadius: 4 }
                            ]
                        },
                        options: {
                            ...commonOptions,
                            indexAxis: 'y',
                            scales: { x: { stacked: true }, y: { stacked: true } }
                        }
                    });
                }).catch(err => console.error("活動圖表失敗:", err));

            // --- 2. 24小時銷售趨勢 (Line Chart) ---
            fetch('/Admin/GetSalesVelocity')
                .then(res => res.json())
                .then(data => {
                    const el = document.getElementById('salesVelocityChart');
                    if (!el) return;

                    new Chart(el.getContext('2d'), {
                        type: 'line',
                        data: {
                            labels: data.map(d => d.hour),
                            datasets: [{
                                label: '單量',
                                data: data.map(d => d.count),
                                borderColor: '#0d6efd',
                                tension: 0.4,
                                fill: true,
                                backgroundColor: 'rgba(13, 110, 253, 0.05)',
                                pointRadius: 2
                            }]
                        },
                        options: {
                            ...commonOptions,
                            plugins: { legend: { display: false } } // 趨勢圖不需要圖例
                        }
                    });
                }).catch(err => console.error("趨勢圖失敗:", err));

            // --- 3. 訂單狀態分佈 (Doughnut Chart) ---
            fetch('/Admin/GetOrderStatusDistribution')
                .then(res => res.json())
                .then(data => {
                    const el = document.getElementById('orderStatusChart');
                    if (!el) return;

                    new Chart(el.getContext('2d'), {
                        type: 'doughnut',
                        data: {
                            labels: data.map(d => d.status),
                            datasets: [{
                                data: data.map(d => d.count),
                                backgroundColor: ['#198754', '#ffc107', '#adb5bd', '#0dcaf0'],
                                borderWidth: 0,
                                hoverOffset: 10
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false, // 🚩 重要：讓它填滿我們設定的 150px 容器
                            cutout: '75%',
                            plugins: {
                                legend: {
                                position: 'right', // 🚩 改到右邊，避免吃掉上下空間
                                labels: { boxWidth: 8, font: { size: 10 } }
                                }
                            }
                        }
                    });
                }).catch(err => console.error("圓餅圖失敗:", err));

            // --- 4. 即時警示與通知邏輯 ---
            function loadLiveAlerts() {
                fetch('/Admin/GetLiveAlerts')
                    .then(res => res.json())
                    .then(data => {
                        const loading = document.getElementById('alertsLoading');
                        const container = document.getElementById('alertsContainer');
                        const noAlerts = document.getElementById('noAlertsMsg');

                        if (loading) loading.classList.add('d-none');
                        if (!container) return;

                        container.innerHTML = "";

                        if (!data || data.length === 0) {
                            if (noAlerts) noAlerts.classList.remove('d-none');
                            return;
                        }

                        if (noAlerts) noAlerts.classList.add('d-none');
                        data.forEach(alert => {
                            const icon = alert.level === 'danger' ? 'bi-exclamation-octagon-fill' : 'bi-exclamation-triangle-fill';
                            container.innerHTML += `
                                <div class="list-group-item border-start border-${alert.level} border-4 py-2 bg-light bg-opacity-10 mb-1">
                                    <h6 class="mb-0 fw-bold text-${alert.level}" style="font-size:0.75rem;"><i class="bi ${icon} me-1"></i>${alert.title}</h6>
                                    <p class="mb-0 x-small text-dark">${alert.message}</p>
                                </div>`;
                        });
                    });
            }

            loadLiveAlerts();
            setInterval(loadLiveAlerts, 60000); // 每一分鐘自動更新一次
        });
    </script>
}