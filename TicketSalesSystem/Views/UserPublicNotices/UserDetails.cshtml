@model TicketSalesSystem.Models.PublicNotice

@{
    ViewData["Title"] = Model.PublicNoticeTitle;
    Layout = "_UserLayout";
}
<style>
    .notice-content {
        color: #333;
        word-wrap: break-word;
    }

        /* 讓內容中的圖片不要爆出去 */
        .notice-content img {
            max-width: 100%;
            height: auto;
            border-radius: 8px;
            margin: 20px 0;
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <nav class="mb-4">
                <a asp-action="UserIndex" class="text-decoration-none text-secondary">
                    <i class="bi bi-chevron-left"></i> 返回公告列表
                </a>
            </nav>

            <header class="mb-5">
                <h1 class="fw-bold mb-3">@Model.PublicNoticeTitle</h1>
                <div class="d-flex align-items-center text-muted small border-top border-bottom py-3">
                    <div class="me-4">
                        <i class="bi bi-calendar3 me-2"></i>發布日期：@Model.CreatedTime.ToString("yyyy-MM-dd")
                    </div>
                    
                </div>
            </header>

            <article class="notice-content mb-5" style="line-height: 1.8; font-size: 1.1rem;">
                @* 如果你的內容包含 HTML 標籤，請使用 Html.Raw *@
                @Html.Raw(Model.PublicNoticeDescription?.Replace("\n", "<br/>"))
            </article>

            <div class="border-top pt-4 text-center">
                <p class="text-muted small">本公告內容受法律保護，轉載請註明出處。</p>
                
            </div>
        </div>
    </div>
</div>




