@model IEnumerable<TicketSalesSystem.Models.PublicNotice>

@{
    ViewData["Title"] = "最新消息";
    Layout = "_UserLayout";
}

<style>
    /* 🚩 專屬於最新消息的像素微調 */
    .notice-pixel-row {
        background-color: rgba(34, 0, 51, 0.6);
        border: 2px solid var(--pixel-blue);
        margin-bottom: 20px;
        transition: all 0.2s;
        position: relative;
    }

        .notice-pixel-row:hover {
            border-color: var(--pixel-pink);
            transform: translateX(10px); /* 🚩 像素選單經典位移 */
            background-color: rgba(255, 0, 204, 0.05);
        }

    /* 模擬左側的狀態指示燈 */
    .status-indicator {
        width: 8px;
        background-color: var(--pixel-blue);
        height: 100%;
        position: absolute;
        left: 0;
        top: 0;
    }

    .notice-pixel-row:hover .status-indicator {
        background-color: var(--pixel-pink);
        box-shadow: 0 0 10px var(--pixel-pink);
    }

    .timestamp-box {
        background-color: #000;
        padding: 5px 10px;
        border: 1px solid var(--pixel-blue);
        display: inline-block;
    }
</style>

<div class="container py-5">
    @* 🚩 頁面標題：廣播塔風格 *@
    <div class="pixel-container-box mb-5">
        <div class="text-center">
            <h2 class="text-pixel-yellow mb-0">[ 系統公告]</h2>
           @*  <p class="text-pixel-muted fs-pixel-small mt-2">DECRYPTING_LATEST_INTEL... STATUS: RECEIVING</p> *@
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            @if (!Model.Any())
            {
                <div class="pixel-container-box text-center py-5">
                    <i class="bi bi-broadcast text-pixel-muted display-1 d-block mb-3"></i>
                    <span class="text-pixel-muted">[ 系統更新中... ]</span>
                </div>
            }
            else
            {
                <div class="notice-list">
                    @foreach (var item in Model)
                    {
                        @* 🚩 像素廣播條目 *@
                        <div class="notice-pixel-row p-4">
                            <div class="status-indicator"></div>
                            <div class="row align-items-center">
                                @* 時間戳記區塊 *@
                                <div class="col-md-3 text-center text-md-start mb-3 mb-md-0">
                                    <div class="timestamp-box">
                                        <div class="text-pixel-blue fs-pixel-small mb-0">
                                            <i class="bi bi-clock me-2"></i>@item.CreatedTime.ToString("yyyy.MM.dd")
                                        </div>
                                    </div>
                                </div>

                                @* 內容區塊 *@
                                <div class="col-md-9 ps-md-4">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <h5 class="fw-bold mb-0">
                                            <a asp-action="UserDetails" asp-route-id="@item.PublicNoticeID"
                                               class="text-decoration-none text-white hover-yellow font-pixel-small">
                                                @item.PublicNoticeTitle
                                            </a>
                                        </h5>

                                        @* 像素文字按鈕 *@
                                        <a asp-action="UserDetails" asp-route-id="@item.PublicNoticeID" class="btn-pixel-text">
                                            [ 詳細說明 ] <i class="bi bi-caret-right-fill ms-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>