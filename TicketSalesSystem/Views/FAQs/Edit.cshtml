@model TicketSalesSystem.Models.FAQ

@{
    ViewData["Title"] = "常見問題更新";
}

@* 🚩 注入戰術樣式表 *@
<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/FAQ/FAQCreate.css" asp-append-version="true" />

<div class="order-management-scope admin-body p-4">

    @* --- [1. 頂部標頭：HUD 儀表板風格] --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-info border-opacity-25 pb-3">
        <div>
          @*   <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb m-0 p-0 bg-transparent">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-info text-decoration-none opacity-50">FAQ_REGISTRY</a></li>
                    <li class="breadcrumb-item active text-white">OVERRIDE_MODE</li>
                </ol>
            </nav> *@
            <h1 class="neon-header m-0">
                <i class="bi bi-pencil-square me-3"></i>@ViewData["Title"]
            </h1>
        </div>
        <a asp-action="Index" class="btn-cyber btn-cyber-warning px-4">
            <i class="bi bi-arrow-left me-2"></i>回清單
        </a>
    </div>

    @* --- [2. 主編輯卡片：Cyber-Card] --- *@
    <div class="cyber-card p-5">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger small font-monospace mb-4"></div>
            <input asp-for="FAQID" type="hidden" />

            <div class="row g-4">
                @* --- A. 問題標題 --- *@
                <div class="col-12">
                    <div class="tech-key">Q.標題</div>
                    <div class="mt-2">
                        <input asp-for="FAQTitle" class="form-control order-input" placeholder="請輸入標題..." />
                        <span asp-validation-for="FAQTitle" class="text-danger small"></span>
                    </div>
                </div>

                @* --- B. 答案內容 --- *@
                <div class="col-12">
                    <div class="tech-key">A.內容</div>
                    <div class="mt-2">
                        <textarea asp-for="FAQDescription" class="form-control order-input custom-scroll"
                                  rows="6" placeholder="請輸入內容..."></textarea>
                        <span asp-validation-for="FAQDescription" class="text-danger small"></span>
                    </div>
                </div>

                @* --- C. FAQ 分類 (通用 Add/Edit 類別) --- *@
                <div class="col-md-6">
                    <div class="tech-key">問題種類</div>
                    <div class="input-group mt-2">
                        <select asp-for="FAQTypeID" class="form-select order-input" asp-items="ViewBag.FAQTypeID" id="faqTypeSelect">
                            <option value="">-- 請選擇 --</option>
                        </select>
                        <button type="button" class="btn-cyber px-2 quick-add-btn" data-mode="Type">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                        <button type="button" class="btn-cyber btn-cyber-warning px-2 quick-edit-btn" data-mode="Type">
                            <i class="bi bi-pencil-square"></i>
                        </button>
                    </div>
                </div>

                @* --- D. 發佈狀態 (通用 Add/Edit 類別) --- *@
                <div class="col-md-6">
                    <div class="tech-key">發佈狀態</div>
                    <div class="input-group mt-2">
                        <select asp-for="FAQPublishStatusID" class="form-select order-input" asp-items="ViewBag.FAQPublishStatusID" id="faqStatusSelect">
                        </select>
                        <button type="button" class="btn-cyber px-2 quick-add-btn" data-mode="Status">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                        <button type="button" class="btn-cyber btn-cyber-warning px-2 quick-edit-btn" data-mode="Status">
                            <i class="bi bi-pencil-square"></i>
                        </button>
                    </div>
                </div>

                @* --- E. 執行操作員 (系統自動帶入) --- *@
                <div class="col-12">
                    <div class="tech-key">負責人</div>
                    <div class="mt-2 p-3 border border-info border-opacity-10 bg-dark bg-opacity-50">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-person-badge me-3 text-info fs-4"></i>
                            <div>
                                <span class="text-info opacity-50 small d-block font-monospace">負責人</span>
                                <span class="fs-5 text-white fw-bold">@User.Identity.Name</span>
                                <span class="ms-2 badge border border-info text-info small">由系統自行帶入</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* --- F. 提交按鈕 --- *@
                <div class="col-12 mt-5 pt-4 border-top border-info border-opacity-10 text-center">
                    <button type="submit" class="btn-cyber px-5 py-2 fs-5">
                        <i class="bi bi-save2-fill me-2"></i>更新並儲存
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <partial name="_FAQModalsPartial" />
}