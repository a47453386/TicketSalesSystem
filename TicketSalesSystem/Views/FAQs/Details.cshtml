@model TicketSalesSystem.Models.FAQ

@{
    ViewData["Title"] = "常見問題詳細資料";
}

<link rel="stylesheet" href="~/css/Admin/AdminCommon.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Admin/FAQ/FAQDetail.css" asp-append-version="true" />

<div class="admin-body p-4">

    @* --- [1. 頂部導覽與戰術操作按鈕] --- *@
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-info border-opacity-25 pb-3">
        <div>
            @* <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb m-0 p-0 bg-transparent" style="font-family: 'Share Tech Mono', monospace;">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-info text-decoration-none opacity-50">FAQ_REGISTRY</a></li>
                    <li class="breadcrumb-item active text-white">RECORD_#@Model.FAQID</li>
                </ol>
            </nav> *@
            <h1 class="neon-header m-0"><i class="bi bi-eye-fill me-3"></i>@ViewData["Title"]</h1>
        </div>
        <div class="d-flex gap-3">
            <a asp-action="Edit" asp-route-id="@Model.FAQID" class="btn-cyber btn-cyber-warning px-4">
                <i class="bi bi-pencil-square me-2"></i>更新
            </a>
            <a asp-action="Index" class="btn-cyber px-4">
                <i class="bi bi-arrow-left me-2"></i>回清單
            </a>
        </div>
    </div>

    <div class="row g-4">
        @* --- [2. 左側：核心數據內容] --- *@
        <div class="col-lg-8">
            <div class="cyber-card p-5 h-100">

                <div class="tech-key mb-2">Q.標題</div>
                <h2 class="text-white fw-bold mb-1" style="letter-spacing: 1px;">@Model.FAQTitle</h2>


                <hr class="my-3 border-info opacity-10">


                <div class="tech-key mb-2">A.詳細解答</div>
                <div class="custom-scroll pe-3" style="max-height: 500px; overflow-y: auto;">
                    <p class="fs-5 text-white" style="white-space: pre-line; line-height: 2; font-family: '微軟正黑體', sans-serif;">
                        @Model.FAQDescription
                    </p>
                </div>
                

            </div>
        </div>

        @* --- [3. 右側：管理資訊與安全性操作] --- *@
        <div class="col-lg-4">
            @* 管理資訊卡片 *@
            <div class="cyber-card p-4 mb-4">
                <div class="tech-key mb-4" style="font-size: 1rem !important;">管理資訊</div>

                <div class="info-row">
                    <span class="detail-label">常見問題編號</span>
                    <span class="font-monospace text-info">@Model.FAQID</span>
                </div>

                <div class="info-row">
                    <span class="detail-label">常見問題種類</span>
                    <span class="badge border border-info text-info bg-dark">@Model.FAQType?.FAQTypeName</span>
                </div>

                <div class="info-row">
                    <span class="detail-label">常見問題狀態</span>
                    @if (Model.FAQPublishStatusID == "Y")
                    {
                        <div class="status-badge">
                            <i class="bi bi-broadcast me-2"></i> 已發布
                        </div>
                    }
                    else
                    {
                        <div class="status-badge" style="color: #ffcc00; border-color: #ffcc00; background-color: rgba(40, 30, 0, 0.6) !important;">
                            <i class="bi bi-pencil-fill me-2"></i> @Model.FAQPublishStatus.FAQPublishStatusName
                        </div>
                    }
                </div>

                <div class="info-row border-0">
                    <span class="detail-label">負責人</span>
                    <div class="d-flex align-items-center mt-2">
                        <div class="bg-info bg-opacity-10 p-2 me-3" style="clip-path: polygon(20% 0%, 100% 0%, 80% 100%, 0% 100%);">
                            <i class="bi bi-person-bounding-box text-info fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-bold text-white">@Model.Employee?.Name</div>
                            <div class="small font-monospace opacity-50">ID: @Model.EmployeeID</div>
                        </div>
                    </div>
                </div>
            </div>

            @* 危險區域 *@
            @* <div class="cyber-card cyber-card-danger p-4">
                <div class="tech-key mb-3" style="background: linear-gradient(90deg, var(--tech-danger), transparent 120%);">CRITICAL_SECTION</div>
                <p class="small text-danger opacity-75 mb-4 font-monospace">
                    WARNING: Deleting this record is irreversible. Associated frontend cache will be purged immediately.
                </p>
                <button type="button" class="btn-cyber w-100 justify-content-center"
                        style="border-color: var(--tech-danger); color: var(--tech-danger);"
                        data-bs-toggle="modal" data-bs-target="#deleteModal">
                    <i class="bi bi-trash3-fill me-2"></i>TERMINATE_RECORD
                </button>
            </div> *@
        </div>
    </div>
</div>

