@model IEnumerable<TicketSalesSystem.Models.FAQ>

@{
    ViewData["Title"] = "常見問題管理";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-patch-question-fill me-2 text-primary"></i>常見問題管理</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>新增問題
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">問題標題</th>
                    <th>分類</th>
                    <th>最後修改人員</th>
                    <th class="text-center">發布狀態</th>
                    <th class="text-center" style="width: 180px;">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold">@item.FAQTitle</div>
                            <small class="text-muted text-truncate d-inline-block" style="max-width: 300px;">
                                @item.FAQDescription
                            </small>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border">@item.FAQType?.FAQTypeName</span>
                        </td>
                        <td>@item.Employee?.Name</td>
                        <td class="text-center">
                            @if (item.FAQPublishStatusID == "Y")
                            {
                                <span class="badge rounded-pill bg-success">已發布</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-secondary">草稿</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@item.FAQID" class="btn btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.FAQID" class="btn btn-outline-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-delete-id="@item.FAQID"
                                        onclick="globalDelete('@item.FAQID', '@Html.Raw(item.FAQTitle)', 'FAQs')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                            <form id="delete-form-@item.FAQID" asp-action="Delete" asp-route-id="@item.FAQID" method="post" style="display:none">
                                @Html.AntiForgeryToken()
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

